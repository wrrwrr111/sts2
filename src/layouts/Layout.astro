---
import '../styles/global.css';
import { getLangFromUrl, withLang } from "../lib/i18n";

const currentUrl = Astro.url;
const currentParams = new URLSearchParams(currentUrl.search);
const currentLang = getLangFromUrl(currentUrl);
const isEn = currentLang === "en";

// SEO配置
const siteTitle = isEn
	? 'Slay the Spire 2 Database | STS2 Compendium'
	: '杀戮尖塔2 中文资料库 | Slay the Spire 2 Database';
const siteDescription = isEn
	? 'A Slay the Spire 2 database for cards, characters, relics, potions, events, and monsters with filters and search.'
	: '杀戮尖塔2（Slay the Spire 2）中文资料库，收录卡牌、角色、遗物、药剂、事件与怪物信息，支持筛选与搜索。';
const siteKeywords = isEn
	? 'Slay the Spire 2,STS2,database,cards,characters,relics,potions,events,monsters'
	: '杀戮尖塔2,Slay the Spire 2,中文资料库,卡牌,角色,遗物,药剂,事件,怪物,中文翻译';
const siteAuthor = 'Baze';
const siteUrl = 'https://sts2.urarawin.com';
const siteImage = ''; // 如果有社交媒体分享图片的话
const currentNoLangQuery = new URLSearchParams(currentParams);
currentNoLangQuery.delete("lang");
const currentPathWithQuery = `${currentUrl.pathname}${
	currentNoLangQuery.toString() ? `?${currentNoLangQuery.toString()}` : ""
}`;
const zhHref = withLang(currentPathWithQuery, "zh");
const enHref = withLang(currentPathWithQuery, "en");
const siteJsonLd = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	name: isEn ? "Slay the Spire 2 Database" : "杀戮尖塔2 中文资料库",
	url: siteUrl,
	description: siteDescription,
	author: {
		"@type": "Organization",
		name: "STS2 中文社区",
	},
	inLanguage: isEn ? "en" : "zh-CN",
	potentialAction: {
		"@type": "SearchAction",
		target: `${siteUrl}/?search={search_term_string}`,
		"query-input": "required name=search_term_string",
	},
};
---

<!doctype html>
<html lang={isEn ? "en" : "zh-CN"}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- 基础SEO标签 -->
		<title>{siteTitle}</title>
		<meta name="description" content={siteDescription} />
		<meta name="keywords" content={siteKeywords} />
		<meta name="author" content={siteAuthor} />
		<meta name="generator" content={Astro.generator} />
		
		<!-- 搜索引擎抓取 -->
		<meta name="robots" content="index, follow" />
		<meta name="googlebot" content="index, follow" />
		
		<!-- 规范链接 (避免重复内容) -->
		<link rel="canonical" href={siteUrl} />
		
		<!-- Open Graph / Facebook 分享卡片 -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:title" content={siteTitle} />
		<meta property="og:description" content={siteDescription} />
		<meta property="og:site_name" content={isEn ? "Slay the Spire 2 Database" : "杀戮尖塔2 中文资料库"} />
		<meta property="og:locale" content={isEn ? "en_US" : "zh_CN"} />
		{siteImage && <meta property="og:image" content={siteImage} />}
		{siteImage && <meta property="og:image:alt" content={isEn ? "Slay the Spire 2 Database preview" : "杀戮尖塔2 中文资料库预览"} />}
		
		<!-- Twitter 分享卡片 -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={siteUrl} />
		<meta name="twitter:title" content={siteTitle} />
		<meta name="twitter:description" content={siteDescription} />
		{siteImage && <meta name="twitter:image" content={siteImage} />}
		{siteImage && <meta name="twitter:image:alt" content={isEn ? "Slay the Spire 2 Database preview" : "杀戮尖塔2 中文资料库预览"} />}
		
		<!-- 图标 -->
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		
		<!-- 主题颜色 -->
		<meta name="theme-color" content="#10121a" />
		<meta name="msapplication-TileColor" content="#10121a" />
		
		<!-- 额外的SEO优化标签 -->
		<meta name="application-name" content={isEn ? "STS2 Database" : "STS2 中文资料库"} />
		<meta name="category" content={isEn ? "Game Database" : "游戏数据库"} />
		
		<!-- 结构化数据 (JSON-LD) 帮助搜索引擎理解网站内容 -->
		<script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)}></script>
		<slot name="head" />
	</head>
	<body
		class="min-h-screen text-[#f2f2f0] bg-[radial-gradient(1200px_700px_at_20%_-10%,_#202235_0%,_#10121a_55%,_#0a0b10_100%)]"
		style="font-family: 'Noto Serif SC', 'Source Han Serif SC', 'Songti SC', 'STSong', Georgia, serif;"
	>
		<script is:inline>
			(() => {
				const url = new URL(window.location.href);
				const queryLang = url.searchParams.get("lang");
				if (queryLang !== "en" && queryLang !== "zh") return;
				url.searchParams.delete("lang");
				const path = url.pathname;
				const isEnPath = path === "/en" || path.startsWith("/en/");
				if (queryLang === "en" && !isEnPath) {
					url.pathname = path === "/" ? "/en" : `/en${path}`;
					window.location.replace(url.toString());
					return;
				}
				if (queryLang === "zh" && isEnPath) {
					url.pathname = path === "/en" ? "/" : path.slice(3) || "/";
					window.location.replace(url.toString());
				}
			})();
		</script>
		<div
			id="lang-switcher"
			class="fixed right-2 top-2 z-[999] flex items-center overflow-hidden rounded-full border border-white/15 bg-black/45 text-[10px] backdrop-blur-sm transition-opacity duration-200 sm:right-3 sm:top-3 sm:text-[11px]"
		>
			<a
				href={zhHref}
				aria-current={currentLang === "zh" ? "true" : undefined}
				class={`px-2 py-0.5 transition sm:px-2.5 sm:py-1 ${currentLang === "zh" ? "bg-white/20 text-white" : "text-white/70 hover:text-white"}`}
			>
				中
			</a>
			<a
				href={enHref}
				aria-current={currentLang === "en" ? "true" : undefined}
				class={`border-l border-white/10 px-2 py-0.5 transition sm:px-2.5 sm:py-1 ${currentLang === "en" ? "bg-white/20 text-white" : "text-white/70 hover:text-white"}`}
			>
				EN
			</a>
		</div>
		<button
			type="button"
			id="back-to-top"
			aria-label={isEn ? "Back to top" : "回到顶部"}
			class="fixed bottom-4 right-2 z-[998] hidden h-9 w-9 items-center justify-center rounded-full border border-white/20 bg-black/45 text-[12px] text-white/85 backdrop-blur-sm transition hover:bg-white/20 sm:bottom-5 sm:right-3"
		>
			↑
		</button>
		<script is:inline>
			(() => {
				const btn = document.getElementById("back-to-top");
				const langSwitcher = document.getElementById("lang-switcher");
				if (!btn) return;
				const update = () => {
					const scrollY = window.scrollY;
					const showBackToTop = scrollY > 260;
					btn.classList.toggle("hidden", !showBackToTop);
					btn.classList.toggle("flex", showBackToTop);
					if (langSwitcher) {
						const hideLang = scrollY > 180;
						langSwitcher.classList.toggle("opacity-0", hideLang);
						langSwitcher.classList.toggle("pointer-events-none", hideLang);
					}
				};
				window.addEventListener("scroll", update, { passive: true });
				btn.addEventListener("click", () => {
					window.scrollTo({ top: 0, behavior: "smooth" });
				});
				update();
			})();
		</script>
		<div class="min-h-screen flex flex-col">
			<main class="flex-1">
				<slot />
			</main>
			<footer class="border-t border-white/10 bg-black/20">
				<div class="mx-auto max-w-6xl px-4 py-3 flex flex-col items-center gap-2 text-center text-[11px] text-white/70 sm:flex-row sm:justify-center sm:gap-3">
					<p class="leading-tight">{isEn ? "Disclaimer: This project is for learning only. All content rights belong to their original owners." : "免责声明：本项目仅用于学习与交流，所有内容版权归原作者与版权方所有。"}</p>
					<a
						class="inline-flex items-center gap-1 rounded-full border border-white/15 bg-white/5 px-2 py-1 text-[11px] text-white/70 transition hover:border-white/30 hover:text-white"
						href="https://github.com/wrrwrr111/sts2"
						rel="noreferrer"
						target="_blank"
						aria-label={isEn ? "GitHub repository" : "GitHub 仓库"}
					>
						<svg
							class="h-[14px] w-[14px]"
							viewBox="0 0 24 24"
							aria-hidden="true"
							fill="currentColor"
						>
							<path
								d="M12 2.25c-5.52 0-10 4.48-10 10 0 4.42 2.87 8.17 6.84 9.49.5.09.68-.22.68-.48 0-.24-.01-.88-.01-1.72-2.78.6-3.36-1.34-3.36-1.34-.45-1.15-1.11-1.46-1.11-1.46-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.9 1.53 2.36 1.09 2.94.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.95 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.65 0 0 .84-.27 2.75 1.02A9.6 9.6 0 0 1 12 6.8c.85 0 1.71.11 2.5.33 1.9-1.29 2.75-1.02 2.75-1.02.55 1.38.2 2.4.1 2.65.64.7 1.03 1.59 1.03 2.68 0 3.85-2.35 4.7-4.58 4.94.36.32.69.94.69 1.9 0 1.37-.01 2.48-.01 2.82 0 .26.18.58.69.48A10.01 10.01 0 0 0 22 12.25c0-5.52-4.48-10-10-10Z"
							/>
						</svg>
						<span>GitHub</span>
					</a>
				</div>
			</footer>
		</div>
	</body>
</html>
