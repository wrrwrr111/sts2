---
import Layout from "../../layouts/Layout.astro";
import relicsData from "../../../data/relics.json";
import charactersData from "../../../data/characters.json";
import { formatRelicText } from "../../lib/relicText";
import TopNav from "../../components/TopNav.astro";
import { getLangFromUrl, pickText, withLang } from "../../lib/i18n";

type Relic = {
  id: string;
  name: string;
  name_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
  flavor?: string | null;
  flavor_zh?: string | null;
  rarity?: string | null;
  pool?: string | null;
  image_url?: string | null;
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";
const relics = relicsData as Relic[];
const characters = charactersData as Array<{
  id: string;
  name: string;
  name_zh?: string | null;
  color?: string | null;
}>;

const getName = (relic: Relic) => pickText(lang, relic.name_zh, relic.name, relic.id);
const getDesc = (relic: Relic) =>
  pickText(lang, relic.description_zh, relic.description);

const normalizeImageUrl = (url: string | null | undefined) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};

const getImage = (relic: Relic) =>
  normalizeImageUrl(relic.image_url ?? null) ??
  `/images/relics/${relic.id.toLowerCase()}.png`;

const rarityLabel: Record<string, string> = {
  Ancient: isEn ? "Ancient" : "古代",
  Common: isEn ? "Common" : "普通",
  Uncommon: isEn ? "Uncommon" : "罕见",
  Rare: isEn ? "Rare" : "稀有",
  Event: isEn ? "Event" : "事件",
  Starter: isEn ? "Starter" : "初始",
  Shop: isEn ? "Shop" : "商店",
  None: isEn ? "None" : "无",
  Unknown: isEn ? "Unknown" : "未知",
};
const poolLabel: Record<string, string> = {
  shared: isEn ? "Shared" : "共享",
};
for (const character of characters) {
  if (!character.color) continue;
  poolLabel[character.color] = pickText(
    lang,
    character.name_zh,
    character.name,
    character.id,
  );
}

const rarities = Array.from(
  new Set(relics.map((item) => item.rarity).filter(Boolean)),
) as string[];
const pools = Array.from(
  new Set(relics.map((item) => item.pool).filter(Boolean)),
) as string[];

const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(withLang(`${base}/relics`, lang), origin).toString();
const pageTitle = isEn
  ? "Relic Library | Slay the Spire 2 Database"
  : "遗物库 | 杀戮尖塔2 中文资料库";
const pageDescription = isEn
  ? `All Slay the Spire 2 relics (${relics.length} total), with rarity/pool filters and search.`
  : `收录杀戮尖塔2全部遗物，共 ${relics.length} 个。支持稀有度、来源筛选与搜索。`;

const t = {
  navLabel: isEn ? "Relics" : "遗物",
  title: isEn ? "Relic Compendium" : "遗物图鉴",
  count: isEn ? `${relics.length} relics` : `共 ${relics.length} 个遗物`,
  rarity: isEn ? "Rarity" : "稀有度",
  pool: isEn ? "Pool" : "来源",
  search: isEn ? "Search" : "搜索",
  all: isEn ? "All" : "全部",
  reset: isEn ? "Reset" : "重置",
  searchPlaceholder: isEn ? "Name / Description / Flavor" : "名称 / 描述 / 风味",
  unknown: isEn ? "Unknown" : "未知",
};
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
  </Fragment>
  <main class="px-4 pb-10 pt-12 sm:px-[6vw]" data-base-path={base}>
    <div class="mx-auto flex max-w-[1100px] flex-col gap-6">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
            {t.navLabel}
          </div>
          <h1 class="mt-2 text-[26px] font-semibold text-[#fdf0d8]">{t.title}</h1>
          <p class="mt-1 text-[#c4c7d6]">{t.count}</p>
        </div>
        <TopNav current="relics" basePath={base} lang={lang} />
      </div>

      <section
        class="grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] items-end gap-3 rounded-2xl border border-white/10 bg-[rgba(16,18,26,0.7)] px-[18px] py-[14px]"
        aria-label="Relic filters"
      >
        <label class="grid gap-1.5 text-[13px] text-[#b6bbcc]">
          <span>{t.rarity}</span>
          <select
            id="relic-filter-rarity"
            class="rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20"
          >
            <option value="all" class="bg-[#1a1c24] text-[#f4f4f1]">{t.all}</option>
            {rarities.map((r) => (
              <option value={r} class="bg-[#1a1c24] text-[#f4f4f1]">
                {rarityLabel[r] ?? r}
              </option>
            ))}
          </select>
        </label>

        <label class="grid gap-1.5 text-[13px] text-[#b6bbcc]">
          <span>{t.pool}</span>
          <select
            id="relic-filter-pool"
            class="rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20"
          >
            <option value="all" class="bg-[#1a1c24] text-[#f4f4f1]">{t.all}</option>
            {pools.map((p) => (
              <option value={p} class="bg-[#1a1c24] text-[#f4f4f1]">
                {poolLabel[p] ?? p}
              </option>
            ))}
          </select>
        </label>

        <label class="grid gap-1.5 text-[13px] text-[#b6bbcc]">
          <span>{t.search}</span>
          <input
            id="relic-filter-search"
            type="search"
            placeholder={t.searchPlaceholder}
            class="rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] placeholder:text-[#6f7486] appearance-none focus:outline-none focus:ring-1 focus:ring-white/20"
          />
        </label>

        <button
          type="button"
          id="relic-filter-reset"
          class="rounded-xl border border-white/20 bg-white/15 px-3.5 py-2.5 text-[#f7f1df] hover:bg-white/20 transition-colors"
        >
          {t.reset}
        </button>
      </section>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {relics.map((relic) => (
          <a
            href={withLang(`${base}/relic/${relic.id}`, lang)}
            class="relic-tile group relative overflow-hidden rounded-[14px] border border-white/10 bg-white/5 p-4 transition hover:border-white/25 hover:bg-white/10"
            data-relic="1"
            data-rarity-raw={relic.rarity ?? ""}
            data-pool-raw={relic.pool ?? ""}
            data-search={[
              getName(relic),
              getDesc(relic),
              pickText(lang, relic.flavor_zh, relic.flavor),
              relic.rarity ?? "",
              relic.pool ?? "",
            ]
              .join(" ")
              .toLowerCase()}
          >
            <div class="flex items-center gap-3">
              <div class="h-[56px] w-[56px] rounded-[10px] border border-white/10 bg-black/30 p-2">
                <img
                  class="h-full w-full object-contain"
                  src={`${base}${getImage(relic)}`}
                  alt={getName(relic)}
                  loading="lazy"
                />
              </div>
              <div class="min-w-0 flex-1">
                <div class="text-[14px] font-semibold text-[#fdf0d8]">
                  {getName(relic)}
                </div>
                <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                  {(rarityLabel[relic.rarity ?? ""] ?? relic.rarity ?? t.unknown).toUpperCase()} · {(poolLabel[relic.pool ?? ""] ?? relic.pool ?? "").toUpperCase()}
                </div>
              </div>
            </div>
            <div
              class="mt-3 text-[11px] leading-[1.3] text-[#f2e5cd]"
              set:html={formatRelicText(getDesc(relic), base)}
            />
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  const byId = (id: string): HTMLElement | null => document.getElementById(id);
  const rarityEl = byId("relic-filter-rarity") as HTMLSelectElement | null;
  const poolEl = byId("relic-filter-pool") as HTMLSelectElement | null;
  const searchEl = byId("relic-filter-search") as HTMLInputElement | null;
  const resetEl = byId("relic-filter-reset") as HTMLButtonElement | null;

  const applyFilters = () => {
    const rarity = rarityEl?.value ?? "all";
    const pool = poolEl?.value ?? "all";
    const query = (searchEl?.value ?? "").trim().toLowerCase();

    document.querySelectorAll("[data-relic]").forEach((node) => {
      const el = node as HTMLElement;
      const r = el.dataset.rarityRaw || "";
      const p = el.dataset.poolRaw || "";
      const s = el.dataset.search || "";

      const match =
        (rarity === "all" || r === rarity) &&
        (pool === "all" || p === pool) &&
        (!query || s.includes(query));

      el.style.display = match ? "" : "none";
    });
  };

  [rarityEl, poolEl].forEach((el) => {
    el?.addEventListener("change", applyFilters);
  });
  searchEl?.addEventListener("input", applyFilters);

  resetEl?.addEventListener("click", () => {
    if (rarityEl) rarityEl.value = "all";
    if (poolEl) poolEl.value = "all";
    if (searchEl) searchEl.value = "";
    applyFilters();
  });
</script>
