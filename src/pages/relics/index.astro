---
import Layout from "../../layouts/Layout.astro";
import relicsData from "../../../data/relics.json";
import charactersData from "../../../data/characters.json";
import { formatRelicText } from "../../lib/relicText";
import TopNav from "../../components/TopNav.astro";
import { getLangFromUrl, pickText, withLang } from "../../lib/i18n";

type Relic = {
  id: string;
  name: string;
  name_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
  flavor?: string | null;
  flavor_zh?: string | null;
  rarity?: string | null;
  pool?: string | null;
  image_url?: string | null;
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";
const relics = relicsData as Relic[];
const characters = charactersData as Array<{
  id: string;
  name: string;
  name_zh?: string | null;
  color?: string | null;
}>;

const getName = (relic: Relic) => pickText(lang, relic.name_zh, relic.name, relic.id);
const getDesc = (relic: Relic) =>
  pickText(lang, relic.description_zh, relic.description);

const normalizeImageUrl = (url: string | null | undefined) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};

const getImage = (relic: Relic) =>
  normalizeImageUrl(relic.image_url ?? null) ??
  `/images/relics/${relic.id.toLowerCase()}.png`;

const rarityLabel: Record<string, string> = {
  Ancient: isEn ? "Ancient" : "古代",
  Common: isEn ? "Common" : "普通",
  Uncommon: isEn ? "Uncommon" : "罕见",
  Rare: isEn ? "Rare" : "稀有",
  Event: isEn ? "Event" : "事件",
  Starter: isEn ? "Starter" : "初始",
  Shop: isEn ? "Shop" : "商店",
  None: isEn ? "None" : "无",
  Unknown: isEn ? "Unknown" : "未知",
};
const poolLabel: Record<string, string> = {
  shared: isEn ? "Shared" : "共享",
};
for (const character of characters) {
  if (!character.color) continue;
  poolLabel[character.color] = pickText(
    lang,
    character.name_zh,
    character.name,
    character.id,
  );
}

const rarities = Array.from(
  new Set(relics.map((item) => item.rarity).filter(Boolean)),
) as string[];
const pools = Array.from(
  new Set(relics.map((item) => item.pool).filter(Boolean)),
) as string[];

const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(withLang(`${base}/relics`, lang), origin).toString();
const pageTitle = isEn
  ? "Relic Library | Slay the Spire 2 Database"
  : "遗物库 | 杀戮尖塔2 中文资料库";
const pageDescription = isEn
  ? `All Slay the Spire 2 relics (${relics.length} total), with rarity/pool filters and search.`
  : `收录杀戮尖塔2全部遗物，共 ${relics.length} 个。支持稀有度、来源筛选与搜索。`;

const t = {
  navLabel: isEn ? "Relics" : "遗物",
  title: isEn ? "Relic Compendium" : "遗物图鉴",
  count: isEn ? `${relics.length} relics` : `共 ${relics.length} 个遗物`,
  rarity: isEn ? "Rarity" : "稀有度",
  pool: isEn ? "Pool" : "来源",
  search: isEn ? "Search" : "搜索",
  selectAll: isEn ? "All" : "全选",
  reset: isEn ? "Reset" : "重置",
  filters: isEn ? "Filters" : "筛选",
  expand: isEn ? "Expand" : "展开",
  collapse: isEn ? "Collapse" : "收起",
  searchPlaceholder: isEn ? "Name / Description / Flavor" : "名称 / 描述 / 细节",
  unknown: isEn ? "Unknown" : "未知",
};
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
  </Fragment>
  <main class="px-3 pb-8 pt-10 sm:px-[6vw] sm:pb-10 sm:pt-12" data-base-path={base}>
    <div class="mx-auto flex max-w-[1100px] flex-col gap-4 sm:gap-6">
      <div class="flex flex-wrap items-end justify-between gap-3 sm:gap-6">
        <div>
          <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
            {t.navLabel}
          </div>
          <h1 class="mt-2 text-[26px] font-semibold text-[#fdf0d8]">{t.title}</h1>
          <p class="mt-1 text-[#c4c7d6]">{t.count}</p>
        </div>
        <TopNav current="relics" basePath={base} lang={lang} />
      </div>

      <section
        class="flex flex-col gap-2 rounded-2xl border border-white/10 bg-[rgba(16,18,26,0.7)] px-3 py-3 sm:gap-3 sm:px-[18px] sm:py-[14px]"
        aria-label="Relic filters"
      >
        <div class="mb-1 flex items-center justify-between sm:hidden">
          <div class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">{t.filters}</div>
          <button
            type="button"
            id="relic-filter-toggle"
            data-label-expand={t.expand}
            data-label-collapse={t.collapse}
            class="h-8 rounded-[10px] border border-white/20 bg-white/10 px-3 text-[12px] text-[#f7f1df] transition hover:bg-white/20"
            aria-expanded="true"
          >
            {t.collapse}
          </button>
        </div>

        <div id="relic-filter-body" class="flex flex-col gap-3">
        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-start sm:gap-3">
          <span class="shrink-0 pt-1 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.rarity}</span>
          <div class="flex flex-wrap gap-2 sm:flex-1" data-filter-group="rarity">
            <button
              type="button"
              data-filter-all
              class="rounded-full border border-white/40 bg-white/20 px-3 py-1 text-[12px] text-[#fdf0d8] transition"
              aria-pressed="true"
            >
              {t.selectAll}
            </button>
            {rarities.map((r) => (
              <button
                type="button"
                data-filter-value={r}
                class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10"
                aria-pressed="false"
              >
                {rarityLabel[r] ?? r}
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-start sm:gap-3">
          <span class="shrink-0 pt-1 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.pool}</span>
          <div class="flex flex-wrap gap-2 sm:flex-1" data-filter-group="pool">
            <button
              type="button"
              data-filter-all
              class="rounded-full border border-white/40 bg-white/20 px-3 py-1 text-[12px] text-[#fdf0d8] transition"
              aria-pressed="true"
            >
              {t.selectAll}
            </button>
            {pools.map((p) => (
              <button
                type="button"
                data-filter-value={p}
                class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10"
                aria-pressed="false"
              >
                {poolLabel[p] ?? p}
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-center sm:gap-3">
          <span class="shrink-0 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.search}</span>
          <div class="flex flex-col gap-2 sm:flex-1 sm:flex-row">
            <input
              id="relic-filter-search"
              type="search"
              placeholder={t.searchPlaceholder}
              class="h-9 rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-0 text-[#f4f4f1] placeholder:text-[#6f7486] appearance-none focus:outline-none focus:ring-1 focus:ring-white/20 sm:flex-1"
            />
            <button
              type="button"
              id="relic-filter-reset"
              class="h-9 rounded-[10px] border border-white/20 bg-white/15 px-3 text-[#f7f1df] hover:bg-white/20 transition-colors"
            >
              {t.reset}
            </button>
          </div>
        </div>
        </div>
      </section>

      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {relics.map((relic) => (
          <a
            href={withLang(`${base}/relic/${relic.id}`, lang)}
            class="relic-tile group relative overflow-hidden rounded-[14px] border border-white/10 bg-white/5 p-4 transition hover:border-white/25 hover:bg-white/10"
            data-relic="1"
            data-rarity-raw={relic.rarity ?? ""}
            data-pool-raw={relic.pool ?? ""}
            data-search={[
              getName(relic),
              getDesc(relic),
              pickText(lang, relic.flavor_zh, relic.flavor),
              relic.rarity ?? "",
              relic.pool ?? "",
            ]
              .join(" ")
              .toLowerCase()}
          >
            <div class="flex items-center gap-3">
              <div class="h-[56px] w-[56px] rounded-[10px] border border-white/10 bg-black/30 p-2">
                <img
                  class="h-full w-full object-contain"
                  src={`${base}${getImage(relic)}`}
                  alt={getName(relic)}
                  loading="lazy"
                />
              </div>
              <div class="min-w-0 flex-1">
                <div class="text-[14px] font-semibold text-[#fdf0d8]">
                  {getName(relic)}
                </div>
                <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                  {(rarityLabel[relic.rarity ?? ""] ?? relic.rarity ?? t.unknown).toUpperCase()} · {(poolLabel[relic.pool ?? ""] ?? relic.pool ?? "").toUpperCase()}
                </div>
              </div>
            </div>
            <div
              class="mt-3 text-[11px] leading-[1.3] text-[#f2e5cd]"
              set:html={formatRelicText(getDesc(relic), base)}
            />
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  const byId = (id: string): HTMLElement | null => document.getElementById(id);
  const filterToggleEl = byId("relic-filter-toggle") as HTMLButtonElement | null;
  const filterBodyEl = byId("relic-filter-body") as HTMLElement | null;
  const searchEl = byId("relic-filter-search") as HTMLInputElement | null;
  const resetEl = byId("relic-filter-reset") as HTMLButtonElement | null;
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>("[data-filter-group]"),
  ).map((el) => ({
    el,
    name: el.dataset.filterGroup ?? "",
    values: Array.from(
      el.querySelectorAll<HTMLButtonElement>("[data-filter-value]"),
    )
      .map((btn) => btn.dataset.filterValue ?? "")
      .filter(Boolean),
    selected: new Set<string>(["all"]),
  }));
  const groupMap = new Map(groups.map((group) => [group.name, group]));

  const setupFilterCollapse = (
    toggleEl: HTMLButtonElement | null,
    bodyEl: HTMLElement | null,
  ) => {
    if (!toggleEl || !bodyEl) return;
    const mobileMq = window.matchMedia("(max-width: 639px)");
    let collapsed = mobileMq.matches;
    const render = () => {
      const shouldHide = mobileMq.matches && collapsed;
      bodyEl.classList.toggle("hidden", shouldHide);
      const expandLabel = toggleEl.dataset.labelExpand ?? "展开";
      const collapseLabel = toggleEl.dataset.labelCollapse ?? "收起";
      toggleEl.textContent = shouldHide ? expandLabel : collapseLabel;
      toggleEl.setAttribute("aria-expanded", shouldHide ? "false" : "true");
    };
    render();
    toggleEl.addEventListener("click", () => {
      collapsed = !collapsed;
      render();
    });
    const onMediaChange = () => {
      collapsed = mobileMq.matches;
      render();
    };
    if ("addEventListener" in mobileMq) {
      mobileMq.addEventListener("change", onMediaChange);
    } else {
      mobileMq.addListener(onMediaChange);
    }
  };

  setupFilterCollapse(filterToggleEl, filterBodyEl);

  const setBtnActive = (btn: HTMLButtonElement, active: boolean) => {
    btn.setAttribute("aria-pressed", active ? "true" : "false");
    btn.classList.toggle("border-white/40", active);
    btn.classList.toggle("bg-white/20", active);
    btn.classList.toggle("text-[#fdf0d8]", active);
    btn.classList.toggle("border-white/10", !active);
    btn.classList.toggle("bg-white/5", !active);
    btn.classList.toggle("text-[#cdd2e3]", !active);
  };

  const syncGroup = (group: (typeof groups)[number]) => {
    const isAll = group.selected.has("all");
    const allBtn = group.el.querySelector<HTMLButtonElement>("[data-filter-all]");
    if (allBtn) setBtnActive(allBtn, isAll);
    group.el
      .querySelectorAll<HTMLButtonElement>("[data-filter-value]")
      .forEach((btn) => {
        const val = btn.dataset.filterValue ?? "";
        setBtnActive(btn, !isAll && group.selected.has(val));
      });
  };

  const setGroupAll = (group: (typeof groups)[number]) => {
    group.selected = new Set(["all"]);
    syncGroup(group);
  };

  const toggleGroupValue = (group: (typeof groups)[number], value: string) => {
    if (group.selected.has("all")) group.selected.clear();
    if (group.selected.has(value)) group.selected.delete(value);
    else group.selected.add(value);
    if (group.selected.size === 0 || group.selected.size === group.values.length) {
      setGroupAll(group);
      return;
    }
    syncGroup(group);
  };

  const matchesGroup = (name: string, value: string) => {
    const group = groupMap.get(name);
    if (!group) return true;
    return group.selected.has("all") || group.selected.has(value);
  };

  const applyFilters = () => {
    const query = (searchEl?.value ?? "").trim().toLowerCase();

    document.querySelectorAll("[data-relic]").forEach((node) => {
      const el = node as HTMLElement;
      const r = el.dataset.rarityRaw || "";
      const p = el.dataset.poolRaw || "";
      const s = el.dataset.search || "";

      const match =
        matchesGroup("rarity", r) &&
        matchesGroup("pool", p) &&
        (!query || s.includes(query));

      el.style.display = match ? "" : "none";
    });
  };

  groups.forEach((group) => {
    const allBtn = group.el.querySelector<HTMLButtonElement>("[data-filter-all]");
    allBtn?.addEventListener("click", () => {
      setGroupAll(group);
      applyFilters();
    });
    group.el
      .querySelectorAll<HTMLButtonElement>("[data-filter-value]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const value = btn.dataset.filterValue ?? "";
          if (!value) return;
          toggleGroupValue(group, value);
          applyFilters();
        });
      });
    syncGroup(group);
  });
  searchEl?.addEventListener("input", applyFilters);

  resetEl?.addEventListener("click", () => {
    groups.forEach((group) => setGroupAll(group));
    if (searchEl) searchEl.value = "";
    applyFilters();
  });
</script>
