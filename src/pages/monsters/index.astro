---
import Layout from "../../layouts/Layout.astro";
import TopNav from "../../components/TopNav.astro";
import monstersData from "../../../data/monsters.json";
import { getLangFromUrl, pickText, withLang } from "../../lib/i18n";

type MonsterMove = {
  id: string;
  name?: string | null;
  name_zh?: string | null;
};

type Monster = {
  id: string;
  name: string;
  name_zh?: string | null;
  type?: string | null;
  min_hp?: number | null;
  max_hp?: number | null;
  min_hp_ascension?: number | null;
  max_hp_ascension?: number | null;
  moves?: MonsterMove[] | null;
  damage_values?: Record<string, { normal?: number | null; ascension?: number | null }> | null;
  block_values?: Record<string, { normal?: number | null; ascension?: number | null }> | null;
  image_url?: string | null;
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";
const monsters = monstersData as Monster[];

const getName = (m: Monster) => pickText(lang, m.name_zh, m.name, m.id);
const getType = (m: Monster) => m.type ?? (isEn ? "Unknown" : "未知");
const normalizeImageUrl = (url: string | null | undefined) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};
const getImage = (m: Monster) => normalizeImageUrl(m.image_url ?? null);

const types = Array.from(
  new Set(monsters.map((item) => item.type).filter(Boolean)),
) as string[];

const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(withLang(`${base}/monsters`, lang), origin).toString();
const pageTitle = isEn
  ? "Monster Library | Slay the Spire 2 Database"
  : "怪物库 | 杀戮尖塔2 中文资料库";
const pageDescription = isEn
  ? `All Slay the Spire 2 monsters (${monsters.length} total), with type filter and search.`
  : `收录杀戮尖塔2全部怪物，共 ${monsters.length} 个。支持类型筛选与搜索。`;

const t = {
  navLabel: isEn ? "Monsters" : "怪物",
  title: isEn ? "Monster Compendium" : "怪物图鉴",
  count: isEn ? `${monsters.length} monsters` : `共 ${monsters.length} 个怪物`,
  type: isEn ? "Type" : "类型",
  search: isEn ? "Search" : "搜索",
  selectAll: isEn ? "All" : "全选",
  reset: isEn ? "Reset" : "重置",
  filters: isEn ? "Filters" : "筛选",
  expand: isEn ? "Expand" : "展开",
  collapse: isEn ? "Collapse" : "收起",
  searchPlaceholder: isEn ? "Name / Move" : "名称 / 动作",
  moves: isEn ? "Moves" : "动作",
  hp: "HP",
};
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
  </Fragment>
  <main class="px-3 pb-8 pt-10 sm:px-[6vw] sm:pb-10 sm:pt-12" data-base-path={base}>
    <div class="mx-auto flex max-w-[1100px] flex-col gap-4 sm:gap-6">
      <header>
        <div class="flex flex-wrap items-end justify-between gap-3 sm:gap-6">
          <div>
            <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
              {t.navLabel}
            </div>
            <h1 class="mt-2 text-[26px] font-semibold text-[#fdf0d8]">{t.title}</h1>
            <p class="mt-1 text-[#c4c7d6]">{t.count}</p>
          </div>
          <TopNav current="monsters" basePath={base} lang={lang} />
        </div>
      </header>

      <section
        class="flex flex-col gap-2 rounded-2xl border border-white/10 bg-[rgba(16,18,26,0.7)] px-3 py-3 sm:gap-3 sm:px-[18px] sm:py-[14px]"
        aria-label="Monster filters"
      >
        <div class="mb-1 flex items-center justify-between sm:hidden">
          <div class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">{t.filters}</div>
          <button
            type="button"
            id="monster-filter-toggle"
            data-label-expand={t.expand}
            data-label-collapse={t.collapse}
            class="h-8 rounded-[10px] border border-white/20 bg-white/10 px-3 text-[12px] text-[#f7f1df] transition hover:bg-white/20"
            aria-expanded="true"
          >
            {t.collapse}
          </button>
        </div>

        <div id="monster-filter-body" class="flex flex-col gap-3">
        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-start sm:gap-3">
          <span class="shrink-0 pt-1 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.type}</span>
          <div class="flex flex-wrap gap-2 sm:flex-1" data-filter-group="type">
            <button
              type="button"
              data-filter-all
              class="rounded-full border border-white/40 bg-white/20 px-3 py-1 text-[12px] text-[#fdf0d8] transition"
              aria-pressed="true"
            >
              {t.selectAll}
            </button>
            {types.map((type) => (
              <button
                type="button"
                data-filter-value={type}
                class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10"
                aria-pressed="false"
              >
                {type}
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-center sm:gap-3">
          <span class="shrink-0 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.search}</span>
          <div class="flex flex-col gap-2 sm:flex-1 sm:flex-row">
            <input
              id="monster-filter-search"
              type="search"
              placeholder={t.searchPlaceholder}
              class="h-9 rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-0 text-[#f4f4f1] placeholder:text-[#6f7486] appearance-none focus:outline-none focus:ring-1 focus:ring-white/20 sm:flex-1"
            />
            <button
              type="button"
              id="monster-filter-reset"
              class="h-9 rounded-[10px] border border-white/20 bg-white/15 px-3 text-[#f7f1df] hover:bg-white/20 transition-colors"
            >
              {t.reset}
            </button>
          </div>
        </div>
        </div>
      </section>

      <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {monsters.map((monster) => (
          <a
            href={withLang(`${base}/monster/${monster.id}`, lang)}
            class="monster-tile group relative overflow-hidden rounded-[14px] border border-white/10 bg-white/5 p-4 transition hover:border-white/25 hover:bg-white/10"
            data-monster="1"
            data-type-raw={monster.type ?? ""}
            data-search={[
              getName(monster),
              monster.name ?? "",
              monster.name_zh ?? "",
              monster.moves?.map((m) => pickText(lang, m.name_zh, m.name, m.id)).join(" ") ?? "",
            ]
              .join(" ")
              .toLowerCase()}
          >
            <div class="flex items-start gap-3">
              <div class="relative h-[54px] w-[54px] rounded-[10px] border border-white/10 bg-black/30 p-2">
                {getImage(monster) ? (
                  <img
                    class="h-full w-full object-contain"
                    src={`${base}${getImage(monster)}`}
                    alt={getName(monster)}
                    loading="lazy"
                    data-monster-fallback
                    onerror='this.style.display="none"; this.nextElementSibling?.classList.remove("hidden");'
                  />
                ) : (
                  <span class="sr-only">no image</span>
                )}
                <div
                  class={`${getImage(monster) ? "hidden " : ""}absolute inset-0 bg-no-repeat bg-center`}
                  data-monster-sprite
                  data-sprite-src={`${base}/images/monsters/sprites/${monster.id.toLowerCase()}.png`}
                  data-sprite-meta={`${base}/images/monsters/sprites/${monster.id.toLowerCase()}.json`}
                ></div>
              </div>
              <div class="flex-1">
                <div class="text-[14px] font-semibold text-[#fdf0d8]">
                  {getName(monster)}
                </div>
                <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                  {getType(monster).toUpperCase()}
                </div>
              </div>
              <div class="text-[10px] text-[#c4c7d6] text-right">
                <div>{t.hp} {monster.min_hp ?? "?"}-{monster.max_hp ?? "?"}</div>
                {(monster.min_hp_ascension || monster.max_hp_ascension) && (
                  <div class="opacity-70">
                    A: {monster.min_hp_ascension ?? "?"}-{monster.max_hp_ascension ?? "?"}
                  </div>
                )}
              </div>
            </div>
            {monster.moves && monster.moves.length > 0 && (
              <div class="mt-3 text-[11px] leading-[1.3] text-[#f2e5cd]">
                {t.moves}:
                {monster.moves
                  .map((m) => pickText(lang, m.name_zh, m.name, m.id))
                  .filter(Boolean)
                  .join(" / ")}
              </div>
            )}
          </a>
        ))}
      </section>
    </div>
  </main>
</Layout>

<script>
  const byId = (id: string): HTMLElement | null => document.getElementById(id);
  const filterToggleEl = byId("monster-filter-toggle") as HTMLButtonElement | null;
  const filterBodyEl = byId("monster-filter-body") as HTMLElement | null;
  const searchEl = byId("monster-filter-search") as HTMLInputElement | null;
  const resetEl = byId("monster-filter-reset") as HTMLButtonElement | null;
  const typeGroup = document.querySelector<HTMLElement>(
    '[data-filter-group="type"]',
  );
  const typeValues = Array.from(
    typeGroup?.querySelectorAll<HTMLButtonElement>("[data-filter-value]") ?? [],
  ).map((btn) => btn.dataset.filterValue ?? "");
  let selectedTypes = new Set<string>(["all"]);

  const setupFilterCollapse = (
    toggleEl: HTMLButtonElement | null,
    bodyEl: HTMLElement | null,
  ) => {
    if (!toggleEl || !bodyEl) return;
    const mobileMq = window.matchMedia("(max-width: 639px)");
    let collapsed = mobileMq.matches;
    const render = () => {
      const shouldHide = mobileMq.matches && collapsed;
      bodyEl.classList.toggle("hidden", shouldHide);
      const expandLabel = toggleEl.dataset.labelExpand ?? "展开";
      const collapseLabel = toggleEl.dataset.labelCollapse ?? "收起";
      toggleEl.textContent = shouldHide ? expandLabel : collapseLabel;
      toggleEl.setAttribute("aria-expanded", shouldHide ? "false" : "true");
    };
    render();
    toggleEl.addEventListener("click", () => {
      collapsed = !collapsed;
      render();
    });
    const onMediaChange = () => {
      collapsed = mobileMq.matches;
      render();
    };
    mobileMq.addEventListener("change", onMediaChange);
  };

  setupFilterCollapse(filterToggleEl, filterBodyEl);

  const setBtnActive = (btn: HTMLButtonElement, active: boolean) => {
    btn.setAttribute("aria-pressed", active ? "true" : "false");
    btn.classList.toggle("border-white/40", active);
    btn.classList.toggle("bg-white/20", active);
    btn.classList.toggle("text-[#fdf0d8]", active);
    btn.classList.toggle("border-white/10", !active);
    btn.classList.toggle("bg-white/5", !active);
    btn.classList.toggle("text-[#cdd2e3]", !active);
  };

  const syncTypeGroup = () => {
    if (!typeGroup) return;
    const isAll = selectedTypes.has("all");
    const allBtn = typeGroup.querySelector<HTMLButtonElement>("[data-filter-all]");
    if (allBtn) setBtnActive(allBtn, isAll);
    typeGroup.querySelectorAll<HTMLButtonElement>("[data-filter-value]").forEach((btn) => {
      const val = btn.dataset.filterValue ?? "";
      setBtnActive(btn, !isAll && selectedTypes.has(val));
    });
  };

  const setAllTypes = () => {
    selectedTypes = new Set(["all"]);
    syncTypeGroup();
  };

  const applyFilters = () => {
    const query = (searchEl?.value ?? "").trim().toLowerCase();

    document.querySelectorAll("[data-monster]").forEach((node) => {
      const el = node as HTMLElement;
      const t = el.dataset.typeRaw || "";
      const s = el.dataset.search || "";

      const match =
        (selectedTypes.has("all") || selectedTypes.has(t)) &&
        (!query || s.includes(query));

      el.style.display = match ? "" : "none";
    });
  };

  if (typeGroup) {
    const allBtn = typeGroup.querySelector<HTMLButtonElement>("[data-filter-all]");
    allBtn?.addEventListener("click", () => {
      setAllTypes();
      applyFilters();
    });
    typeGroup.querySelectorAll<HTMLButtonElement>("[data-filter-value]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const value = btn.dataset.filterValue ?? "";
        if (!value) return;
        if (selectedTypes.has("all")) selectedTypes.clear();
        if (selectedTypes.has(value)) selectedTypes.delete(value);
        else selectedTypes.add(value);
        if (selectedTypes.size === 0 || selectedTypes.size === typeValues.length) {
          setAllTypes();
        } else {
          syncTypeGroup();
        }
        applyFilters();
      });
    });
    syncTypeGroup();
  }

  searchEl?.addEventListener("input", applyFilters);

  resetEl?.addEventListener("click", () => {
    setAllTypes();
    if (searchEl) searchEl.value = "";
    applyFilters();
  });

  const spriteTargets = Array.from(
    document.querySelectorAll<HTMLElement>("[data-monster-sprite]"),
  );
  const initSprite = async (el: HTMLElement) => {
    const metaUrl = el.getAttribute("data-sprite-meta") || "";
    const imgUrl = el.getAttribute("data-sprite-src") || "";
    if (!metaUrl || !imgUrl) return;
    try {
      const res = await fetch(metaUrl);
      if (!res.ok) return;
      const meta = await res.json();
      const rect = el.getBoundingClientRect();
      if (!rect.width || !rect.height) return;
      const scaleX = rect.width / meta.frameWidth;
      const scaleY = rect.height / meta.frameHeight;
      const sheetWidth = meta.columns * meta.frameWidth * scaleX;
      const sheetHeight = meta.rows * meta.frameHeight * scaleY;

      el.style.backgroundImage = `url(${imgUrl})`;
      el.style.backgroundSize = `${sheetWidth}px ${sheetHeight}px`;

      const fallback = el.parentElement?.querySelector(
        "[data-monster-fallback]",
      );
      const shouldShow =
        !fallback || getComputedStyle(fallback).display === "none";
      if (shouldShow) el.classList.remove("hidden");

      el.style.backgroundPosition = `0px 0px`;
    } catch {}
  };

  spriteTargets.forEach((el) => {
    initSprite(el);
  });
</script>
