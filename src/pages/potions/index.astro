---
import Layout from "../../layouts/Layout.astro";
import potionsData from "../../../data/potions.json";
import { formatRelicText } from "../../lib/relicText";
import TopNav from "../../components/TopNav.astro";

type Potion = {
  id: string;
  name: string;
  name_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
  rarity?: string | null;
  image_url?: string | null;
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const potions = potionsData as Potion[];

const getName = (potion: Potion) => potion.name_zh ?? potion.name ?? potion.id;
const getDesc = (potion: Potion) =>
  potion.description_zh ?? potion.description ?? "";

const normalizeImageUrl = (url: string | null | undefined) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};

const getImage = (potion: Potion) =>
  normalizeImageUrl(potion.image_url ?? null) ??
  `/images/potions/${potion.id.toLowerCase()}.png`;

const rarityLabel: Record<string, string> = {
  Common: "普通",
  Uncommon: "罕见",
  Rare: "稀有",
  Ancient: "古代",
};

const rarities = Array.from(
  new Set(potions.map((item) => item.rarity).filter(Boolean)),
) as string[];

const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(`${base}/potions`, origin).toString();
const pageTitle = "药剂图鉴 | 杀戮尖塔2 中文数据库";
const pageDescription = `收录杀戮尖塔2全部药剂，共 ${potions.length} 个。支持稀有度筛选与搜索。`;
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
  </Fragment>
  <main class='px-4 pb-10 pt-12 sm:px-[6vw]' data-base-path={base}>
    <div class='mx-auto flex max-w-[1100px] flex-col gap-6'>
      <div class='flex flex-wrap items-end justify-between gap-6'>
        <div>
          <div class='text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]'>
            药剂
          </div>
          <h1 class='mt-2 text-[26px] font-semibold text-[#fdf0d8]'>药剂图鉴</h1>
          <p class='mt-1 text-[#c4c7d6]'>共 {potions.length} 个药剂</p>
        </div>
        <TopNav current='potions' basePath={base} />
      </div>

      <section
        class='grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] items-end gap-3 rounded-2xl border border-white/10 bg-[rgba(16,18,26,0.7)] px-[18px] py-[14px]'
        aria-label='Potion filters'
      >
        <label class='grid gap-1.5 text-[13px] text-[#b6bbcc]'>
          <span>稀有度</span>
          <select
            id='potion-filter-rarity'
            class='rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20'
          >
            <option value='all' class='bg-[#1a1c24] text-[#f4f4f1]'>全部</option>
            {rarities.map((r) => (
              <option value={r} class='bg-[#1a1c24] text-[#f4f4f1]'>
                {rarityLabel[r] ?? r}
              </option>
            ))}
          </select>
        </label>

        <label class='grid gap-1.5 text-[13px] text-[#b6bbcc]'>
          <span>搜索</span>
          <input
            id='potion-filter-search'
            type='search'
            placeholder='名称 / 描述'
            class='rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] placeholder:text-[#6f7486] appearance-none focus:outline-none focus:ring-1 focus:ring-white/20'
          />
        </label>

        <button
          type='button'
          id='potion-filter-reset'
          class='rounded-xl border border-white/20 bg-white/15 px-3.5 py-2.5 text-[#f7f1df] hover:bg-white/20 transition-colors'
        >
          重置
        </button>
      </section>

      <div class='grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3'>
        {potions.map((potion) => (
          <a
            href={`${base}/potion/${potion.id}`}
            class='potion-tile group relative overflow-hidden rounded-[14px] border border-white/10 bg-white/5 p-4 transition hover:border-white/25 hover:bg-white/10'
            data-potion='1'
            data-rarity-raw={potion.rarity ?? ""}
            data-search={[
              getName(potion),
              getDesc(potion),
              potion.rarity ?? "",
            ]
              .join(" ")
              .toLowerCase()}
          >
            <div class='flex items-center gap-3'>
              <div class='h-[56px] w-[56px] rounded-[10px] border border-white/10 bg-black/30 p-2'>
                <img
                  class='h-full w-full object-contain'
                  src={`${base}${getImage(potion)}`}
                  alt={getName(potion)}
                  loading='lazy'
                />
              </div>
              <div class='min-w-0 flex-1'>
                <div class='text-[14px] font-semibold text-[#fdf0d8]'>
                  {getName(potion)}
                </div>
                <div class='mt-1 text-[10px] uppercase tracking-[0.2em] text-[#9ea2b3]'>
                  {(potion.rarity ?? "未知").toUpperCase()}
                </div>
              </div>
            </div>
            <div
              class='mt-3 text-[11px] leading-[1.3] text-[#f2e5cd]'
              set:html={formatRelicText(getDesc(potion), base)}
            />
          </a>
        ))}
      </div>
    </div>
  </main>
</Layout>

<script>
  const byId = (id: string): HTMLElement | null => document.getElementById(id);
  const rarityEl = byId("potion-filter-rarity") as HTMLSelectElement | null;
  const searchEl = byId("potion-filter-search") as HTMLInputElement | null;
  const resetEl = byId("potion-filter-reset") as HTMLButtonElement | null;

  const applyFilters = () => {
    const rarity = rarityEl?.value ?? "all";
    const query = (searchEl?.value ?? "").trim().toLowerCase();

    document.querySelectorAll("[data-potion]").forEach((node) => {
      const el = node as HTMLElement;
      const r = el.dataset.rarityRaw || "";
      const s = el.dataset.search || "";

      const match =
        (rarity === "all" || r === rarity) &&
        (!query || s.includes(query));

      el.style.display = match ? "" : "none";
    });
  };

  rarityEl?.addEventListener("change", applyFilters);
  searchEl?.addEventListener("input", applyFilters);
  resetEl?.addEventListener("click", () => {
    if (rarityEl) rarityEl.value = "all";
    if (searchEl) searchEl.value = "";
    applyFilters();
  });
</script>
