---
import Layout from "../../layouts/Layout.astro";
import cardsData from "../../../data/cards.json";
import CardView from "../../components/CardView.astro";
import type { Card } from "../../lib/cardModels";
import TopNav from "../../components/TopNav.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const cards = cardsData as Card[];
export const getStaticPaths = () =>
  (cardsData as Card[]).map((card) => ({
    params: { id: card.id },
  }));

const { id } = Astro.params;
console.log(`[card] requested id=${id ?? ""}`);
const card = cards.find((item) => item.id?.toLowerCase() === id?.toLowerCase());
if (!card) {
  console.warn(`[card] not found for id=${id ?? ""}`);
  return new Response("Not found", { status: 404 });
}

const displayName = card.name_zh ?? card.name ?? card.id;
const typeLabel = card.type ?? "";
const rarityLabel = card.rarity ?? "";
const rawDesc = (card.description_zh ?? card.description ?? "")
  .replace(/\[\/?[a-zA-Z0-9_]+\]/g, "")
  .replace(/\s+/g, " ")
  .trim();
const cardDescription = [
  rawDesc,
  typeLabel && `类型：${typeLabel}`,
  rarityLabel && `稀有度：${rarityLabel}`,
]
  .filter(Boolean)
  .join(" · ")
  .slice(0, 160);
const pageTitle = `${displayName} | 杀戮尖塔2 卡牌图鉴`;
const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(`${base}/card/${card.id}`, origin).toString();
const normalizeImageUrl = (url: string | null) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};
const cardImagePath =
  normalizeImageUrl(card.image_url) ??
  normalizeImageUrl(card.beta_image_url) ??
  `/images/cards/${card.id.toLowerCase()}.png`;
const ogImage = new URL(`${base}${cardImagePath}`, origin).toString();
const hasUpgrade = Boolean(card.upgrade);
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={cardDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={cardDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={displayName} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={cardDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={displayName} />
  </Fragment>
  <main class='px-4 pb-10 pt-12 sm:px-[6vw]' data-base-path={base}>
    <div class='mx-auto flex max-w-[980px] flex-col items-center gap-6'>
      <div class='flex w-full flex-col items-center gap-4'>
        <a
          class='text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]'
          href={`${base}/`}>返回</a
        >
        <TopNav current='cards' basePath={base} />
      </div>
      {hasUpgrade ? (
        <div class='flex flex-wrap items-start justify-center gap-6'>
          <div class='flex flex-col items-center gap-2'>
            <div class='text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]'>
              普通
            </div>
            <CardView card={card} variant='base' />
          </div>
          <div class='flex flex-col items-center gap-2'>
            <div class='text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]'>
              升级
            </div>
            <CardView card={card} variant='upgrade' />
          </div>
        </div>
      ) : (
        <CardView card={card} />
      )}
    </div>
  </main>
</Layout>
