---
import Layout from "../../layouts/Layout.astro";
import cardsData from "../../../data/cards.json";
import keywordsData from "../../../data/keywords.json";
import CardView from "../../components/CardView.astro";
import type { Card, Keyword } from "../../lib/cardModels";
import { TYPE_ZH } from "../../lib/cardModels";
import TopNav from "../../components/TopNav.astro";
import { getLangFromUrl, pickText, withLang } from "../../lib/i18n";
import { formatRelicText } from "../../lib/relicText";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";

const cards = cardsData as Card[];
const keywords = keywordsData as Keyword[];
export const getStaticPaths = () =>
  (cardsData as Card[]).map((card) => ({
    params: { id: card.id },
  }));

const { id } = Astro.params;
const card = cards.find((item) => item.id?.toLowerCase() === id?.toLowerCase());
if (!card) {
  return new Response("Not found", { status: 404 });
}

const rarityLabelMap: Record<string, string> = {
  Basic: isEn ? "Basic" : "基础",
  Common: isEn ? "Common" : "普通",
  Uncommon: isEn ? "Uncommon" : "罕见",
  Rare: isEn ? "Rare" : "稀有",
  Ancient: isEn ? "Ancient" : "古代",
  Event: isEn ? "Event" : "事件",
  Token: isEn ? "Token" : "衍生",
  Status: isEn ? "Status" : "状态",
  Curse: isEn ? "Curse" : "诅咒",
  Quest: isEn ? "Quest" : "任务",
};

const displayName = pickText(lang, card.name_zh, card.name, card.id);
const typeLabel = card.type
  ? isEn
    ? card.type
    : (TYPE_ZH[card.type] ?? card.type)
  : "";
const rarityLabel = card.rarity ? (rarityLabelMap[card.rarity] ?? card.rarity) : "";
const rawDesc = pickText(lang, card.description_zh, card.description)
  .replace(/\[\/?[a-zA-Z0-9_]+\]/g, "")
  .replace(/\s+/g, " ")
  .trim();
const cardDescription = [
  rawDesc,
  typeLabel && `${isEn ? "Type" : "类型"}: ${typeLabel}`,
  rarityLabel && `${isEn ? "Rarity" : "稀有度"}: ${rarityLabel}`,
]
  .filter(Boolean)
  .join(" · ")
  .slice(0, 160);
const pageTitle = `${displayName} - ${isEn ? "Card" : "卡牌"} | ${
  isEn ? "Slay the Spire 2 Database" : "杀戮尖塔2 中文资料库"
}`;
const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(withLang(`${base}/card/${card.id}`, lang), origin).toString();
const normalizeImageUrl = (url: string | null) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};
const cardImagePath =
  normalizeImageUrl(card.image_url) ??
  normalizeImageUrl(card.beta_image_url) ??
  `/images/cards/${card.id.toLowerCase()}.png`;
const ogImage = new URL(`${base}${cardImagePath}`, origin).toString();
const resolveIfUpgradedText = (raw: string | null, upgraded: boolean) => {
  if (!raw) return "";
  let text = raw;
  for (let i = 0; i < 4; i++) {
    const next = text.replace(
      /\{IfUpgraded:show:([^{}|]*)\|([^{}]*)\}/g,
      (_, upText, baseText) => (upgraded ? upText : baseText),
    );
    if (next === text) break;
    text = next;
  }
  return text;
};
const rawTemplate = pickText(lang, card.description_raw_zh, card.description_raw, "");
const hasImplicitUpgrade =
  resolveIfUpgradedText(rawTemplate, true).trim() !==
  resolveIfUpgradedText(rawTemplate, false).trim();
const hasUpgrade =
  Boolean(card.upgrade) ||
  Boolean(card.description_upgraded || card.description_upgraded_zh) ||
  hasImplicitUpgrade;
const subtitle = [
  typeLabel && `${isEn ? "Type" : "类型"}: ${typeLabel}`,
  rarityLabel && `${isEn ? "Rarity" : "稀有度"}: ${rarityLabel}`,
]
  .filter(Boolean)
  .join(" · ");

const normalizeId = (value: string) => value.toLowerCase().replace(/[^a-z0-9]/g, "");
const cardMap = new Map(cards.map((item) => [item.id.toLowerCase(), item]));
const cardLooseMap = new Map(cards.map((item) => [normalizeId(item.id), item]));
const findCard = (cardId: string) =>
  cardMap.get(cardId.toLowerCase()) ?? cardLooseMap.get(normalizeId(cardId)) ?? null;
const spawnedCards = (card.spawns_cards ?? [])
  .map((spawnId) => findCard(spawnId))
  .filter((spawn): spawn is Card => Boolean(spawn));
const hasSpawnedCards = spawnedCards.length > 0;
const upgradedSpawnedCards = hasUpgrade ? spawnedCards : [];
const keywordMap = new Map<string, Keyword>();
for (const keyword of keywords) {
  keywordMap.set(keyword.name.toLowerCase(), keyword);
  if (keyword.name_zh) keywordMap.set(keyword.name_zh.toLowerCase(), keyword);
}
const keywordDetails = (card.keywords ?? [])
  .map((kw) => {
    const hit = keywordMap.get(kw.toLowerCase());
    const label = hit
      ? pickText(lang, hit.name_zh, hit.name, kw)
      : kw;
    const desc = hit
      ? pickText(lang, hit.description_zh, hit.description)
      : null;
    return { key: kw.toLowerCase(), label, desc };
  })
  .filter((item, idx, arr) => arr.findIndex((x) => x.key === item.key) === idx);

const t = {
  back: isEn ? "Back to Cards" : "返回卡牌",
  base: isEn ? "Base" : "普通",
  upgrade: isEn ? "Upgrade" : "升级",
  spawns: isEn ? "Spawns" : "生成卡牌",
  keywordTips: isEn ? "Keyword Notes" : "关键词补充说明",
};
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={cardDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={cardDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={displayName} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={cardDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={displayName} />
  </Fragment>
  <main class="px-3 pb-8 pt-10 sm:px-[6vw] sm:pb-10 sm:pt-12" data-base-path={base}>
    <div class="mx-auto flex max-w-[1100px] flex-col gap-4 sm:gap-6">
      <div class="flex flex-wrap items-end justify-between gap-3 sm:gap-6">
        <div>
          <a
            class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3] hover:text-[#f7f1df]"
            href={withLang(`${base}/`, lang)}
          >
            {t.back}
          </a>
          <h1 class="mt-2 text-[26px] font-semibold text-[#fdf0d8]">
            {displayName}
          </h1>
          {subtitle && <p class="mt-1 text-[#c4c7d6]">{subtitle}</p>}
        </div>
        <TopNav current="cards" basePath={base} lang={lang} />
      </div>
      {hasUpgrade ? (
        <div class="flex flex-wrap items-start gap-6">
          <div class="flex flex-col items-center gap-2">
            <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
              {t.base}
            </div>
            <CardView card={card} variant="base" lang={lang} />
          </div>
          <div class="flex flex-col items-center gap-2">
            <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
              {t.upgrade}
            </div>
            <CardView card={card} variant="upgrade" lang={lang} />
          </div>
        </div>
      ) : (
        <div class="flex items-start">
          <CardView card={card} lang={lang} />
        </div>
      )}

      {hasSpawnedCards && (
        <section>
          <h2 class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">
            {t.spawns}
          </h2>
          {hasUpgrade ? (
            <div class="mt-2 grid gap-6">
              {upgradedSpawnedCards.map((spawn) => (
                <div class="flex flex-wrap items-start gap-6">
                  <div class="flex flex-col items-center gap-2">
                    <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
                      {t.base}
                    </div>
                    <a
                      class="block transition hover:opacity-90"
                      href={withLang(`${base}/card/${spawn.id}`, lang)}
                      aria-label={pickText(lang, spawn.name_zh, spawn.name, spawn.id)}
                    >
                      <CardView card={spawn} variant="base" lang={lang} />
                    </a>
                  </div>
                  <div class="flex flex-col items-center gap-2">
                    <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
                      {t.upgrade}
                    </div>
                    <a
                      class="block transition hover:opacity-90"
                      href={withLang(`${base}/card/${spawn.id}`, lang)}
                      aria-label={pickText(lang, spawn.name_zh, spawn.name, spawn.id)}
                    >
                      <CardView
                        card={spawn}
                        variant={spawn.upgrade ? "upgrade" : "base"}
                        lang={lang}
                      />
                    </a>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="mt-2 flex flex-wrap items-start gap-6">
              {spawnedCards.map((spawn) => (
                <a
                  class="block transition hover:opacity-90"
                  href={withLang(`${base}/card/${spawn.id}`, lang)}
                  aria-label={pickText(lang, spawn.name_zh, spawn.name, spawn.id)}
                >
                  <CardView card={spawn} variant="base" lang={lang} />
                </a>
              ))}
            </div>
          )}
        </section>
      )}

      {keywordDetails.length > 0 && (
        <section class="rounded-[18px] border border-white/10 bg-white/5 p-4">
          <h2 class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">
            {t.keywordTips}
          </h2>
          <div class="mt-2 grid gap-2 sm:grid-cols-2">
            {keywordDetails.map((keyword) => (
              <div class="rounded-[10px] border border-white/10 bg-black/20 p-3">
                <div class="text-[12px] font-semibold text-[#fdf0d8]">
                  {keyword.label}
                </div>
                {keyword.desc && (
                  <div
                    class="mt-1 text-[12px] leading-[1.45] text-[#f2e5cd]"
                    set:html={formatRelicText(keyword.desc, base)}
                  />
                )}
              </div>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>
</Layout>
