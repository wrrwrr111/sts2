---
import Layout from "../../layouts/Layout.astro";
import cardsData from "../../../data/cards.json";
import CardView from "../../components/CardView.astro";
import type { Card } from "../../lib/cardModels";
import { TYPE_ZH } from "../../lib/cardModels";
import TopNav from "../../components/TopNav.astro";
import { getLangFromUrl, pickText, withLang } from "../../lib/i18n";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";

const cards = cardsData as Card[];
export const getStaticPaths = () =>
  (cardsData as Card[]).map((card) => ({
    params: { id: card.id },
  }));

const { id } = Astro.params;
const card = cards.find((item) => item.id?.toLowerCase() === id?.toLowerCase());
if (!card) {
  return new Response("Not found", { status: 404 });
}

const rarityLabelMap: Record<string, string> = {
  Basic: isEn ? "Basic" : "基础",
  Common: isEn ? "Common" : "普通",
  Uncommon: isEn ? "Uncommon" : "罕见",
  Rare: isEn ? "Rare" : "稀有",
  Ancient: isEn ? "Ancient" : "古代",
  Event: isEn ? "Event" : "事件",
  Token: isEn ? "Token" : "衍生",
  Status: isEn ? "Status" : "状态",
  Curse: isEn ? "Curse" : "诅咒",
  Quest: isEn ? "Quest" : "任务",
};

const displayName = pickText(lang, card.name_zh, card.name, card.id);
const typeLabel = card.type
  ? isEn
    ? card.type
    : (TYPE_ZH[card.type] ?? card.type)
  : "";
const rarityLabel = card.rarity ? (rarityLabelMap[card.rarity] ?? card.rarity) : "";
const rawDesc = pickText(lang, card.description_zh, card.description)
  .replace(/\[\/?[a-zA-Z0-9_]+\]/g, "")
  .replace(/\s+/g, " ")
  .trim();
const cardDescription = [
  rawDesc,
  typeLabel && `${isEn ? "Type" : "类型"}: ${typeLabel}`,
  rarityLabel && `${isEn ? "Rarity" : "稀有度"}: ${rarityLabel}`,
]
  .filter(Boolean)
  .join(" · ")
  .slice(0, 160);
const pageTitle = `${displayName} - ${isEn ? "Card" : "卡牌"} | ${
  isEn ? "Slay the Spire 2 Database" : "杀戮尖塔2 中文资料库"
}`;
const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(withLang(`${base}/card/${card.id}`, lang), origin).toString();
const normalizeImageUrl = (url: string | null) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};
const cardImagePath =
  normalizeImageUrl(card.image_url) ??
  normalizeImageUrl(card.beta_image_url) ??
  `/images/cards/${card.id.toLowerCase()}.png`;
const ogImage = new URL(`${base}${cardImagePath}`, origin).toString();
const hasUpgrade = Boolean(card.upgrade);
const subtitle = [
  typeLabel && `${isEn ? "Type" : "类型"}: ${typeLabel}`,
  rarityLabel && `${isEn ? "Rarity" : "稀有度"}: ${rarityLabel}`,
]
  .filter(Boolean)
  .join(" · ");

const t = {
  back: isEn ? "Back to Cards" : "返回卡牌",
  base: isEn ? "Base" : "普通",
  upgrade: isEn ? "Upgrade" : "升级",
};
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={cardDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={cardDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={displayName} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={cardDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={displayName} />
  </Fragment>
  <main class="px-4 pb-10 pt-12 sm:px-[6vw]" data-base-path={base}>
    <div class="mx-auto flex max-w-[1100px] flex-col gap-6">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <a
            class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3] hover:text-[#f7f1df]"
            href={withLang(`${base}/`, lang)}
          >
            {t.back}
          </a>
          <h1 class="mt-2 text-[26px] font-semibold text-[#fdf0d8]">
            {displayName}
          </h1>
          {subtitle && <p class="mt-1 text-[#c4c7d6]">{subtitle}</p>}
        </div>
        <TopNav current="cards" basePath={base} lang={lang} />
      </div>
      {hasUpgrade ? (
        <div class="flex flex-wrap items-start gap-6">
          <div class="flex flex-col items-center gap-2">
            <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
              {t.base}
            </div>
            <CardView card={card} variant="base" lang={lang} />
          </div>
          <div class="flex flex-col items-center gap-2">
            <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
              {t.upgrade}
            </div>
            <CardView card={card} variant="upgrade" lang={lang} />
          </div>
        </div>
      ) : (
        <div class="flex items-start">
          <CardView card={card} lang={lang} />
        </div>
      )}
    </div>
  </main>
</Layout>
