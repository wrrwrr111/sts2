---
import Layout from "../layouts/Layout.astro";
import cardsData from "../../data/cards.json";
import keywordsData from "../../data/keywords.json";

// 获取base路径
const base = Astro.url.pathname.replace(/\/$/, "");

type Card = {
  id: string;
  name: string;
  name_zh: string | null;
  description: string | null;
  cost: number | null;
  is_x_cost: boolean | null;
  is_x_star_cost: boolean | null;
  star_cost: number | null;
  type: string | null;
  rarity: string | null;
  target: string | null;
  color: string | null;
  image_url: string | null;
  beta_image_url: string | null;
  upgrade: Record<string, string | number> | null;
  description_upgraded: string | null;
  description_upgraded_zh: string | null;
  keywords?: string[] | null;
};

const cards = cardsData as Card[];
const keywords = keywordsData as Array<{
  id: string;
  name: string;
  name_zh: string | null;
  description: string;
  description_zh: string | null;
}>;

const keywordMap = new Map<
  string,
  {
    name: string;
    name_zh: string | null;
    description: string;
    description_zh: string | null;
  }
>();
for (const k of keywords) {
  keywordMap.set(k.name.toLowerCase(), k);
  if (k.name_zh) keywordMap.set(k.name_zh.toLowerCase(), k);
}

const keywordLabel = (kw: string) => {
  const hit = keywordMap.get(kw.toLowerCase());
  if (!hit) return kw;
  return hit.name_zh ?? hit.name;
};

const escapeHtml = (value: string) =>
  value.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

const escapeAttr = (value: string) =>
  value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");

const openTag = (tag: string) => {
  const t = tag.toLowerCase();
  if (t === "b") return '<strong class="inline-block">';
  if (t === "i") return '<em class="inline-block">';
  if (t === "u") return '<span class="inline-block underline">';
  if (t === "gold") return '<span class="inline-block text-[#ffd38c]">';
  if (t === "red") return '<span class="inline-block text-[#ff7b7b]">';
  if (t === "blue") return '<span class="inline-block text-[#7fb8ff]">';
  if (t === "green") return '<span class="inline-block text-[#86e3a0]">';
  if (t === "purple") return '<span class="inline-block text-[#b89bff]">';
  if (t === "orange") return '<span class="inline-block text-[#ffb46a]">';
  if (t === "aqua") return '<span class="inline-block text-[#7fe3ff]">';
  if (t === "pink") return '<span class="inline-block text-[#ff9bd0]">';
  if (t === "rainbow") {
    return '<span class="inline-block text-transparent [background:linear-gradient(90deg,#ff6b6b,#ffd93d,#6bffb6,#6bc7ff,#b56bff)] [-webkit-background-clip:text]">';
  }
  if (t === "amount")
    return '<span class="inline-block text-[#ffe6b0] font-semibold">';
  if (t === "passive" || t === "evoke")
    return '<span class="inline-block text-[#bfe5ff] uppercase tracking-[0.08em] text-[0.85em]">';
  if (t === "sine") return '<span class="inline-block animate-bounce">';
  if (t === "jitter") return '<span class="inline-block animate-pulse">';
  return '<span class="inline-block">';
};

const closeTag = (tag: string) => {
  const t = tag.toLowerCase();
  if (t === "b") return "</strong>";
  if (t === "i") return "</em>";
  if (t === "u") return "</span>";
  return "</span>";
};

const energyIconForColor = (color: string | null) => {
  const c = color ?? "colorless";
  if (c === "silent") return "energy_silent";
  if (c === "ironclad") return "energy_ironclad";
  if (c === "defect") return "energy_defect";
  if (c === "necrobinder") return "energy_necrobinder";
  if (c === "regent") return "energy_regent";
  if (c === "quest") return "energy_quest";
  return "energy_colorless";
};

const openTagWithTitle = (tag: string, innerText: string) => {
  const t = tag.toLowerCase();
  const key = innerText.trim().toLowerCase();
  const tipHtml = keywordTipHtmlMap.get(key) ?? "";
  if (!tipHtml) {
    if (t === "b") return '<strong class="inline-block">';
    if (t === "i") return '<em class="inline-block">';
    if (t === "u") return '<span class="inline-block underline">';
    return '<span class="inline-block">';
  }
  const tipAttr = ` data-tip-html="${escapeAttr(tipHtml)}" class="inline-block relative cursor-help"`;
  if (t === "b") return `<strong${tipAttr}>`;
  if (t === "i") return `<em${tipAttr}>`;
  if (t === "u")
    return `<span class="inline-block underline relative cursor-help" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "gold")
    return `<span class="inline-block relative cursor-help text-[#ffd38c]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "red")
    return `<span class="inline-block relative cursor-help text-[#ff7b7b]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "blue")
    return `<span class="inline-block relative cursor-help text-[#7fb8ff]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "green")
    return `<span class="inline-block relative cursor-help text-[#86e3a0]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "purple")
    return `<span class="inline-block relative cursor-help text-[#b89bff]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "orange")
    return `<span class="inline-block relative cursor-help text-[#ffb46a]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "aqua")
    return `<span class="inline-block relative cursor-help text-[#7fe3ff]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "pink")
    return `<span class="inline-block relative cursor-help text-[#ff9bd0]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "rainbow") {
    return `<span class="inline-block relative cursor-help text-transparent [background:linear-gradient(90deg,#ff6b6b,#ffd93d,#6bffb6,#6bc7ff,#b56bff)] [-webkit-background-clip:text]" data-tip-html="${escapeAttr(tipHtml)}">`;
  }
  if (t === "amount")
    return `<span class="inline-block relative cursor-help text-[#ffe6b0] font-semibold" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "passive" || t === "evoke")
    return `<span class="inline-block relative cursor-help text-[#bfe5ff] uppercase tracking-[0.08em] text-[0.85em]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "sine")
    return `<span class="inline-block relative cursor-help animate-bounce" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "jitter")
    return `<span class="inline-block relative cursor-help animate-pulse" data-tip-html="${escapeAttr(tipHtml)}">`;
  return `<span class="inline-block relative cursor-help" data-tip-html="${escapeAttr(tipHtml)}">`;
};

const formatDescription = (
  desc: string | null,
  color: string | null,
  options: { tooltips?: boolean } = {},
) => {
  if (!desc) return "";
  const escaped = escapeHtml(desc);
  const withTooltips = options.tooltips !== false;
  return escaped
    .replace(/\[energy:(\d+)\]/gi, (_, raw) => {
      const count = Math.max(0, Math.min(9, Number(raw)));
      const icon = energyIconForColor(color);
      if (!count) return "";
      return `<span class="inline-flex gap-0.5 align-middle">${Array.from({
        length: count,
      })
        .map(
          () =>
            `<img class="inline-block align-text-bottom" style="height:1em;width:1em;margin-bottom:0.1em;filter:drop-shadow(0 1px 1px rgba(0,0,0,0.45));" src="${base}/images/ui/${icon}.png" alt="" />`,
        )
        .join("")}</span>`;
    })
    .replace(/\[star:(\d+)\]/gi, (_, raw) => {
      const count = Math.max(0, Math.min(9, Number(raw)));
      if (!count) return "";
      return `<span class="inline-flex gap-0.5 align-middle">${Array.from({
        length: count,
      })
        .map(
          () =>
            `<img class="inline-block align-text-bottom" style="height:1em;width:1em;margin-bottom:0.1em;filter:drop-shadow(0 1px 1px rgba(0,0,0,0.45));" src="${base}/images/icons/star_icon.png" alt="" />`,
        )
        .join("")}</span>`;
    })
    .replace(/\[([a-zA-Z0-9_]+)\]([\s\S]*?)\[\/\1\]/g, (_, tag, inner) => {
      const plain = inner.replace(/\[\/?[a-zA-Z0-9_]+\]/g, "");
      return withTooltips
        ? `${openTagWithTitle(tag, plain)}${inner}${closeTag(tag)}`
        : `${openTag(tag)}${inner}${closeTag(tag)}`;
    })
    .replace(/\[([a-zA-Z0-9_]+)\]/g, (_, tag) => openTag(tag))
    .replace(/\[\/([a-zA-Z0-9_]+)\]/g, (_, tag) => closeTag(tag))
    .replace(/\n/g, "<br />");
};

const keywordTipHtmlMap = new Map<string, string>();
for (const k of keywords) {
  const desc = k.description_zh ?? k.description;
  const html = formatDescription(desc, null, { tooltips: false });
  keywordTipHtmlMap.set(k.name.toLowerCase(), html);
  if (k.name_zh) keywordTipHtmlMap.set(k.name_zh.toLowerCase(), html);
}

const normalizeImageUrl = (url: string | null) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};

const getCardImage = (card: Card) => {
  const normalized =
    normalizeImageUrl(card.image_url) ?? normalizeImageUrl(card.beta_image_url);
  if (normalized) return normalized;
  return `${base}/images/cards/${card.id.toLowerCase()}.png`;
};

const getDisplayName = (card: Card) => card.name_zh ?? card.name;
const getDisplayDesc = (card: Card) =>
  card.description_zh ?? card.description ?? "";
const getDisplayDescUpgraded = (card: Card) =>
  card.description_upgraded_zh ??
  card.description_upgraded ??
  getDisplayDesc(card);
const getCostLabel = (card: Card, upgraded = false) => {
  if (card.is_x_cost) return "X";
  if (upgraded && card.upgrade && typeof card.upgrade.cost === "number") {
    return String(card.upgrade.cost);
  }
  if (card.cost !== null) return String(card.cost);
  return "";
};
const getUpgradeCostLabel = (card: Card) => {
  if (!card.upgrade) return "";
  const base = getCostLabel(card);
  const upgraded = getCostLabel(card, true);
  if (!upgraded || upgraded === base) return "";
  return upgraded;
};
const getStarLabel = (card: Card) =>
  card.star_cost !== null ? String(card.star_cost) : "";
const getCostBucket = (card: Card) => {
  if (card.is_x_cost) return "X";
  if (card.cost === null) return "N";
  if (card.cost >= 4) return "4+";
  return String(card.cost);
};

const TYPE_ZH: Record<string, string> = {
  Attack: "攻击",
  Skill: "技能",
  Power: "能力",
  Status: "状态",
  Curse: "诅咒",
  Quest: "任务",
};

const getTypeLabel = (card: Card) => {
  if (!card.type) return "未知";
  return TYPE_ZH[card.type] ?? card.type;
};

const RARITY_ZH: Record<string, string> = {
  Basic: "基础",
  Common: "普通",
  Uncommon: "罕见",
  Rare: "稀有",
  Ancient: "古代",
  Event: "事件",
  Token: "衍生",
  Status: "状态",
  Curse: "诅咒",
  Quest: "任务",
};

const COLOR_ZH: Record<string, string> = {
  ironclad: "铁卫",
  silent: "静默",
  defect: "故障",
  necrobinder: "唤尸",
  regent: "摄政",
  colorless: "无色",
  curse: "诅咒",
  status: "状态",
  event: "事件",
  token: "衍生",
  quest: "任务",
};

const frameImageFor = (card: Card) => {
  if (card.rarity?.toLowerCase() === "ancient") return "card_frame_ancient_s";
  const t = card.type?.toLowerCase();
  if (t === "attack") return "card_frame_attack_s";
  if (t === "skill") return "card_frame_skill_s";
  if (t === "power") return "card_frame_power_s";
  if (t === "quest") return "card_frame_quest_s";
  return "card_frame_skill_s";
};

const borderImageFor = (card: Card) => {
  const t = card.type?.toLowerCase();
  if (t === "attack") return "card_portrait_border_attack_s";
  if (t === "skill") return "card_portrait_border_skill_s";
  if (t === "power") return "card_portrait_border_power_s";
  return "card_portrait_border_power_s";
};

const bannerImageFor = (card: Card) =>
  card.rarity?.toLowerCase() === "ancient" ? "ancient_banner" : "card_banner";

const energyImageFor = (card: Card) =>
  energyIconForColor(card.color ?? "colorless");
---

<Layout>
  <main class='min-h-screen px-[6vw] pb-[72px] pt-12'>
    <header class='mx-auto mb-8 max-w-[980px] text-center'>
      <p class='mb-2 text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]'>
        Slay the Spire 2
      </p>
      <h1 class='mb-1 text-[clamp(32px,4vw,56px)]'>卡牌图鉴</h1>
      <p class='text-[#c4c7d6]'>共 {cards.length} 张卡牌</p>
    </header>

    <section
      class='mx-auto mb-6 grid max-w-[1100px] grid-cols-[repeat(auto-fit,minmax(180px,1fr))] items-end gap-3 rounded-2xl border border-white/10 bg-[rgba(16,18,26,0.7)] px-[18px] py-[14px]'
      aria-label='Card filters'
    >
      <label class='grid gap-1.5 text-[13px] text-[#b6bbcc]'>
        <span>类型</span>
        <select
          id='filter-type'
          class='rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20'
        >
          <option value='all' class='bg-[#1a1c24] text-[#f4f4f1]'>全部</option>
          <option value='Attack' class='bg-[#1a1c24] text-[#f4f4f1]'
            >攻击</option
          >
          <option value='Skill' class='bg-[#1a1c24] text-[#f4f4f1]'>技能</option
          >
          <option value='Power' class='bg-[#1a1c24] text-[#f4f4f1]'>能力</option
          >
          <option value='Status' class='bg-[#1a1c24] text-[#f4f4f1]'
            >状态</option
          >
          <option value='Curse' class='bg-[#1a1c24] text-[#f4f4f1]'>诅咒</option
          >
          <option value='Quest' class='bg-[#1a1c24] text-[#f4f4f1]'>任务</option
          >
        </select>
      </label>

      <label class='grid gap-1.5 text-[13px] text-[#b6bbcc]'>
        <span>稀有度</span>
        <select
          id='filter-rarity'
          class='rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20'
        >
          <option value='all' class='bg-[#1a1c24] text-[#f4f4f1]'>全部</option>
          <option value='Basic' class='bg-[#1a1c24] text-[#f4f4f1]'>基础</option
          >
          <option value='Common' class='bg-[#1a1c24] text-[#f4f4f1]'
            >普通</option
          >
          <option value='Uncommon' class='bg-[#1a1c24] text-[#f4f4f1]'
            >罕见</option
          >
          <option value='Rare' class='bg-[#1a1c24] text-[#f4f4f1]'>稀有</option>
          <option value='Ancient' class='bg-[#1a1c24] text-[#f4f4f1]'
            >古代</option
          >
          <option value='Event' class='bg-[#1a1c24] text-[#f4f4f1]'>事件</option
          >
          <option value='Token' class='bg-[#1a1c24] text-[#f4f4f1]'>衍生</option
          >
          <option value='Status' class='bg-[#1a1c24] text-[#f4f4f1]'
            >状态</option
          >
          <option value='Curse' class='bg-[#1a1c24] text-[#f4f4f1]'>诅咒</option
          >
          <option value='Quest' class='bg-[#1a1c24] text-[#f4f4f1]'>任务</option
          >
        </select>
      </label>

      <label class='grid gap-1.5 text-[13px] text-[#b6bbcc]'>
        <span>角色</span>
        <select
          id='filter-color'
          class='rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20'
        >
          <option value='all' class='bg-[#1a1c24] text-[#f4f4f1]'>全部</option>
          <option value='ironclad' class='bg-[#1a1c24] text-[#f4f4f1]'
            >铁卫</option
          >
          <option value='silent' class='bg-[#1a1c24] text-[#f4f4f1]'
            >静默</option
          >
          <option value='defect' class='bg-[#1a1c24] text-[#f4f4f1]'
            >故障</option
          >
          <option value='necrobinder' class='bg-[#1a1c24] text-[#f4f4f1]'
            >唤尸</option
          >
          <option value='regent' class='bg-[#1a1c24] text-[#f4f4f1]'
            >摄政</option
          >
          <option value='colorless' class='bg-[#1a1c24] text-[#f4f4f1]'
            >无色</option
          >
          <option value='status' class='bg-[#1a1c24] text-[#f4f4f1]'
            >状态</option
          >
          <option value='curse' class='bg-[#1a1c24] text-[#f4f4f1]'>诅咒</option
          >
          <option value='event' class='bg-[#1a1c24] text-[#f4f4f1]'>事件</option
          >
          <option value='token' class='bg-[#1a1c24] text-[#f4f4f1]'>衍生</option
          >
          <option value='quest' class='bg-[#1a1c24] text-[#f4f4f1]'>任务</option
          >
        </select>
      </label>

      <label class='grid gap-1.5 text-[13px] text-[#b6bbcc]'>
        <span>费用</span>
        <select
          id='filter-cost'
          class='rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20'
        >
          <option value='all' class='bg-[#1a1c24] text-[#f4f4f1]'>全部</option>
          <option value='0' class='bg-[#1a1c24] text-[#f4f4f1]'>0</option>
          <option value='1' class='bg-[#1a1c24] text-[#f4f4f1]'>1</option>
          <option value='2' class='bg-[#1a1c24] text-[#f4f4f1]'>2</option>
          <option value='3' class='bg-[#1a1c24] text-[#f4f4f1]'>3</option>
          <option value='4+' class='bg-[#1a1c24] text-[#f4f4f1]'>4+</option>
          <option value='X' class='bg-[#1a1c24] text-[#f4f4f1]'>X</option>
        </select>
      </label>

      <button
        type='button'
        id='filter-reset'
        class='rounded-xl border border-white/20 bg-white/15 px-3.5 py-2.5 text-[#f7f1df] hover:bg-white/20 transition-colors'
      >
        重置
      </button>
      <button
        type='button'
        id='toggle-upgrade'
        class='rounded-xl border border-white/20 bg-white/15 px-3.5 py-2.5 text-[#f7f1df] hover:bg-white/20 transition-colors'
      >
        显示升级
      </button>
    </section>

    <section
      class='grid grid-cols-[repeat(auto-fit,minmax(160px,1fr))] gap-[15px]'
      aria-label='Card gallery'
    >
      {
        cards.map((card) => {
          const baseDesc = getDisplayDesc(card);
          const upgradedDesc = getDisplayDescUpgraded(card);
          const upgradeCost = getUpgradeCostLabel(card);
          return (
            <div class='card-tile mx-auto h-[253px] w-[180px]'>
              <div class='relative h-full w-full'>
                <article
                  class='relative left-0 top-0 h-[211px] w-[150px] origin-top-left'
                  data-card='1'
                  data-color={card.color ?? "neutral"}
                  data-type={card.type?.toLowerCase() ?? "unknown"}
                  data-rarity={card.rarity?.toLowerCase() ?? "unknown"}
                  data-type-raw={card.type ?? ""}
                  data-rarity-raw={card.rarity ?? ""}
                  data-color-raw={card.color ?? ""}
                  data-cost-raw={getCostBucket(card)}
                  data-has-upgrade={card.upgrade ? "1" : "0"}
                >
                  <div class='absolute left-[12.5px] top-[21.5px] z-[0] h-[95px] w-[125px] overflow-hidden rounded-[5px]'>
                    <img
                      class='h-full w-full object-cover [filter:drop-shadow(0_5px_9px_rgba(0,0,0,0.4))]'
                      src={`${base}${getCardImage(card)}`}
                      alt=''
                      loading='lazy'
                    />
                  </div>
                  <img
                    class='absolute left-0 top-0 z-[1] h-[211px] w-[150px]'
                    src={`${base}/images/ui/${frameImageFor(card)}.png`}
                    alt=''
                    loading='lazy'
                  />
                  <img
                    class='absolute left-0 top-0 z-[5] h-[211px] w-[150px] opacity-60 mix-blend-soft-light'
                    src={`${base}/images/ui/${frameImageFor(card)}.png`}
                    alt=''
                    loading='lazy'
                  />
                  <img
                    class='absolute left-[6.25px] top-[23.5px] z-[4] h-[105px] w-[137.5px]'
                    src={`${base}/images/ui/${borderImageFor(card)}.png`}
                    alt=''
                    loading='lazy'
                  />
                  <img
                    class='absolute left-[59.75px] top-[106px] z-[6] h-[18.5px] w-[30.5px]'
                    src={`${base}/images/ui/card_portrait_border_plaque2.png`}
                    alt=''
                    loading='lazy'
                  />
                  <img
                    class='absolute left-[-6.5px] top-[2px] z-[6] h-[41.5px] w-[163.5px]'
                    src={`${base}/images/ui/${bannerImageFor(card)}.png`}
                    alt=''
                    loading='lazy'
                  />
                  <div class='absolute left-[-8px] top-[-8px] z-[7] h-[32px] w-[32px]'>
                    <img
                      class='h-full w-full'
                      src={`${base}/images/ui/${energyImageFor(card)}.png`}
                      alt=''
                      loading='lazy'
                    />
                    <span class='absolute left-[4.5px] top-[3px] z-[8] grid h-[28px] w-[23px] place-items-center text-[16px] font-extrabold text-white [text-shadow:0_1px_0_rgba(0,0,0,0.55),0_0_3px_rgba(0,0,0,0.45)]'>
                      {getCostLabel(card)}
                    </span>
                  </div>
                  <span class='absolute left-[59.75px] top-[106px] z-[7] grid h-[18.5px] w-[30.5px] place-items-center text-center text-[8px] font-bold uppercase tracking-[0.08em] text-[#241f17] [text-shadow:0_1px_0_rgba(255,255,255,0.5)]'>
                    {getTypeLabel(card)}
                  </span>
                  <span class='absolute left-[22.5px] top-[3.5px] z-[7] w-[105px] text-center text-[13px] text-[#fdf0d8] [text-shadow:0_1px_1px_rgba(0,0,0,0.35),0_0_3px_rgba(0,0,0,0.45)]'>
                    {getDisplayName(card)}
                  </span>
                  {getStarLabel(card) && (
                    <span class='absolute left-[-18px] top-[11px] z-[7] text-[8px] text-[#ffe3a6] [text-shadow:0_1px_2px_rgba(0,0,0,0.4)]'>
                      ⭐ {getStarLabel(card)}
                    </span>
                  )}
                  {(baseDesc || upgradedDesc) && (
                    <div class='absolute left-[14px] top-[124px] z-[6] h-[72px] w-[121.5px] text-center text-[10.5px] leading-[1.05] tracking-[0.02em] text-[#f2e5cd] [text-shadow:0_1px_1px_rgba(0,0,0,0.4),0_0_3px_rgba(0,0,0,0.45)] flex flex-col items-center justify-center'>
                      {baseDesc && (
                        <div
                          data-desc='base'
                          set:html={formatDescription(baseDesc, card.color)}
                        />
                      )}
                      {card.upgrade && upgradedDesc && (
                        <div
                          data-desc='upgrade'
                          class={`${baseDesc ? "hidden " : ""}mt-1 border-t border-white/20 pt-1 text-[9px] leading-[1.05]`}
                        >
                          <div class='mb-1 text-[5.5px] uppercase tracking-[0.3em] text-[#f5d9a6]'>
                            升级
                          </div>
                          {upgradeCost && (
                            <div class='mb-1 text-[7px] text-[#f5d9a6]'>
                              费用 {upgradeCost}
                            </div>
                          )}
                          <div
                            set:html={formatDescription(
                              upgradedDesc,
                              card.color,
                            )}
                          />
                        </div>
                      )}
                      {card.keywords && card.keywords.length > 0 && (
                        <div class='mt-1 text-[7px] tracking-[0.06em] text-[#f2e5cd]'>
                          {card.keywords.map((kw) => (
                            <span class='mr-1 inline-block rounded-full border border-white/15 bg-white/5 px-1 py-[1px]'>
                              {keywordLabel(kw)}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  )}
                </article>
              </div>
            </div>
          );
        })
      }
    </section>
  </main>
</Layout>

<script>
  const byId = (id) => document.getElementById(id);
  const typeEl = byId("filter-type");
  const rarityEl = byId("filter-rarity");
  const colorEl = byId("filter-color");
  const costEl = byId("filter-cost");
  const resetEl = byId("filter-reset");

  const applyFilters = () => {
    const type = typeEl?.value ?? "all";
    const rarity = rarityEl?.value ?? "all";
    const color = colorEl?.value ?? "all";
    const cost = costEl?.value ?? "all";

    document.querySelectorAll("[data-card]").forEach((node) => {
      const el = node;
      const t = el.dataset.typeRaw || "";
      const r = el.dataset.rarityRaw || "";
      const c = el.dataset.colorRaw || "";
      const k = el.dataset.costRaw || "";

      const match =
        (type === "all" || t === type) &&
        (rarity === "all" || r === rarity) &&
        (color === "all" || c === color) &&
        (cost === "all" || k === cost);

      const wrapper = el.closest(".card-tile");
      if (wrapper) {
        wrapper.style.display = match ? "" : "none";
      }
    });
  };

  [typeEl, rarityEl, colorEl, costEl].forEach((el) => {
    el?.addEventListener("change", applyFilters);
  });

  resetEl?.addEventListener("click", () => {
    if (typeEl) typeEl.value = "all";
    if (rarityEl) rarityEl.value = "all";
    if (colorEl) colorEl.value = "all";
    if (costEl) costEl.value = "all";
    applyFilters();
  });

  const upgradeEl = byId("toggle-upgrade");
  upgradeEl?.addEventListener("click", () => {
    document.body.classList.toggle("show-upgrade");
    const enabled = document.body.classList.contains("show-upgrade");
    upgradeEl.textContent = enabled ? "显示基础" : "显示升级";
    document.querySelectorAll('[data-has-upgrade="1"]').forEach((card) => {
      const base = card.querySelector('[data-desc="base"]');
      const upgrade = card.querySelector('[data-desc="upgrade"]');
      if (base) base.classList.toggle("hidden", enabled);
      if (upgrade) {
        const shouldShowUpgrade = enabled || !base;
        upgrade.classList.toggle("hidden", !shouldShowUpgrade);
      }
    });
  });

  const tooltip = document.createElement("div");
  tooltip.className =
    "fixed z-[9999] max-w-[420px] px-[10px] py-2 rounded-[10px] bg-[rgba(6,8,14,0.95)] text-[#f2f2f0] text-[13px] leading-[1.5] whitespace-pre-wrap shadow-[0_10px_24px_rgba(0,0,0,0.45)] pointer-events-none opacity-0 translate-y-1 transition-[opacity,transform] duration-150";
  document.body.appendChild(tooltip);
  let activeTip = null;

  const showTip = (el, x, y) => {
    const html = el.getAttribute("data-tip-html");
    if (!html) return;
    tooltip.innerHTML = html;
    tooltip.classList.add("opacity-100", "translate-y-0");
    tooltip.classList.remove("opacity-0", "translate-y-1");
    tooltip.style.left = `${x + 12}px`;
    tooltip.style.top = `${y + 12}px`;
    activeTip = el;
  };

  const hideTip = () => {
    tooltip.classList.add("opacity-0", "translate-y-1");
    tooltip.classList.remove("opacity-100", "translate-y-0");
    activeTip = null;
  };

  document.addEventListener("mousemove", (e) => {
    if (!activeTip) return;
    tooltip.style.left = `${e.clientX + 12}px`;
    tooltip.style.top = `${e.clientY + 12}px`;
  });

  document.addEventListener("mouseover", (e) => {
    const target =
      e.target instanceof Element ? e.target.closest("[data-tip-html]") : null;
    if (target) {
      showTip(target, e.clientX, e.clientY);
    }
  });

  document.addEventListener("mouseout", (e) => {
    const target =
      e.target instanceof Element ? e.target.closest("[data-tip-html]") : null;
    if (target && target === activeTip) hideTip();
  });
</script>
