---
import Layout from "../layouts/Layout.astro";
import CardView from "../components/CardView.astro";
import TopNav from "../components/TopNav.astro";
import cardsData from "../../data/cards.json";
import charactersData from "../../data/characters.json";
import type { Card } from "../lib/cardModels";
import { getLangFromUrl, pickText, withLang } from "../lib/i18n";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";

const cards = cardsData as Card[];
const characters = charactersData as Array<{
  id: string;
  name: string;
  name_zh?: string | null;
  color?: string | null;
}>;
const characterOptions = characters
  .filter((character) => character.color)
  .map((character) => ({
    value: character.color as string,
    label: pickText(lang, character.name_zh, character.name, character.id),
  }));

const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(withLang(`${base}/`, lang), origin).toString();
const pageTitle = isEn
  ? "Card Library | Slay the Spire 2 Database"
  : "卡牌库 | 杀戮尖塔2 中文资料库";
const pageDescription = isEn
  ? `All Slay the Spire 2 cards (${cards.length} total), with filters for type, rarity, character, cost, and search.`
  : `收录杀戮尖塔2全部卡牌，共 ${cards.length} 张。支持类型、稀有度、角色、费用筛选与搜索。`;

const t = {
  navLabel: isEn ? "Cards" : "卡牌",
  title: isEn ? "Card Compendium" : "卡牌图鉴",
  count: isEn ? `${cards.length} cards` : `共 ${cards.length} 张卡牌`,
  type: isEn ? "Type" : "类型",
  rarity: isEn ? "Rarity" : "稀有度",
  character: isEn ? "Character" : "角色",
  cost: isEn ? "Cost" : "费用",
  search: isEn ? "Search" : "搜索",
  selectAll: isEn ? "All" : "全选",
  noColor: isEn ? "Colorless" : "无色",
  status: isEn ? "Status" : "状态",
  curse: isEn ? "Curse" : "诅咒",
  event: isEn ? "Event" : "事件",
  token: isEn ? "Token" : "衍生",
  quest: isEn ? "Quest" : "任务",
  reset: isEn ? "Reset" : "重置",
  showUpgrade: isEn ? "Show Upgrade" : "显示升级",
  showBase: isEn ? "Show Base" : "显示基础",
  filters: isEn ? "Filters" : "筛选",
  expand: isEn ? "Expand" : "展开",
  collapse: isEn ? "Collapse" : "收起",
  searchPlaceholder: isEn
    ? "Name / Description / Keyword"
    : "名称 / 描述 / 关键字",
};

const typeOptions = [
  { value: "Attack", label: isEn ? "Attack" : "攻击" },
  { value: "Skill", label: isEn ? "Skill" : "技能" },
  { value: "Power", label: isEn ? "Power" : "能力" },
  { value: "Status", label: isEn ? "Status" : "状态" },
  { value: "Curse", label: isEn ? "Curse" : "诅咒" },
  { value: "Quest", label: isEn ? "Quest" : "任务" },
];

const rarityOptions = [
  { value: "Basic", label: isEn ? "Basic" : "基础" },
  { value: "Common", label: isEn ? "Common" : "普通" },
  { value: "Uncommon", label: isEn ? "Uncommon" : "罕见" },
  { value: "Rare", label: isEn ? "Rare" : "稀有" },
  { value: "Ancient", label: isEn ? "Ancient" : "古代" },
  { value: "Event", label: isEn ? "Event" : "事件" },
  { value: "Token", label: isEn ? "Token" : "衍生" },
  { value: "Status", label: isEn ? "Status" : "状态" },
  { value: "Curse", label: isEn ? "Curse" : "诅咒" },
  { value: "Quest", label: isEn ? "Quest" : "任务" },
];
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
  </Fragment>
  <main class="px-3 pb-8 pt-10 sm:px-[6vw] sm:pb-10 sm:pt-12" data-base-path={base}>
    <div class="mx-auto flex max-w-[1100px] flex-col gap-4 sm:gap-6">
      <header>
        <div class="flex flex-wrap items-end justify-between gap-3 sm:gap-6">
          <div>
            <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
              {t.navLabel}
            </div>
            <h1 class="mt-2 text-[26px] font-semibold text-[#fdf0d8]">
              {t.title}
            </h1>
            <p class="mt-1 text-[#c4c7d6]">{t.count}</p>
          </div>
          <TopNav current="cards" basePath={base} lang={lang} />
        </div>
      </header>

      <section
        class="flex flex-col gap-2 rounded-2xl border border-white/10 bg-[rgba(16,18,26,0.7)] px-3 py-3 sm:gap-3 sm:px-[18px] sm:py-[14px]"
        aria-label="Card filters"
      >
        <div class="mb-1 flex items-center justify-between sm:hidden">
          <div class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">{t.filters}</div>
          <button
            type="button"
            id="card-filter-toggle"
            data-label-expand={t.expand}
            data-label-collapse={t.collapse}
            class="h-8 rounded-[10px] border border-white/20 bg-white/10 px-3 text-[12px] text-[#f7f1df] transition hover:bg-white/20"
            aria-expanded="true"
          >
            {t.collapse}
          </button>
        </div>

        <div id="card-filter-body" class="flex flex-col gap-3">
        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-start sm:gap-3">
          <span class="shrink-0 pt-1 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.type}</span>
          <div class="flex flex-wrap gap-2 sm:flex-1" data-filter-group="type">
            <button
              type="button"
              data-filter-all
              class="rounded-full border border-white/40 bg-white/20 px-3 py-1 text-[12px] text-[#fdf0d8] transition"
              aria-pressed="true"
            >
              {t.selectAll}
            </button>
            {typeOptions.map((opt) => (
              <button
                type="button"
                data-filter-value={opt.value}
                class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10"
                aria-pressed="false"
              >
                {opt.label}
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-start sm:gap-3">
          <span class="shrink-0 pt-1 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.rarity}</span>
          <div class="flex flex-wrap gap-2 sm:flex-1" data-filter-group="rarity">
            <button
              type="button"
              data-filter-all
              class="rounded-full border border-white/40 bg-white/20 px-3 py-1 text-[12px] text-[#fdf0d8] transition"
              aria-pressed="true"
            >
              {t.selectAll}
            </button>
            {rarityOptions.map((opt) => (
              <button
                type="button"
                data-filter-value={opt.value}
                class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10"
                aria-pressed="false"
              >
                {opt.label}
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-start sm:gap-3">
          <span class="shrink-0 pt-1 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.character}</span>
          <div class="flex flex-wrap gap-2 sm:flex-1" data-filter-group="color">
            <button
              type="button"
              data-filter-all
              class="rounded-full border border-white/40 bg-white/20 px-3 py-1 text-[12px] text-[#fdf0d8] transition"
              aria-pressed="true"
            >
              {t.selectAll}
            </button>
            {characterOptions.map((opt) => (
              <button
                type="button"
                data-filter-value={opt.value}
                class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10"
                aria-pressed="false"
              >
                {opt.label}
              </button>
            ))}
            <button type="button" data-filter-value="colorless" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">{t.noColor}</button>
            <button type="button" data-filter-value="status" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">{t.status}</button>
            <button type="button" data-filter-value="curse" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">{t.curse}</button>
            <button type="button" data-filter-value="event" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">{t.event}</button>
            <button type="button" data-filter-value="token" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">{t.token}</button>
            <button type="button" data-filter-value="quest" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">{t.quest}</button>
          </div>
        </div>

        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-start sm:gap-3">
          <span class="shrink-0 pt-1 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.cost}</span>
          <div class="flex flex-wrap gap-2 sm:flex-1" data-filter-group="cost">
            <button
              type="button"
              data-filter-all
              class="rounded-full border border-white/40 bg-white/20 px-3 py-1 text-[12px] text-[#fdf0d8] transition"
              aria-pressed="true"
            >
              {t.selectAll}
            </button>
            <button type="button" data-filter-value="0" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">0</button>
            <button type="button" data-filter-value="1" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">1</button>
            <button type="button" data-filter-value="2" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">2</button>
            <button type="button" data-filter-value="3" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">3</button>
            <button type="button" data-filter-value="4+" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">4+</button>
            <button type="button" data-filter-value="X" class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10" aria-pressed="false">X</button>
          </div>
        </div>

        <label class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-center sm:gap-3">
          <span class="shrink-0 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.search}</span>
          <div class="flex flex-col gap-2 sm:flex-1 sm:flex-row">
            <input
              id="filter-search"
              type="search"
              placeholder={t.searchPlaceholder}
              class="h-9 rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-0 text-[#f4f4f1] placeholder:text-[#6f7486] appearance-none focus:outline-none focus:ring-1 focus:ring-white/20 sm:flex-1"
            />
            <button
              type="button"
              id="filter-reset"
              class="h-9 rounded-[10px] border border-white/20 bg-white/15 px-3 text-[#f7f1df] hover:bg-white/20 transition-colors"
            >
              {t.reset}
            </button>
            <button
              type="button"
              id="toggle-upgrade"
              data-label-upgrade={t.showUpgrade}
              data-label-base={t.showBase}
              class="h-9 rounded-[10px] border border-white/20 bg-white/15 px-3 text-[#f7f1df] hover:bg-white/20 transition-colors"
            >
              {t.showUpgrade}
            </button>
          </div>
        </label>
        </div>
      </section>

      <section
        class="grid grid-cols-[repeat(auto-fit,minmax(160px,1fr))] gap-[15px]"
        aria-label="Card gallery"
      >
        {
          cards.map((card) => {
            return (
              <a class="block card-tile" href={withLang(`${base}/card/${card.id}`, lang)}>
                <CardView card={card} lang={lang} />
              </a>
            );
          })
        }
      </section>
    </div>
  </main>
</Layout>

<script>
  const byId = (id: string): HTMLElement | null =>
    document.getElementById(id);
  const filterToggleEl = byId("card-filter-toggle") as HTMLButtonElement | null;
  const filterBodyEl = byId("card-filter-body") as HTMLElement | null;
  const searchEl = byId("filter-search") as HTMLInputElement | null;
  const resetEl = byId("filter-reset") as HTMLButtonElement | null;
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>("[data-filter-group]"),
  ).map((el) => ({
    el,
    name: el.dataset.filterGroup ?? "",
    values: Array.from(
      el.querySelectorAll<HTMLButtonElement>("[data-filter-value]"),
    )
      .map((btn) => btn.dataset.filterValue ?? "")
      .filter(Boolean),
    selected: new Set<string>(["all"]),
  }));
  const groupMap = new Map(groups.map((group) => [group.name, group]));

  const setupFilterCollapse = (
    toggleEl: HTMLButtonElement | null,
    bodyEl: HTMLElement | null,
  ) => {
    if (!toggleEl || !bodyEl) return;
    const mobileMq = window.matchMedia("(max-width: 639px)");
    let collapsed = mobileMq.matches;

    const render = () => {
      const shouldHide = mobileMq.matches && collapsed;
      bodyEl.classList.toggle("hidden", shouldHide);
      const expandLabel = toggleEl.dataset.labelExpand ?? "展开";
      const collapseLabel = toggleEl.dataset.labelCollapse ?? "收起";
      toggleEl.textContent = shouldHide ? expandLabel : collapseLabel;
      toggleEl.setAttribute("aria-expanded", shouldHide ? "false" : "true");
    };

    render();
    toggleEl.addEventListener("click", () => {
      collapsed = !collapsed;
      render();
    });
    const onMediaChange = () => {
      collapsed = mobileMq.matches;
      render();
    };
    if ("addEventListener" in mobileMq) {
      mobileMq.addEventListener("change", onMediaChange);
    } else {
      mobileMq.addListener(onMediaChange);
    }
  };

  setupFilterCollapse(filterToggleEl, filterBodyEl);

  const setBtnActive = (btn: HTMLButtonElement, active: boolean) => {
    btn.setAttribute("aria-pressed", active ? "true" : "false");
    btn.classList.toggle("border-white/40", active);
    btn.classList.toggle("bg-white/20", active);
    btn.classList.toggle("text-[#fdf0d8]", active);
    btn.classList.toggle("border-white/10", !active);
    btn.classList.toggle("bg-white/5", !active);
    btn.classList.toggle("text-[#cdd2e3]", !active);
  };

  const syncGroup = (group: (typeof groups)[number]) => {
    const isAll = group.selected.has("all");
    const allBtn = group.el.querySelector<HTMLButtonElement>("[data-filter-all]");
    if (allBtn) setBtnActive(allBtn, isAll);
    group.el
      .querySelectorAll<HTMLButtonElement>("[data-filter-value]")
      .forEach((btn) => {
        const val = btn.dataset.filterValue ?? "";
        setBtnActive(btn, !isAll && group.selected.has(val));
      });
  };

  const setGroupAll = (group: (typeof groups)[number]) => {
    group.selected = new Set(["all"]);
    syncGroup(group);
  };

  const toggleGroupValue = (group: (typeof groups)[number], value: string) => {
    if (group.selected.has("all")) group.selected.clear();
    if (group.selected.has(value)) group.selected.delete(value);
    else group.selected.add(value);
    if (group.selected.size === 0 || group.selected.size === group.values.length) {
      setGroupAll(group);
      return;
    }
    syncGroup(group);
  };

  const matchesGroup = (name: string, value: string) => {
    const group = groupMap.get(name);
    if (!group) return true;
    return group.selected.has("all") || group.selected.has(value);
  };

  const applyFilters = () => {
    const query = (searchEl?.value ?? "").trim().toLowerCase();

    document
      .querySelectorAll("[data-card]")
      .forEach((node) => {
        const el = node as HTMLElement;
        const t = el.dataset.typeRaw || "";
        const r = el.dataset.rarityRaw || "";
        const c = el.dataset.colorRaw || "";
        const k = el.dataset.costRaw || "";
        const s = el.dataset.search || "";

        const match =
          matchesGroup("type", t) &&
          matchesGroup("rarity", r) &&
          matchesGroup("color", c) &&
          matchesGroup("cost", k) &&
          (!query || s.includes(query));

        const wrapper = el.closest(".card-tile") as HTMLElement | null;
        if (wrapper) {
          wrapper.style.display = match ? "" : "none";
        }
      });
  };

  groups.forEach((group) => {
    const allBtn = group.el.querySelector<HTMLButtonElement>("[data-filter-all]");
    allBtn?.addEventListener("click", () => {
      setGroupAll(group);
      applyFilters();
    });
    group.el
      .querySelectorAll<HTMLButtonElement>("[data-filter-value]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const value = btn.dataset.filterValue ?? "";
          if (!value) return;
          toggleGroupValue(group, value);
          applyFilters();
        });
      });
    syncGroup(group);
  });
  searchEl?.addEventListener("input", applyFilters);

  const params = new URLSearchParams(window.location.search);
  const searchFromQuery = params.get("search");
  if (searchEl && searchFromQuery) {
    searchEl.value = searchFromQuery;
    applyFilters();
  }

  resetEl?.addEventListener("click", () => {
    groups.forEach((group) => setGroupAll(group));
    if (searchEl) searchEl.value = "";
    applyFilters();
  });

  const upgradeEl = byId("toggle-upgrade") as HTMLButtonElement | null;
  upgradeEl?.addEventListener("click", () => {
    document.body.classList.toggle("show-upgrade");
    const enabled = document.body.classList.contains("show-upgrade");
    const labelBase = upgradeEl.getAttribute("data-label-base") ?? "显示基础";
    const labelUpgrade =
      upgradeEl.getAttribute("data-label-upgrade") ?? "显示升级";
    upgradeEl.textContent = enabled ? labelBase : labelUpgrade;
    document.querySelectorAll('[data-has-upgrade="1"]').forEach((card) => {
      const base = card.querySelector('[data-desc="base"]');
      const upgrade = card.querySelector('[data-desc="upgrade"]');
      const nameBase = card.querySelector('[data-name="base"]');
      const nameUpgrade = card.querySelector('[data-name="upgrade"]');
      const costBase = card.querySelector('[data-cost="base"]');
      const costUpgrade = card.querySelector('[data-cost="upgrade"]');
      if (base) base.classList.toggle("hidden", enabled);
      if (upgrade) {
        const shouldShowUpgrade = enabled || !base;
        upgrade.classList.toggle("hidden", !shouldShowUpgrade);
      }
      if (nameBase) nameBase.classList.toggle("hidden", enabled);
      if (nameUpgrade) nameUpgrade.classList.toggle("hidden", !enabled);
      if (costBase)
        costBase.classList.toggle("hidden", enabled && !!costUpgrade);
      if (costUpgrade) costUpgrade.classList.toggle("hidden", !enabled);
    });
  });

  const tooltip = document.createElement("div");
  tooltip.className =
    "fixed z-[9999] max-w-[420px] px-[10px] py-2 rounded-[10px] bg-[rgba(6,8,14,0.95)] text-[#f2f2f0] text-[13px] leading-[1.5] whitespace-pre-wrap shadow-[0_10px_24px_rgba(0,0,0,0.45)] pointer-events-none opacity-0 translate-y-1 transition-[opacity,transform] duration-150";
  document.body.appendChild(tooltip);
  let activeTip: HTMLElement | null = null;

  const showTip = (el: HTMLElement, x: number, y: number) => {
    const html = el.getAttribute("data-tip-html");
    if (!html) return;
    tooltip.innerHTML = html;
    tooltip.classList.add("opacity-100", "translate-y-0");
    tooltip.classList.remove("opacity-0", "translate-y-1");
    tooltip.style.left = `${x + 12}px`;
    tooltip.style.top = `${y + 12}px`;
    activeTip = el;
  };

  const hideTip = () => {
    tooltip.classList.add("opacity-0", "translate-y-1");
    tooltip.classList.remove("opacity-100", "translate-y-0");
    activeTip = null;
  };

  document.addEventListener("mousemove", (e) => {
    if (!activeTip) return;
    tooltip.style.left = `${e.clientX + 12}px`;
    tooltip.style.top = `${e.clientY + 12}px`;
  });

  document.addEventListener("mouseover", (e) => {
    const target =
      e.target instanceof Element ? e.target.closest("[data-tip-html]") : null;
    if (target) {
      showTip(target as HTMLElement, e.clientX, e.clientY);
    }
  });

  document.addEventListener("mouseout", (e) => {
    const target =
      e.target instanceof Element ? e.target.closest("[data-tip-html]") : null;
    if (target && target === activeTip) hideTip();
  });
</script>
