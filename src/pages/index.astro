---
import Layout from "../layouts/Layout.astro";
import CardView from "../components/CardView.astro";
import TopNav from "../components/TopNav.astro";
import cardsData from "../../data/cards.json";
import charactersData from "../../data/characters.json";
import type { Card } from "../lib/cardModels";
import { getLangFromUrl, pickText, withLang } from "../lib/i18n";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";

const cards = cardsData as Card[];
const characters = charactersData as Array<{
  id: string;
  name: string;
  name_zh?: string | null;
  color?: string | null;
}>;
const characterOptions = characters
  .filter((character) => character.color)
  .map((character) => ({
    value: character.color as string,
    label: pickText(lang, character.name_zh, character.name, character.id),
  }));

const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(withLang(`${base}/`, lang), origin).toString();
const pageTitle = isEn
  ? "Card Library | Slay the Spire 2 Database"
  : "卡牌库 | 杀戮尖塔2 中文资料库";
const pageDescription = isEn
  ? `All Slay the Spire 2 cards (${cards.length} total), with filters for type, rarity, character, cost, and search.`
  : `收录杀戮尖塔2全部卡牌，共 ${cards.length} 张。支持类型、稀有度、角色、费用筛选与搜索。`;

const t = {
  navLabel: isEn ? "Cards" : "卡牌",
  title: isEn ? "Card Compendium" : "卡牌图鉴",
  count: isEn ? `${cards.length} cards` : `共 ${cards.length} 张卡牌`,
  type: isEn ? "Type" : "类型",
  rarity: isEn ? "Rarity" : "稀有度",
  character: isEn ? "Character" : "角色",
  cost: isEn ? "Cost" : "费用",
  search: isEn ? "Search" : "搜索",
  all: isEn ? "All" : "全部",
  noColor: isEn ? "Colorless" : "无色",
  status: isEn ? "Status" : "状态",
  curse: isEn ? "Curse" : "诅咒",
  event: isEn ? "Event" : "事件",
  token: isEn ? "Token" : "衍生",
  quest: isEn ? "Quest" : "任务",
  reset: isEn ? "Reset" : "重置",
  showUpgrade: isEn ? "Show Upgrade" : "显示升级",
  showBase: isEn ? "Show Base" : "显示基础",
  searchPlaceholder: isEn
    ? "Name / Description / Keyword"
    : "名称 / 描述 / 关键字",
};

const typeOptions = [
  { value: "Attack", label: isEn ? "Attack" : "攻击" },
  { value: "Skill", label: isEn ? "Skill" : "技能" },
  { value: "Power", label: isEn ? "Power" : "能力" },
  { value: "Status", label: isEn ? "Status" : "状态" },
  { value: "Curse", label: isEn ? "Curse" : "诅咒" },
  { value: "Quest", label: isEn ? "Quest" : "任务" },
];

const rarityOptions = [
  { value: "Basic", label: isEn ? "Basic" : "基础" },
  { value: "Common", label: isEn ? "Common" : "普通" },
  { value: "Uncommon", label: isEn ? "Uncommon" : "罕见" },
  { value: "Rare", label: isEn ? "Rare" : "稀有" },
  { value: "Ancient", label: isEn ? "Ancient" : "古代" },
  { value: "Event", label: isEn ? "Event" : "事件" },
  { value: "Token", label: isEn ? "Token" : "衍生" },
  { value: "Status", label: isEn ? "Status" : "状态" },
  { value: "Curse", label: isEn ? "Curse" : "诅咒" },
  { value: "Quest", label: isEn ? "Quest" : "任务" },
];
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
  </Fragment>
  <main class="px-3 pb-8 pt-10 sm:px-[6vw] sm:pb-10 sm:pt-12" data-base-path={base}>
    <div class="mx-auto flex max-w-[1100px] flex-col gap-6">
      <header>
        <div class="flex flex-wrap items-end justify-between gap-6">
          <div>
            <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
              {t.navLabel}
            </div>
            <h1 class="mt-2 text-[26px] font-semibold text-[#fdf0d8]">
              {t.title}
            </h1>
            <p class="mt-1 text-[#c4c7d6]">{t.count}</p>
          </div>
          <TopNav current="cards" basePath={base} lang={lang} />
        </div>
      </header>

      <section
        class="grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] items-end gap-3 rounded-2xl border border-white/10 bg-[rgba(16,18,26,0.7)] px-[18px] py-[14px]"
        aria-label="Card filters"
      >
        <label class="grid gap-1.5 text-[13px] text-[#b6bbcc]">
          <span>{t.type}</span>
          <select
            id="filter-type"
            class="rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20"
          >
            <option value="all" class="bg-[#1a1c24] text-[#f4f4f1]">{t.all}</option>
            {typeOptions.map((opt) => (
              <option value={opt.value} class="bg-[#1a1c24] text-[#f4f4f1]">
                {opt.label}
              </option>
            ))}
          </select>
        </label>

        <label class="grid gap-1.5 text-[13px] text-[#b6bbcc]">
          <span>{t.rarity}</span>
          <select
            id="filter-rarity"
            class="rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20"
          >
            <option value="all" class="bg-[#1a1c24] text-[#f4f4f1]">{t.all}</option>
            {rarityOptions.map((opt) => (
              <option value={opt.value} class="bg-[#1a1c24] text-[#f4f4f1]">
                {opt.label}
              </option>
            ))}
          </select>
        </label>

        <label class="grid gap-1.5 text-[13px] text-[#b6bbcc]">
          <span>{t.character}</span>
          <select
            id="filter-color"
            class="rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20"
          >
            <option value="all" class="bg-[#1a1c24] text-[#f4f4f1]">{t.all}</option>
            {characterOptions.map((opt) => (
              <option value={opt.value} class="bg-[#1a1c24] text-[#f4f4f1]">
                {opt.label}
              </option>
            ))}
            <option value="colorless" class="bg-[#1a1c24] text-[#f4f4f1]">{t.noColor}</option>
            <option value="status" class="bg-[#1a1c24] text-[#f4f4f1]">{t.status}</option>
            <option value="curse" class="bg-[#1a1c24] text-[#f4f4f1]">{t.curse}</option>
            <option value="event" class="bg-[#1a1c24] text-[#f4f4f1]">{t.event}</option>
            <option value="token" class="bg-[#1a1c24] text-[#f4f4f1]">{t.token}</option>
            <option value="quest" class="bg-[#1a1c24] text-[#f4f4f1]">{t.quest}</option>
          </select>
        </label>

        <label class="grid gap-1.5 text-[13px] text-[#b6bbcc]">
          <span>{t.cost}</span>
          <select
            id="filter-cost"
            class="rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20"
          >
            <option value="all" class="bg-[#1a1c24] text-[#f4f4f1]">{t.all}</option>
            <option value="0" class="bg-[#1a1c24] text-[#f4f4f1]">0</option>
            <option value="1" class="bg-[#1a1c24] text-[#f4f4f1]">1</option>
            <option value="2" class="bg-[#1a1c24] text-[#f4f4f1]">2</option>
            <option value="3" class="bg-[#1a1c24] text-[#f4f4f1]">3</option>
            <option value="4+" class="bg-[#1a1c24] text-[#f4f4f1]">4+</option>
            <option value="X" class="bg-[#1a1c24] text-[#f4f4f1]">X</option>
          </select>
        </label>

        <label class="grid gap-1.5 text-[13px] text-[#b6bbcc]">
          <span>{t.search}</span>
          <input
            id="filter-search"
            type="search"
            placeholder={t.searchPlaceholder}
            class="rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] placeholder:text-[#6f7486] appearance-none focus:outline-none focus:ring-1 focus:ring-white/20"
          />
        </label>

        <button
          type="button"
          id="filter-reset"
          class="rounded-xl border border-white/20 bg-white/15 px-3.5 py-2.5 text-[#f7f1df] hover:bg-white/20 transition-colors"
        >
          {t.reset}
        </button>
        <button
          type="button"
          id="toggle-upgrade"
          data-label-upgrade={t.showUpgrade}
          data-label-base={t.showBase}
          class="rounded-xl border border-white/20 bg-white/15 px-3.5 py-2.5 text-[#f7f1df] hover:bg-white/20 transition-colors"
        >
          {t.showUpgrade}
        </button>
      </section>

      <section
        class="grid grid-cols-[repeat(auto-fit,minmax(160px,1fr))] gap-[15px]"
        aria-label="Card gallery"
      >
        {
          cards.map((card) => {
            return (
              <div class="card-tile mx-auto h-[253px] w-[180px]">
                <a class="block" href={withLang(`${base}/card/${card.id}`, lang)}>
                  <CardView card={card} lang={lang} />
                </a>
              </div>
            );
          })
        }
      </section>
    </div>
  </main>
</Layout>

<script>
  const byId = (id: string): HTMLElement | null =>
    document.getElementById(id);
  const typeEl = byId("filter-type") as HTMLSelectElement | null;
  const rarityEl = byId("filter-rarity") as HTMLSelectElement | null;
  const colorEl = byId("filter-color") as HTMLSelectElement | null;
  const costEl = byId("filter-cost") as HTMLSelectElement | null;
  const searchEl = byId("filter-search") as HTMLInputElement | null;
  const resetEl = byId("filter-reset") as HTMLButtonElement | null;

  const applyFilters = () => {
    const type = typeEl?.value ?? "all";
    const rarity = rarityEl?.value ?? "all";
    const color = colorEl?.value ?? "all";
    const cost = costEl?.value ?? "all";
    const query = (searchEl?.value ?? "").trim().toLowerCase();

    document
      .querySelectorAll("[data-card]")
      .forEach((node) => {
        const el = node as HTMLElement;
        const t = el.dataset.typeRaw || "";
        const r = el.dataset.rarityRaw || "";
        const c = el.dataset.colorRaw || "";
        const k = el.dataset.costRaw || "";
        const s = el.dataset.search || "";

        const match =
          (type === "all" || t === type) &&
          (rarity === "all" || r === rarity) &&
          (color === "all" || c === color) &&
          (cost === "all" || k === cost) &&
          (!query || s.includes(query));

        const wrapper = el.closest(".card-tile") as HTMLElement | null;
        if (wrapper) {
          wrapper.style.display = match ? "" : "none";
        }
      });
  };

  [typeEl, rarityEl, colorEl, costEl].forEach((el) => {
    el?.addEventListener("change", applyFilters);
  });
  searchEl?.addEventListener("input", applyFilters);

  const params = new URLSearchParams(window.location.search);
  const searchFromQuery = params.get("search");
  if (searchEl && searchFromQuery) {
    searchEl.value = searchFromQuery;
    applyFilters();
  }

  resetEl?.addEventListener("click", () => {
    if (typeEl) typeEl.value = "all";
    if (rarityEl) rarityEl.value = "all";
    if (colorEl) colorEl.value = "all";
    if (costEl) costEl.value = "all";
    if (searchEl) searchEl.value = "";
    applyFilters();
  });

  const upgradeEl = byId("toggle-upgrade") as HTMLButtonElement | null;
  upgradeEl?.addEventListener("click", () => {
    document.body.classList.toggle("show-upgrade");
    const enabled = document.body.classList.contains("show-upgrade");
    const labelBase = upgradeEl.getAttribute("data-label-base") ?? "显示基础";
    const labelUpgrade =
      upgradeEl.getAttribute("data-label-upgrade") ?? "显示升级";
    upgradeEl.textContent = enabled ? labelBase : labelUpgrade;
    document.querySelectorAll('[data-has-upgrade="1"]').forEach((card) => {
      const base = card.querySelector('[data-desc="base"]');
      const upgrade = card.querySelector('[data-desc="upgrade"]');
      const nameBase = card.querySelector('[data-name="base"]');
      const nameUpgrade = card.querySelector('[data-name="upgrade"]');
      const costBase = card.querySelector('[data-cost="base"]');
      const costUpgrade = card.querySelector('[data-cost="upgrade"]');
      if (base) base.classList.toggle("hidden", enabled);
      if (upgrade) {
        const shouldShowUpgrade = enabled || !base;
        upgrade.classList.toggle("hidden", !shouldShowUpgrade);
      }
      if (nameBase) nameBase.classList.toggle("hidden", enabled);
      if (nameUpgrade) nameUpgrade.classList.toggle("hidden", !enabled);
      if (costBase)
        costBase.classList.toggle("hidden", enabled && !!costUpgrade);
      if (costUpgrade) costUpgrade.classList.toggle("hidden", !enabled);
    });
  });

  const tooltip = document.createElement("div");
  tooltip.className =
    "fixed z-[9999] max-w-[420px] px-[10px] py-2 rounded-[10px] bg-[rgba(6,8,14,0.95)] text-[#f2f2f0] text-[13px] leading-[1.5] whitespace-pre-wrap shadow-[0_10px_24px_rgba(0,0,0,0.45)] pointer-events-none opacity-0 translate-y-1 transition-[opacity,transform] duration-150";
  document.body.appendChild(tooltip);
  let activeTip: HTMLElement | null = null;

  const showTip = (el: HTMLElement, x: number, y: number) => {
    const html = el.getAttribute("data-tip-html");
    if (!html) return;
    tooltip.innerHTML = html;
    tooltip.classList.add("opacity-100", "translate-y-0");
    tooltip.classList.remove("opacity-0", "translate-y-1");
    tooltip.style.left = `${x + 12}px`;
    tooltip.style.top = `${y + 12}px`;
    activeTip = el;
  };

  const hideTip = () => {
    tooltip.classList.add("opacity-0", "translate-y-1");
    tooltip.classList.remove("opacity-100", "translate-y-0");
    activeTip = null;
  };

  document.addEventListener("mousemove", (e) => {
    if (!activeTip) return;
    tooltip.style.left = `${e.clientX + 12}px`;
    tooltip.style.top = `${e.clientY + 12}px`;
  });

  document.addEventListener("mouseover", (e) => {
    const target =
      e.target instanceof Element ? e.target.closest("[data-tip-html]") : null;
    if (target) {
      showTip(target as HTMLElement, e.clientX, e.clientY);
    }
  });

  document.addEventListener("mouseout", (e) => {
    const target =
      e.target instanceof Element ? e.target.closest("[data-tip-html]") : null;
    if (target && target === activeTip) hideTip();
  });
</script>
