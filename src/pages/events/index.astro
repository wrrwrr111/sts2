---
import Layout from "../../layouts/Layout.astro";
import eventsData from "../../../data/events.json";
import cardsData from "../../../data/cards.json";
import relicsData from "../../../data/relics.json";
import potionsData from "../../../data/potions.json";
import { formatRelicText } from "../../lib/relicText";
import TopNav from "../../components/TopNav.astro";
import { getLangFromUrl, pickText, withLang } from "../../lib/i18n";
import { createMentionResolver } from "../../lib/entityMention";
import type { Card } from "../../lib/cardModels";
import type { PotionEntity, RelicEntity } from "../../lib/entityModels";

type EventOption = {
  id: string;
  title?: string | null;
  title_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
};

type EventPage = {
  id: string;
  description?: string | null;
  description_zh?: string | null;
  options?: EventOption[] | null;
};

type EventItem = {
  id: string;
  name: string;
  name_zh?: string | null;
  type?: string | null;
  act?: string | null;
  description?: string | null;
  description_zh?: string | null;
  options?: EventOption[] | null;
  pages?: EventPage[] | null;
};
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";
const events = eventsData as EventItem[];
const cards = cardsData as Card[];
const relics = relicsData as RelicEntity[];
const potions = potionsData as PotionEntity[];
const resolveMention = createMentionResolver({
  base,
  lang,
  cards,
  relics,
  potions,
});

const getName = (event: EventItem) =>
  pickText(lang, event.name_zh, event.name, event.id);
const getDesc = (event: EventItem) =>
  pickText(lang, event.description_zh, event.description);
const formatEventText = (text: string) =>
  formatRelicText(text, base, { resolveMention });

const types = Array.from(
  new Set(events.map((item) => item.type).filter(Boolean)),
) as string[];
const acts = Array.from(
  new Set(events.map((item) => item.act).filter(Boolean)),
) as string[];

const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(withLang(`${base}/events`, lang), origin).toString();
const pageTitle = isEn
  ? "Event Library | Slay the Spire 2 Database"
  : "事件库 | 杀戮尖塔2 中文资料库";
const pageDescription = isEn
  ? `All Slay the Spire 2 events (${events.length} total), with act/type filters and search.`
  : `收录杀戮尖塔2全部事件，共 ${events.length} 个。支持章节、类型筛选与搜索。`;

const t = {
  navLabel: isEn ? "Events" : "事件",
  title: isEn ? "Event Compendium" : "事件图鉴",
  count: isEn ? `${events.length} events` : `共 ${events.length} 个事件`,
  act: isEn ? "Act" : "章节",
  type: isEn ? "Type" : "类型",
  search: isEn ? "Search" : "搜索",
  selectAll: isEn ? "All" : "全选",
  reset: isEn ? "Reset" : "重置",
  filters: isEn ? "Filters" : "筛选",
  expand: isEn ? "Expand" : "展开",
  collapse: isEn ? "Collapse" : "收起",
  searchPlaceholder: isEn ? "Name / Description / Option" : "名称 / 描述 / 选项",
  unknown: isEn ? "Unknown" : "未知",
};
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
  </Fragment>
  <main class="px-3 pb-8 pt-10 sm:px-[6vw] sm:pb-10 sm:pt-12" data-base-path={base}>
    <div class="mx-auto flex max-w-[1100px] flex-col gap-4 sm:gap-6">
      <header>
        <div class="flex flex-wrap items-end justify-between gap-3 sm:gap-6">
          <div>
            <div class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]">
              {t.navLabel}
            </div>
            <h1 class="mt-2 text-[26px] font-semibold text-[#fdf0d8]">{t.title}</h1>
            <p class="mt-1 text-[#c4c7d6]">{t.count}</p>
          </div>
          <TopNav current="events" basePath={base} lang={lang} />
        </div>
      </header>

      <section
        class="flex flex-col gap-2 rounded-2xl border border-white/10 bg-[rgba(16,18,26,0.7)] px-3 py-3 sm:gap-3 sm:px-[18px] sm:py-[14px]"
        aria-label="Event filters"
      >
        <div class="mb-1 flex items-center justify-between sm:hidden">
          <div class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">{t.filters}</div>
          <button
            type="button"
            id="event-filter-toggle"
            data-label-expand={t.expand}
            data-label-collapse={t.collapse}
            class="h-8 rounded-[10px] border border-white/20 bg-white/10 px-3 text-[12px] text-[#f7f1df] transition hover:bg-white/20"
            aria-expanded="true"
          >
            {t.collapse}
          </button>
        </div>

        <div id="event-filter-body" class="flex flex-col gap-3">
        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-start sm:gap-3">
          <span class="shrink-0 pt-1 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.act}</span>
          <div class="flex flex-wrap gap-2 sm:flex-1" data-filter-group="act">
            <button
              type="button"
              data-filter-all
              class="rounded-full border border-white/40 bg-white/20 px-3 py-1 text-[12px] text-[#fdf0d8] transition"
              aria-pressed="true"
            >
              {t.selectAll}
            </button>
            {acts.map((act) => (
              <button
                type="button"
                data-filter-value={act}
                class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10"
                aria-pressed="false"
              >
                {act}
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-start sm:gap-3">
          <span class="shrink-0 pt-1 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.type}</span>
          <div class="flex flex-wrap gap-2 sm:flex-1" data-filter-group="type">
            <button
              type="button"
              data-filter-all
              class="rounded-full border border-white/40 bg-white/20 px-3 py-1 text-[12px] text-[#fdf0d8] transition"
              aria-pressed="true"
            >
              {t.selectAll}
            </button>
            {types.map((type) => (
              <button
                type="button"
                data-filter-value={type}
                class="rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[12px] text-[#cdd2e3] transition hover:border-white/25 hover:bg-white/10"
                aria-pressed="false"
              >
                {type}
              </button>
            ))}
          </div>
        </div>

        <div class="flex flex-col gap-1.5 text-[13px] text-[#b6bbcc] sm:flex-row sm:items-center sm:gap-3">
          <span class="shrink-0 text-[12px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:w-[74px]">{t.search}</span>
          <div class="flex flex-col gap-2 sm:flex-1 sm:flex-row">
            <input
              id="event-filter-search"
              type="search"
              placeholder={t.searchPlaceholder}
              class="h-9 rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-0 text-[#f4f4f1] placeholder:text-[#6f7486] appearance-none focus:outline-none focus:ring-1 focus:ring-white/20 sm:flex-1"
            />
            <button
              type="button"
              id="event-filter-reset"
              class="h-9 rounded-[10px] border border-white/20 bg-white/15 px-3 text-[#f7f1df] hover:bg-white/20 transition-colors"
            >
              {t.reset}
            </button>
          </div>
        </div>
        </div>
      </section>

      <section class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {events.map((event) => (
          <a
            href={withLang(`${base}/event/${event.id}`, lang)}
            class="event-tile group relative overflow-hidden rounded-[14px] border border-white/10 bg-white/5 p-4 transition hover:border-white/25 hover:bg-white/10"
            data-event="1"
            data-act-raw={event.act ?? ""}
            data-type-raw={event.type ?? ""}
            data-search={[
              getName(event),
              getDesc(event),
              event.options?.map((o) => pickText(lang, o.title_zh, o.title)).join(" ") ?? "",
              event.options?.map((o) => pickText(lang, o.description_zh, o.description)).join(" ") ?? "",
              event.act ?? "",
              event.type ?? "",
            ]
              .join(" ")
              .toLowerCase()}
          >
            <div class="flex items-center justify-between gap-3">
              <div>
                <div class="text-[14px] font-semibold text-[#fdf0d8]">
                  {getName(event)}
                </div>
                <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                  {(event.act ?? t.unknown).toUpperCase()} · {(event.type ?? "").toUpperCase()}
                </div>
              </div>
            </div>
            <div
              class="mt-3 text-[11px] leading-[1.3] text-[#f2e5cd]"
              set:html={formatEventText(getDesc(event))}
            />
          </a>
        ))}
      </section>
    </div>
  </main>
</Layout>

<script>
  const byId = (id: string): HTMLElement | null => document.getElementById(id);
  const filterToggleEl = byId("event-filter-toggle") as HTMLButtonElement | null;
  const filterBodyEl = byId("event-filter-body") as HTMLElement | null;
  const searchEl = byId("event-filter-search") as HTMLInputElement | null;
  const resetEl = byId("event-filter-reset") as HTMLButtonElement | null;
  const groups = Array.from(
    document.querySelectorAll<HTMLElement>("[data-filter-group]"),
  ).map((el) => ({
    el,
    name: el.dataset.filterGroup ?? "",
    values: Array.from(
      el.querySelectorAll<HTMLButtonElement>("[data-filter-value]"),
    )
      .map((btn) => btn.dataset.filterValue ?? "")
      .filter(Boolean),
    selected: new Set<string>(["all"]),
  }));
  const groupMap = new Map(groups.map((group) => [group.name, group]));

  const setupFilterCollapse = (
    toggleEl: HTMLButtonElement | null,
    bodyEl: HTMLElement | null,
  ) => {
    if (!toggleEl || !bodyEl) return;
    const mobileMq = window.matchMedia("(max-width: 639px)");
    let collapsed = mobileMq.matches;
    const render = () => {
      const shouldHide = mobileMq.matches && collapsed;
      bodyEl.classList.toggle("hidden", shouldHide);
      const expandLabel = toggleEl.dataset.labelExpand ?? "展开";
      const collapseLabel = toggleEl.dataset.labelCollapse ?? "收起";
      toggleEl.textContent = shouldHide ? expandLabel : collapseLabel;
      toggleEl.setAttribute("aria-expanded", shouldHide ? "false" : "true");
    };
    render();
    toggleEl.addEventListener("click", () => {
      collapsed = !collapsed;
      render();
    });
    const onMediaChange = () => {
      collapsed = mobileMq.matches;
      render();
    };
    mobileMq.addEventListener("change", onMediaChange);
  };

  setupFilterCollapse(filterToggleEl, filterBodyEl);

  const setBtnActive = (btn: HTMLButtonElement, active: boolean) => {
    btn.setAttribute("aria-pressed", active ? "true" : "false");
    btn.classList.toggle("border-white/40", active);
    btn.classList.toggle("bg-white/20", active);
    btn.classList.toggle("text-[#fdf0d8]", active);
    btn.classList.toggle("border-white/10", !active);
    btn.classList.toggle("bg-white/5", !active);
    btn.classList.toggle("text-[#cdd2e3]", !active);
  };

  const syncGroup = (group: (typeof groups)[number]) => {
    const isAll = group.selected.has("all");
    const allBtn = group.el.querySelector<HTMLButtonElement>("[data-filter-all]");
    if (allBtn) setBtnActive(allBtn, isAll);
    group.el
      .querySelectorAll<HTMLButtonElement>("[data-filter-value]")
      .forEach((btn) => {
        const val = btn.dataset.filterValue ?? "";
        setBtnActive(btn, !isAll && group.selected.has(val));
      });
  };

  const setGroupAll = (group: (typeof groups)[number]) => {
    group.selected = new Set(["all"]);
    syncGroup(group);
  };

  const toggleGroupValue = (group: (typeof groups)[number], value: string) => {
    if (group.selected.has("all")) group.selected.clear();
    if (group.selected.has(value)) group.selected.delete(value);
    else group.selected.add(value);
    if (group.selected.size === 0 || group.selected.size === group.values.length) {
      setGroupAll(group);
      return;
    }
    syncGroup(group);
  };

  const matchesGroup = (name: string, value: string) => {
    const group = groupMap.get(name);
    if (!group) return true;
    return group.selected.has("all") || group.selected.has(value);
  };

  const applyFilters = () => {
    const query = (searchEl?.value ?? "").trim().toLowerCase();

    document.querySelectorAll("[data-event]").forEach((node) => {
      const el = node as HTMLElement;
      const a = el.dataset.actRaw || "";
      const t = el.dataset.typeRaw || "";
      const s = el.dataset.search || "";

      const match =
        matchesGroup("act", a) &&
        matchesGroup("type", t) &&
        (!query || s.includes(query));

      el.style.display = match ? "" : "none";
    });
  };

  groups.forEach((group) => {
    const allBtn = group.el.querySelector<HTMLButtonElement>("[data-filter-all]");
    allBtn?.addEventListener("click", () => {
      setGroupAll(group);
      applyFilters();
    });
    group.el
      .querySelectorAll<HTMLButtonElement>("[data-filter-value]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const value = btn.dataset.filterValue ?? "";
          if (!value) return;
          toggleGroupValue(group, value);
          applyFilters();
        });
      });
    syncGroup(group);
  });
  searchEl?.addEventListener("input", applyFilters);

  resetEl?.addEventListener("click", () => {
    groups.forEach((group) => setGroupAll(group));
    if (searchEl) searchEl.value = "";
    applyFilters();
  });
</script>
