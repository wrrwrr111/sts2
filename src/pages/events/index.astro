---
import Layout from "../../layouts/Layout.astro";
import eventsData from "../../../data/events.json";
import { formatRelicText } from "../../lib/relicText";
import TopNav from "../../components/TopNav.astro";

type EventOption = {
  id: string;
  title?: string | null;
  title_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
};

type EventPage = {
  id: string;
  description?: string | null;
  description_zh?: string | null;
  options?: EventOption[] | null;
};

type EventItem = {
  id: string;
  name: string;
  name_zh?: string | null;
  type?: string | null;
  act?: string | null;
  description?: string | null;
  description_zh?: string | null;
  options?: EventOption[] | null;
  pages?: EventPage[] | null;
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const events = eventsData as EventItem[];

const getName = (event: EventItem) => event.name_zh ?? event.name;
const getDesc = (event: EventItem) => event.description_zh ?? event.description ?? "";

const types = Array.from(
  new Set(events.map((item) => item.type).filter(Boolean)),
) as string[];
const acts = Array.from(
  new Set(events.map((item) => item.act).filter(Boolean)),
) as string[];

const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(`${base}/events`, origin).toString();
const pageTitle = "事件图鉴 | 杀戮尖塔2 中文数据库";
const pageDescription = `收录杀戮尖塔2全部事件，共 ${events.length} 个。支持章节、类型筛选与搜索。`;
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
  </Fragment>
  <main class='min-h-screen px-4 pb-[72px] pt-12 sm:px-[6vw]' data-base-path={base}>
    <div class='mx-auto flex max-w-[1100px] flex-col gap-6'>
      <header>
        <div class='flex items-end justify-between gap-6'>
          <div>
            <div class='text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3]'>
              事件
            </div>
            <h1 class='mt-2 text-[26px] font-semibold text-[#fdf0d8]'>事件图鉴</h1>
            <p class='mt-1 text-[#c4c7d6]'>共 {events.length} 个事件</p>
          </div>
          <TopNav current='events' basePath={base} />
        </div>
      </header>

      <section
        class='grid grid-cols-[repeat(auto-fit,minmax(180px,1fr))] items-end gap-3 rounded-2xl border border-white/10 bg-[rgba(16,18,26,0.7)] px-[18px] py-[14px]'
        aria-label='Event filters'
      >
        <label class='grid gap-1.5 text-[13px] text-[#b6bbcc]'>
          <span>章节</span>
          <select
            id='event-filter-act'
            class='rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20'
          >
            <option value='all' class='bg-[#1a1c24] text-[#f4f4f1]'>全部</option>
            {acts.map((act) => (
              <option value={act} class='bg-[#1a1c24] text-[#f4f4f1]'>
                {act}
              </option>
            ))}
          </select>
        </label>

        <label class='grid gap-1.5 text-[13px] text-[#b6bbcc]'>
          <span>类型</span>
          <select
            id='event-filter-type'
            class='rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] appearance-none cursor-pointer hover:bg-[#252833] focus:outline-none focus:ring-1 focus:ring-white/20'
          >
            <option value='all' class='bg-[#1a1c24] text-[#f4f4f1]'>全部</option>
            {types.map((type) => (
              <option value={type} class='bg-[#1a1c24] text-[#f4f4f1]'>
                {type}
              </option>
            ))}
          </select>
        </label>

        <label class='grid gap-1.5 text-[13px] text-[#b6bbcc]'>
          <span>搜索</span>
          <input
            id='event-filter-search'
            type='search'
            placeholder='名称 / 描述 / 选项'
            class='rounded-[10px] border border-white/10 bg-[#1a1c24] px-2.5 py-2 text-[#f4f4f1] placeholder:text-[#6f7486] appearance-none focus:outline-none focus:ring-1 focus:ring-white/20'
          />
        </label>

        <button
          type='button'
          id='event-filter-reset'
          class='rounded-xl border border-white/20 bg-white/15 px-3.5 py-2.5 text-[#f7f1df] hover:bg-white/20 transition-colors'
        >
          重置
        </button>
      </section>

      <section class='grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3'>
        {events.map((event) => (
          <a
            href={`${base}/event/${event.id}`}
            class='event-tile group relative overflow-hidden rounded-[14px] border border-white/10 bg-white/5 p-4 transition hover:border-white/25 hover:bg-white/10'
            data-event='1'
            data-act-raw={event.act ?? ""}
            data-type-raw={event.type ?? ""}
            data-search={[
              getName(event),
              getDesc(event),
              event.options?.map((o) => o.title_zh ?? o.title ?? "").join(" ") ?? "",
              event.options?.map((o) => o.description_zh ?? o.description ?? "").join(" ") ?? "",
              event.act ?? "",
              event.type ?? "",
            ]
              .join(" ")
              .toLowerCase()}
          >
            <div class='flex items-center justify-between gap-3'>
              <div>
                <div class='text-[14px] font-semibold text-[#fdf0d8]'>
                  {getName(event)}
                </div>
                <div class='mt-1 text-[10px] uppercase tracking-[0.2em] text-[#9ea2b3]'>
                  {(event.act ?? "未知").toUpperCase()} · {(event.type ?? "").toUpperCase()}
                </div>
              </div>
            </div>
            <div
              class='mt-3 text-[11px] leading-[1.3] text-[#f2e5cd]'
              set:html={formatRelicText(getDesc(event), base)}
            />
          </a>
        ))}
      </section>
    </div>
  </main>
</Layout>

<script>
  const byId = (id: string): HTMLElement | null => document.getElementById(id);
  const actEl = byId("event-filter-act") as HTMLSelectElement | null;
  const typeEl = byId("event-filter-type") as HTMLSelectElement | null;
  const searchEl = byId("event-filter-search") as HTMLInputElement | null;
  const resetEl = byId("event-filter-reset") as HTMLButtonElement | null;

  const applyFilters = () => {
    const act = actEl?.value ?? "all";
    const type = typeEl?.value ?? "all";
    const query = (searchEl?.value ?? "").trim().toLowerCase();

    document.querySelectorAll("[data-event]").forEach((node) => {
      const el = node as HTMLElement;
      const a = el.dataset.actRaw || "";
      const t = el.dataset.typeRaw || "";
      const s = el.dataset.search || "";

      const match =
        (act === "all" || a === act) &&
        (type === "all" || t === type) &&
        (!query || s.includes(query));

      el.style.display = match ? "" : "none";
    });
  };

  [actEl, typeEl].forEach((el) => {
    el?.addEventListener("change", applyFilters);
  });
  searchEl?.addEventListener("input", applyFilters);

  resetEl?.addEventListener("click", () => {
    if (actEl) actEl.value = "all";
    if (typeEl) typeEl.value = "all";
    if (searchEl) searchEl.value = "";
    applyFilters();
  });
</script>
