---
import Layout from "../../layouts/Layout.astro";
import potionsData from "../../../data/potions.json";
import { formatRelicText } from "../../lib/relicText";
import TopNav from "../../components/TopNav.astro";

type Potion = {
  id: string;
  name: string;
  name_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
  rarity?: string | null;
  image_url?: string | null;
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const potions = potionsData as Potion[];

export const getStaticPaths = () =>
  (potionsData as Potion[]).map((potion) => ({
    params: { id: potion.id },
  }));

const { id } = Astro.params;
const potion = potions.find(
  (item) => item.id?.toLowerCase() === id?.toLowerCase(),
);

if (!potion) {
  return new Response("Not found", { status: 404 });
}

const displayName = potion.name_zh ?? potion.name ?? potion.id;
const rawDesc = (potion.description_zh ?? potion.description ?? "")
  .replace(/\[\/?[a-zA-Z0-9_]+\]/g, "")
  .replace(/\s+/g, " ")
  .trim();
const pageDescription = [
  rawDesc,
  potion.rarity && `稀有度：${potion.rarity}`,
]
  .filter(Boolean)
  .join(" · ")
  .slice(0, 160);
const pageTitle = `${displayName} | 杀戮尖塔2 药剂图鉴`;
const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(`${base}/potion/${potion.id}`, origin).toString();

const normalizeImageUrl = (url: string | null | undefined) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};
const potionImagePath =
  normalizeImageUrl(potion.image_url ?? null) ??
  `/images/potions/${potion.id.toLowerCase()}.png`;
const ogImage = new URL(`${base}${potionImagePath}`, origin).toString();
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={displayName} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={displayName} />
  </Fragment>
  <main class='px-4 pb-10 pt-12 sm:px-[6vw]' data-base-path={base}>
    <div class='mx-auto flex max-w-[1100px] flex-col gap-6'>
      <div class='flex flex-wrap items-end justify-between gap-6'>
        <div>
          <a
            class='text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3] hover:text-[#f7f1df]'
            href={`${base}/potions`}
          >
            返回药剂
          </a>
          <h1 class='mt-2 text-[26px] font-semibold text-[#fdf0d8]'>
            {displayName}
          </h1>
          <p class='mt-1 text-[#c4c7d6]'>
            {potion.rarity ?? "未知"}
          </p>
        </div>
        <TopNav current='potions' basePath={base} />
      </div>
      <div class='w-full max-w-[720px] rounded-[18px] border border-white/10 bg-white/5 p-6'>
        <div class='flex items-center gap-4'>
          <div class='h-[90px] w-[90px] rounded-[14px] border border-white/10 bg-black/30 p-3'>
            <img
              class='h-full w-full object-contain'
              src={`${base}${potionImagePath}`}
              alt={displayName}
              loading='lazy'
            />
          </div>
          <div class='flex-1'>
            <div class='text-[20px] font-semibold text-[#fdf0d8]'>
              {displayName}
            </div>
            <div class='mt-2 text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]'>
              {(potion.rarity ?? "未知").toUpperCase()}
            </div>
          </div>
        </div>
        <div
          class='mt-4 text-[13px] leading-[1.4] text-[#f2e5cd]'
          set:html={formatRelicText(potion.description_zh ?? potion.description ?? "", base)}
        />
      </div>
    </div>
  </main>
</Layout>
