---
import Layout from "../../layouts/Layout.astro";
import relicsData from "../../../data/relics.json";
import { formatRelicText } from "../../lib/relicText";
import TopNav from "../../components/TopNav.astro";
import { getLangFromUrl, pickText, withLang } from "../../lib/i18n";

type Relic = {
  id: string;
  name: string;
  name_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
  flavor?: string | null;
  flavor_zh?: string | null;
  rarity?: string | null;
  pool?: string | null;
  image_url?: string | null;
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";

const relics = relicsData as Relic[];
export const getStaticPaths = () =>
  (relicsData as Relic[]).map((relic) => ({
    params: { id: relic.id },
  }));

const { id } = Astro.params;
const relic = relics.find(
  (item) => item.id?.toLowerCase() === id?.toLowerCase(),
);

if (!relic) {
  return new Response("Not found", { status: 404 });
}

const displayName = pickText(lang, relic.name_zh, relic.name, relic.id);
const rawDesc = pickText(lang, relic.description_zh, relic.description)
  .replace(/\[\/?[a-zA-Z0-9_]+\]/g, "")
  .replace(/\s+/g, " ")
  .trim();
const cardDescription = [
  rawDesc,
  relic.rarity && `${isEn ? "Rarity" : "稀有度"}: ${relic.rarity}`,
  relic.pool && `${isEn ? "Pool" : "来源"}: ${relic.pool}`,
]
  .filter(Boolean)
  .join(" · ")
  .slice(0, 160);
const pageTitle = `${displayName} - ${isEn ? "Relic" : "遗物"} | ${
  isEn ? "Slay the Spire 2 Database" : "杀戮尖塔2 中文资料库"
}`;
const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(withLang(`${base}/relic/${relic.id}`, lang), origin).toString();

const normalizeImageUrl = (url: string | null | undefined) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};
const relicImagePath =
  normalizeImageUrl(relic.image_url ?? null) ??
  `/images/relics/${relic.id.toLowerCase()}.png`;
const ogImage = new URL(`${base}${relicImagePath}`, origin).toString();

const rarityLabelMap: Record<string, string> = {
  Ancient: isEn ? "Ancient" : "古代",
  Common: isEn ? "Common" : "普通",
  Uncommon: isEn ? "Uncommon" : "罕见",
  Rare: isEn ? "Rare" : "稀有",
  Event: isEn ? "Event" : "事件",
  Starter: isEn ? "Starter" : "初始",
  Shop: isEn ? "Shop" : "商店",
  None: isEn ? "None" : "无",
  Unknown: isEn ? "Unknown" : "未知",
};
const poolLabelMap: Record<string, string> = {
  shared: isEn ? "Shared" : "共享",
};

const rarityLabel = rarityLabelMap[relic.rarity ?? ""] ?? relic.rarity ?? (isEn ? "Unknown" : "未知");
const poolLabel = poolLabelMap[relic.pool ?? ""] ?? relic.pool ?? (isEn ? "Unknown" : "未知");

const t = {
  back: isEn ? "Back to Relics" : "返回遗物",
};
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={cardDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={cardDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={displayName} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={cardDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={displayName} />
  </Fragment>
  <main class="px-4 pb-10 pt-12 sm:px-[6vw]" data-base-path={base}>
    <div class="mx-auto flex max-w-[1100px] flex-col gap-6">
      <div class="flex flex-wrap items-end justify-between gap-6">
        <div>
          <a
            class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3] hover:text-[#f7f1df]"
            href={withLang(`${base}/relics`, lang)}
          >
            {t.back}
          </a>
          <h1 class="mt-2 text-[26px] font-semibold text-[#fdf0d8]">
            {displayName}
          </h1>
          <p class="mt-1 text-[#c4c7d6]">
            {rarityLabel} · {poolLabel}
          </p>
        </div>
        <TopNav current="relics" basePath={base} lang={lang} />
      </div>
      <div class="w-full max-w-[720px] rounded-[18px] border border-white/10 bg-white/5 p-6">
        <div class="flex items-center gap-4">
          <div class="h-[90px] w-[90px] rounded-[14px] border border-white/10 bg-black/30 p-3">
            <img
              class="h-full w-full object-contain"
              src={`${base}${relicImagePath}`}
              alt={displayName}
              loading="lazy"
            />
          </div>
          <div class="flex-1">
            <div class="text-[20px] font-semibold text-[#fdf0d8]">{displayName}</div>
            <div class="mt-2 text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">
              {rarityLabel.toUpperCase()} · {poolLabel.toUpperCase()}
            </div>
          </div>
        </div>
        <div
          class="mt-4 text-[13px] leading-[1.4] text-[#f2e5cd]"
          set:html={formatRelicText(pickText(lang, relic.description_zh, relic.description), base)}
        />
        {(pickText(lang, relic.flavor_zh, relic.flavor)) && (
          <div
            class="mt-4 border-t border-white/10 pt-4 text-[12px] italic text-[#c4bfae]"
            set:html={formatRelicText(pickText(lang, relic.flavor_zh, relic.flavor), base)}
          />
        )}
      </div>
    </div>
  </main>
</Layout>
