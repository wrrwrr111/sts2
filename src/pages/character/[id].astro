---
import Layout from "../../layouts/Layout.astro";
import charactersData from "../../../data/characters.json";
import cardsData from "../../../data/cards.json";
import relicsData from "../../../data/relics.json";
import orbsData from "../../../data/orbs.json";
import eventsData from "../../../data/events.json";
import TopNav from "../../components/TopNav.astro";
import CardView from "../../components/CardView.astro";
import type { Card } from "../../lib/cardModels";
import { formatRelicText } from "../../lib/relicText";
import { getLangFromUrl, pickText, withLang } from "../../lib/i18n";

type Character = {
  id: string;
  name: string;
  name_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
  starting_hp?: number | null;
  starting_gold?: number | null;
  max_energy?: number | null;
  orb_slots?: number | null;
  starting_deck?: string[] | null;
  starting_relics?: string[] | null;
  unlocks_after?: string | null;
  gender?: string | null;
  color?: string | null;
  dialogue_color?: string | null;
  quotes?: Record<string, string> | null;
  quotes_zh?: Record<string, string> | null;
  dialogues?: AncientDialogue[] | null;
  dialogues_zh?: AncientDialogue[] | null;
  image_url?: string | null;
};

type AncientDialogueLine = {
  order: number | string;
  speaker: string;
  text: string;
};

type AncientDialogue = {
  ancient: string;
  ancient_name?: string | null;
  lines?: AncientDialogueLine[] | null;
};

type EventOption = {
  id: string;
  title?: string | null;
  title_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
};

type EventItem = {
  id: string;
  name: string;
  name_zh?: string | null;
  type?: string | null;
  image_url?: string | null;
  epithet?: string | null;
  epithet_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
  options?: EventOption[] | null;
  relics?: string[] | null;
};

type AncientDialogueWithEvent = AncientDialogue & {
  event?: EventItem | null;
};

type Relic = {
  id: string;
  name: string;
  name_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
  image_url?: string | null;
};

type Orb = {
  id: string;
  name: string;
  name_zh?: string | null;
  description?: string | null;
  description_zh?: string | null;
  passive?: number | null;
  evoke?: number | null;
  image_url?: string | null;
};

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const lang = getLangFromUrl(Astro.url);
const isEn = lang === "en";

const characters = charactersData as Character[];
const cards = cardsData as Card[];
const relics = relicsData as Relic[];
const orbs = orbsData as Orb[];
const events = eventsData as EventItem[];

export const getStaticPaths = () =>
  (charactersData as Character[]).map((character) => ({
    params: { id: character.id },
  }));

const { id } = Astro.params;
const character = characters.find(
  (item) => item.id?.toLowerCase() === id?.toLowerCase(),
);
if (!character) {
  return new Response("Not found", { status: 404 });
}

const t = {
  back: isEn ? "Back to Characters" : "返回角色",
  role: isEn ? "Characters" : "角色",
  unknown: isEn ? "Unknown" : "未知",
  noDescription: isEn ? "No description." : "暂无描述。",
  unlockPrefix: isEn ? "Unlock:" : "解锁条件：完成",
  intro: isEn ? "Overview" : "角色介绍",
  startingHp: isEn ? "Starting HP" : "初始生命",
  startingGold: isEn ? "Starting Gold" : "初始金币",
  maxEnergy: isEn ? "Max Energy" : "最大能量",
  orbSlots: isEn ? "Orb Slots" : "充能球位",
  orbs: isEn ? "Orbs" : "充能球",
  passive: isEn ? "Passive" : "被动",
  evoke: isEn ? "Evoke" : "激发",
  startingDeck: isEn ? "Starting Deck" : "起始牌组",
  showUpgrade: isEn ? "Show Upgrade" : "显示升级",
  showBase: isEn ? "Show Base" : "显示基础",
  none: isEn ? "None" : "暂无",
  startingRelics: isEn ? "Starting Relics" : "初始遗物",
  noRelicDesc: isEn ? "No description" : "暂无描述",
  ancients: isEn ? "Ancient Interactions" : "远古者互动",
  ancientQuotes: isEn ? "Character Lines" : "角色台词",
  ancientDialogues: isEn ? "Ancient Dialogues" : "远古对话",
  noAncients: isEn ? "No ancient data yet." : "暂无远古者相关内容。",
  ancientSpeaker: isEn ? "Ancient" : "远古者",
  characterSpeaker: isEn ? "Character" : "角色",
  dialogueLines: isEn ? "lines" : "句",
  expand: isEn ? "Expand" : "展开",
  collapse: isEn ? "Collapse" : "收起",
  ancientEvent: isEn ? "Ancient Event" : "先古事件",
  eventChoices: isEn ? "Choices" : "选项",
  eventOfferings: isEn ? "Offerings" : "供奉遗物",
  noAncientEvent: isEn ? "No event data found." : "未找到对应先古事件数据。",
};

const getName = (item: { name?: string | null; name_zh?: string | null; id: string }) =>
  pickText(lang, item.name_zh, item.name, item.id);

const normalizeImageUrl = (url: string | null | undefined) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};

const characterImage =
  normalizeImageUrl(character.image_url ?? null) ??
  `/images/characters/${character.id.toLowerCase()}.png`;

const normalizeId = (value: string) => value.toLowerCase().replace(/[^a-z0-9]/g, "");
const cardMap = new Map(cards.map((card) => [card.id.toLowerCase(), card]));
const relicMap = new Map(relics.map((relic) => [relic.id.toLowerCase(), relic]));
const cardLooseMap = new Map(cards.map((card) => [normalizeId(card.id), card]));
const relicLooseMap = new Map(relics.map((relic) => [normalizeId(relic.id), relic]));

const findCard = (id: string) =>
  cardMap.get(id.toLowerCase()) ?? cardLooseMap.get(normalizeId(id)) ?? null;
const findRelic = (id: string) =>
  relicMap.get(id.toLowerCase()) ?? relicLooseMap.get(normalizeId(id)) ?? null;

const getCardName = (cardId: string) =>
  getName(findCard(cardId) ?? { id: cardId });
const getRelicName = (relicId: string) =>
  getName(findRelic(relicId) ?? { id: relicId });
const getRelicDesc = (relic: Relic | null) =>
  pickText(lang, relic?.description_zh, relic?.description);
const getRelicImage = (relic: Relic | null) =>
  normalizeImageUrl(relic?.image_url ?? null) ??
  (relic ? `/images/relics/${relic.id.toLowerCase()}.png` : null);
const getEventName = (event: EventItem | null | undefined) =>
  event ? pickText(lang, event.name_zh, event.name, event.id) : null;
const getEventEpithet = (event: EventItem | null | undefined) =>
  event ? pickText(lang, event.epithet_zh, event.epithet) : null;
const getEventDescription = (event: EventItem | null | undefined) =>
  event ? pickText(lang, event.description_zh, event.description) : null;
const getEventOptionTitle = (option: EventOption) =>
  pickText(lang, option.title_zh, option.title, option.id);
const getEventOptionDesc = (option: EventOption) =>
  pickText(lang, option.description_zh, option.description);
const getAncientIcon = (dialogue: AncientDialogueWithEvent) =>
  normalizeImageUrl(dialogue.event?.image_url ?? null);
const stripHtml = (text: string | null | undefined) =>
  (text ?? "").replace(/<[^>]+>/g, "").replace(/\s+/g, " ").trim();

const getDeckCounts = (deck: string[] | null | undefined) => {
  const counts = new Map<string, number>();
  const order: string[] = [];
  for (const id of deck ?? []) {
    if (!counts.has(id)) order.push(id);
    counts.set(id, (counts.get(id) ?? 0) + 1);
  }
  return order.map((value) => ({ id: value, count: counts.get(value) ?? 1 }));
};

const deckCounts = getDeckCounts(character.starting_deck);
const deckCards = (character.starting_deck ?? [])
  .map((cardId) => findCard(cardId))
  .filter((card): card is Card => Boolean(card));
const deckHasUpgrades = deckCards.some((card) => Boolean(card.upgrade));
const startingRelics = character.starting_relics ?? [];
const showOrbs =
  character.id?.toLowerCase() === "defect" || character.color === "blue";
const displayOrbs = showOrbs ? orbs : [];

const quoteLabelMap: Record<string, string> = {
  event_death_prevention: isEn ? "Death Prevention" : "活动保命台词",
  gold_monologue: isEn ? "Gold Monologue" : "金币独白",
  aroma_principle: isEn ? "Aroma Principle" : "香气法则",
  banter_alive: isEn ? "Banter (Alive)" : "存活嘲讽",
  banter_dead: isEn ? "Banter (Dead)" : "死亡嘲讽",
  unlock_text: isEn ? "Unlock Text" : "解锁文本",
  cards_modifier_title: isEn ? "Card Modifier Title" : "卡牌修饰标题",
  cards_modifier_description: isEn
    ? "Card Modifier Description"
    : "卡牌修饰描述",
};

const quoteEntries = Object.entries(
  (isEn ? character.quotes : (character.quotes_zh ?? character.quotes)) ?? {},
)
  .map(([key, value]) => ({
    key,
    label: quoteLabelMap[key] ?? key,
    text: value,
  }))
  .filter((item) => item.text && item.text.trim().length > 0);

const rawAncientDialogues =
  (isEn ? character.dialogues : (character.dialogues_zh ?? character.dialogues)) ??
  [];

const eventById = new Map(events.map((event) => [event.id.toUpperCase(), event]));
const eventByName = new Map(
  events.map((event) => [normalizeId(pickText(lang, event.name_zh, event.name, event.id)), event]),
);

const ancientDialogues: AncientDialogueWithEvent[] = (() => {
  const merged = new Map<string, AncientDialogue>();
  for (const dialogue of rawAncientDialogues) {
    const key = (dialogue.ancient ?? dialogue.ancient_name ?? "").toUpperCase();
    if (!key) continue;
    const existing = merged.get(key);
    if (!existing) {
      merged.set(key, {
        ancient: dialogue.ancient,
        ancient_name: dialogue.ancient_name,
        lines: [...(dialogue.lines ?? [])],
      });
      continue;
    }
    if (!existing.ancient && dialogue.ancient) {
      existing.ancient = dialogue.ancient;
    }
    if (!existing.ancient_name && dialogue.ancient_name) {
      existing.ancient_name = dialogue.ancient_name;
    }
    const seen = new Set(
      (existing.lines ?? []).map((line) => `${line.speaker}::${line.text}`),
    );
    for (const line of dialogue.lines ?? []) {
      const sig = `${line.speaker}::${line.text}`;
      if (seen.has(sig)) continue;
      (existing.lines ??= []).push(line);
      seen.add(sig);
    }
  }
  return Array.from(merged.entries()).map(([key, dialogue]) => {
    const eventFromId = eventById.get(key);
    const eventFromName = eventByName.get(
      normalizeId(dialogue.ancient_name ?? dialogue.ancient ?? ""),
    );
    return {
      ...dialogue,
      event: eventFromId ?? eventFromName ?? null,
    };
  });
})();

const getOrbValues = (orb: Orb) => ({
  passive: orb.passive ?? null,
  evoke: orb.evoke ?? null,
  note: null,
});

const formatOrbDescription = (orb: Orb) => {
  const baseDesc = pickText(lang, orb.description_zh, orb.description);
  const values = getOrbValues(orb);
  let text = baseDesc;
  if (values.passive !== null && values.passive !== undefined) {
    text = text.replace(/\[Passive\]/gi, String(values.passive));
  }
  if (values.evoke !== null && values.evoke !== undefined) {
    text = text.replace(/\[Evoke\]/gi, String(values.evoke));
  }
  return text;
};

const origin =
  Astro.site?.toString().replace(/\/$/, "") ??
  new URL(Astro.request.url).origin;
const canonical = new URL(withLang(`${base}/character/${character.id}`, lang), origin).toString();
const pageTitle = `${getName(character)} - ${isEn ? "Character" : "角色"} | ${
  isEn ? "Slay the Spire 2 Database" : "杀戮尖塔2 中文资料库"
}`;
const rawDesc =
  pickText(lang, character.description_zh, character.description)
    .replace(/\s+/g, " ")
    .trim() || getName(character);
const pageDescription = rawDesc.slice(0, 160);
const ogImage = new URL(`${base}${characterImage}`, origin).toString();

const colorLabel: Record<string, string> = {};
for (const characterItem of characters) {
  if (!characterItem.color) continue;
  colorLabel[characterItem.color] = getName(characterItem);
}
const unlocksAfter = character.unlocks_after
  ? getName(characters.find((c) => c.id === character.unlocks_after) ?? {
      id: character.unlocks_after,
    })
  : null;

const deckCountLabel = isEn
  ? `${deckCounts.reduce((sum, item) => sum + item.count, 0)} cards`
  : `共 ${deckCounts.reduce((sum, item) => sum + item.count, 0)} 张`;
---

<Layout>
  <Fragment slot="head">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={getName(character)} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={getName(character)} />
  </Fragment>
  <main class="px-3 pb-8 pt-10 sm:px-[6vw] sm:pb-10 sm:pt-12" data-base-path={base}>
    <div class="mx-auto flex max-w-[1100px] flex-col gap-4 sm:gap-6">
      <div class="flex flex-wrap items-end justify-between gap-3 sm:gap-6">
        <div>
          <a
            class="text-[12px] uppercase tracking-[0.3em] text-[#9ea2b3] hover:text-[#f7f1df]"
            href={withLang(`${base}/characters`, lang)}
          >
            {t.back}
          </a>
          <h1 class="mt-2 text-[26px] font-semibold text-[#fdf0d8]">
            {getName(character)}
          </h1>
          <p class="mt-1 text-[#c4c7d6]">
            {(character.name ?? character.id).toUpperCase()}
          </p>
        </div>
        <TopNav current="characters" basePath={base} lang={lang} />
      </div>

      <section class="grid gap-6 lg:grid-cols-[320px_1fr]">
        <div class="rounded-[18px] border border-white/10 bg-white/5 p-4 h-fit">
          <div class="rounded-[14px] border border-white/10 bg-black/30 p-3">
            <img
              class="h-[220px] w-full object-contain"
              src={`${base}${characterImage}`}
              alt={getName(character)}
              loading="lazy"
            />
          </div>
          <div class="mt-4 grid gap-2">
            <div class="inline-flex items-center justify-center rounded-full border border-white/10 bg-white/10 px-3 py-1 text-[11px] uppercase tracking-[0.2em] text-[#f2e5cd]">
              {colorLabel[character.color ?? ""] ?? (character.color ?? t.unknown)}
            </div>
            {unlocksAfter && (
              <div class="text-center text-[11px] text-[#9ea2b3]">
                {isEn ? `${t.unlockPrefix} ${unlocksAfter}` : `${t.unlockPrefix} ${unlocksAfter}`}
              </div>
            )}
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <div class="rounded-[18px] border border-white/10 bg-white/5 p-4">
            <h2 class="text-[14px] font-semibold text-[#fdf0d8]">{t.intro}</h2>
            <p class="mt-2 whitespace-pre-line text-[12px] leading-[1.5] text-[#f2e5cd]">
              {pickText(lang, character.description_zh, character.description) || t.noDescription}
            </p>
          </div>

          <div class="grid gap-3 sm:grid-cols-2">
            <div class="rounded-[16px] border border-white/10 bg-white/5 p-4">
              <div class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                {t.startingHp}
              </div>
              <div class="mt-1 text-[18px] font-semibold text-[#fdf0d8]">
                {character.starting_hp ?? "—"}
              </div>
            </div>
            <div class="rounded-[16px] border border-white/10 bg-white/5 p-4">
              <div class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                {t.startingGold}
              </div>
              <div class="mt-1 text-[18px] font-semibold text-[#fdf0d8]">
                {character.starting_gold ?? "—"}
              </div>
            </div>
            <div class="rounded-[16px] border border-white/10 bg-white/5 p-4">
              <div class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                {t.maxEnergy}
              </div>
              <div class="mt-1 text-[18px] font-semibold text-[#fdf0d8]">
                {character.max_energy ?? "—"}
              </div>
            </div>
            {character.orb_slots !== null && character.orb_slots !== undefined && (
              <div class="rounded-[16px] border border-white/10 bg-white/5 p-4">
                <div class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                  {t.orbSlots}
                </div>
                <div class="mt-1 text-[18px] font-semibold text-[#fdf0d8]">
                  {character.orb_slots}
                </div>
              </div>
            )}
          </div>

          <div class="rounded-[18px] border border-white/10 bg-white/5 p-4">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <h2 class="text-[14px] font-semibold text-[#fdf0d8]">{t.startingDeck}</h2>
              <div class="flex flex-wrap items-center gap-3">
                {deckCounts.length > 0 && (
                  <div class="text-[11px] text-[#9ea2b3]">{deckCountLabel}</div>
                )}
                {deckHasUpgrades && (
                  <button
                    type="button"
                    id="deck-toggle-upgrade"
                    data-label-upgrade={t.showUpgrade}
                    data-label-base={t.showBase}
                    class="rounded-full border border-white/15 bg-white/10 px-3 py-1 text-[11px] text-[#f2e5cd] hover:border-white/30 hover:bg-white/15"
                  >
                    {t.showUpgrade}
                  </button>
                )}
              </div>
            </div>
            {deckCards.length > 0 ? (
              <div
                class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-4"
                data-deck-cards
              >
                {deckCards.map((card) => (
                  <div
                    class="flex justify-center"
                    data-card-entry
                    data-has-upgrade={card.upgrade ? "1" : "0"}
                  >
                    <a
                      href={withLang(`${base}/card/${card.id}`, lang)}
                      aria-label={getCardName(card.id)}
                    >
                      <div class="origin-top-left scale-[0.85]">
                        <div data-card-variant="base">
                          <CardView card={card} variant="base" lang={lang} />
                        </div>
                        {card.upgrade && (
                          <div data-card-variant="upgrade" class="hidden">
                            <CardView card={card} variant="upgrade" lang={lang} />
                          </div>
                        )}
                      </div>
                    </a>
                  </div>
                ))}
              </div>
            ) : (
              <div class="mt-3 text-[11px] text-[#9ea2b3]">{t.none}</div>
            )}
          </div>

          <div class="rounded-[18px] border border-white/10 bg-white/5 p-4">
            <h2 class="text-[14px] font-semibold text-[#fdf0d8]">{t.startingRelics}</h2>
            {startingRelics.length > 0 ? (
              <div class="mt-4 grid gap-3 sm:grid-cols-2">
                {startingRelics.map((relicId) => {
                  const relic = findRelic(relicId);
                  const relicImage = getRelicImage(relic);
                  return (
                    <a
                      class="group flex gap-3 rounded-[14px] border border-white/10 bg-white/5 p-3 transition hover:border-white/25 hover:bg-white/10"
                      href={withLang(`${base}/relic/${relicId}`, lang)}
                    >
                      <div class="h-[56px] w-[56px] rounded-[10px] border border-white/10 bg-black/30 p-2">
                        {relicImage ? (
                          <img
                            class="h-full w-full object-contain"
                            src={`${base}${relicImage}`}
                            alt={getRelicName(relicId)}
                            loading="lazy"
                          />
                        ) : (
                          <div class="flex h-full w-full items-center justify-center text-[10px] text-white/40">
                            —
                          </div>
                        )}
                      </div>
                      <div class="min-w-0 flex-1">
                        <div class="text-[13px] font-semibold text-[#fdf0d8]">
                          {getRelicName(relicId)}
                        </div>
                        {relic ? (
                          <div
                            class="mt-1 text-[11px] leading-[1.35] text-[#f2e5cd]"
                            set:html={formatRelicText(getRelicDesc(relic), base)}
                          />
                        ) : (
                          <div class="mt-1 text-[11px] text-[#9ea2b3]">{t.noRelicDesc}</div>
                        )}
                      </div>
                    </a>
                  );
                })}
              </div>
            ) : (
              <div class="mt-3 text-[11px] text-[#9ea2b3]">{t.none}</div>
            )}
          </div>

          {displayOrbs.length > 0 && (
            <div class="rounded-[18px] border border-white/10 bg-white/5 p-4">
              <h2 class="text-[14px] font-semibold text-[#fdf0d8]">{t.orbs}</h2>
              <div class="mt-4 grid gap-3 sm:grid-cols-2">
                {displayOrbs.map((orb) => {
                  const values = getOrbValues(orb);
                  const showValues =
                    values.passive !== null ||
                    values.evoke !== null ||
                    Boolean(values.note);
                  return (
                    <div class="rounded-[14px] border border-white/10 bg-white/5 p-3">
                      <div class="flex items-center gap-3">
                        <div class="h-[44px] w-[44px] rounded-[10px] border border-white/10 bg-black/30 p-1.5">
                          {orb.image_url ? (
                            <img
                              class="h-full w-full object-contain"
                              src={`${base}${orb.image_url}`}
                              alt={pickText(lang, orb.name_zh, orb.name, orb.id)}
                              loading="lazy"
                            />
                          ) : (
                            <div class="flex h-full w-full items-center justify-center text-[10px] text-white/40">
                              —
                            </div>
                          )}
                        </div>
                        <div class="min-w-0 flex-1">
                          <div class="text-[13px] font-semibold text-[#fdf0d8]">
                            {pickText(lang, orb.name_zh, orb.name, orb.id)}
                          </div>
                          {showValues && (
                            <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                              {t.passive} {values.passive ?? "?"}
                              <span class="mx-1">/</span>
                              {t.evoke} {values.evoke ?? "?"}
                              {values.note && (
                                <span class="ml-2 text-[#b7bccb]">
                                  {values.note}
                                </span>
                              )}
                            </div>
                          )}
                        </div>
                      </div>
                      {showValues && (
                        <div class="mt-1 text-[10px] uppercase tracking-[0.2em] text-[#9ea2b3] sm:hidden">
                          {t.passive} {values.passive ?? "?"}
                          <span class="mx-1">/</span>
                          {t.evoke} {values.evoke ?? "?"}
                          {values.note && (
                            <span class="ml-2 text-[#b7bccb]">
                              {values.note}
                            </span>
                          )}
                        </div>
                      )}
                      <div
                        class="mt-2 text-[11px] leading-[1.35] text-[#f2e5cd]"
                        set:html={formatRelicText(formatOrbDescription(orb), base)}
                      />
                    </div>
                  );
                })}
              </div>
            </div>
          )}
          
          <div class="rounded-[18px] border border-white/10 bg-white/5 p-4">
            <h2 class="text-[14px] font-semibold text-[#fdf0d8]">{t.ancients}</h2>
            {quoteEntries.length > 0 && (
              <div class="mt-3">
                <h3 class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                  {t.ancientQuotes}
                </h3>
                <div class="mt-2 grid gap-2 sm:grid-cols-2">
                  {quoteEntries.map((quote) => (
                    <div class="rounded-[12px] border border-white/10 bg-white/5 p-3">
                      <div class="text-[10px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                        {quote.label}
                      </div>
                      <p
                        class="mt-1 text-[12px] leading-[1.45] text-[#f2e5cd]"
                        set:html={formatRelicText(quote.text, base)}
                      />
                    </div>
                  ))}
                </div>
              </div>
            )}

            {ancientDialogues.length > 0 && (
              <div class="mt-4">
                <h3 class="text-[11px] uppercase tracking-[0.2em] text-[#9ea2b3]">
                  {t.ancientDialogues}
                </h3>
                <div class="mt-2 grid gap-2">
                  {ancientDialogues.map((dialogue, idx) => (
                    <div class="rounded-[12px] border border-white/10 bg-white/5 p-3">
                      {(() => {
                        const icon = getAncientIcon(dialogue);
                        return (
                      <button
                        type="button"
                        class="flex w-full items-center justify-between gap-2 text-left"
                        data-ancient-toggle
                        data-target={`ancient-panel-${idx}`}
                        data-label-expand={t.expand}
                        data-label-collapse={t.collapse}
                        aria-expanded="false"
                      >
                        <div class="flex min-w-0 items-center gap-2">
                          <div class="h-[32px] w-[32px] shrink-0 overflow-hidden rounded-[8px] border border-white/10 bg-black/30">
                            {icon ? (
                              <img
                                class="h-full w-full object-cover"
                                src={`${base}${icon}`}
                                alt={dialogue.ancient_name ?? dialogue.ancient}
                                loading="lazy"
                              />
                            ) : (
                              <div class="flex h-full w-full items-center justify-center text-[10px] text-white/40">
                                {(dialogue.ancient_name ?? dialogue.ancient).slice(0, 1).toUpperCase()}
                              </div>
                            )}
                          </div>
                          <div class="min-w-0">
                            <span class="text-[12px] font-semibold text-[#fdf0d8]">
                              {dialogue.ancient_name ?? dialogue.ancient}
                            </span>
                            <span class="ml-2 text-[10px] font-normal uppercase tracking-[0.16em] text-[#9ea2b3]">
                              {(dialogue.lines ?? []).length} {t.dialogueLines}
                            </span>
                          </div>
                        </div>
                        <span
                          data-ancient-toggle-label
                          class="text-[10px] uppercase tracking-[0.16em] text-[#9ea2b3]"
                        >
                          {t.expand}
                        </span>
                      </button>
                        );
                      })()}
                      <div id={`ancient-panel-${idx}`} class="mt-2 hidden">
                        {(dialogue.lines ?? []).map((line) => (
                          <div class="mt-2 rounded-[10px] border border-white/10 bg-black/20 p-2">
                            <div class="text-[10px] uppercase tracking-[0.16em] text-[#9ea2b3]">
                              {line.speaker === "ancient"
                                ? t.ancientSpeaker
                                : t.characterSpeaker}
                            </div>
                            <p
                              class="mt-1 text-[12px] leading-[1.45] text-[#f2e5cd]"
                              set:html={formatRelicText(line.text, base)}
                            />
                          </div>
                        ))}
                        {dialogue.event ? (
                          <div class="mt-3 rounded-[10px] border border-white/10 bg-black/20 p-3">
                            <div class="text-[10px] uppercase tracking-[0.18em] text-[#9ea2b3]">
                              {t.ancientEvent}
                            </div>
                            <div class="mt-1 text-[12px] font-semibold text-[#fdf0d8]">
                              {getEventName(dialogue.event)}
                            </div>
                            {getEventEpithet(dialogue.event) && (
                              <div class="mt-1 text-[11px] text-[#b8bdd0]">
                                {getEventEpithet(dialogue.event)}
                              </div>
                            )}
                            {getEventDescription(dialogue.event) && (
                              <div
                                class="mt-2 text-[12px] leading-[1.45] text-[#f2e5cd]"
                                set:html={formatRelicText(getEventDescription(dialogue.event), base)}
                              />
                            )}
                            {(dialogue.event.options?.length ?? 0) > 0 && (
                              <div class="mt-3">
                                <div class="text-[10px] uppercase tracking-[0.16em] text-[#9ea2b3]">
                                  {t.eventChoices}
                                </div>
                                <div class="mt-1 grid gap-1.5">
                                  {(dialogue.event.options ?? []).map((option) => (
                                    <div class="rounded-[8px] border border-white/10 bg-white/5 px-2 py-1.5">
                                      <div class="text-[11px] font-semibold text-[#f2e5cd]">
                                        {getEventOptionTitle(option)}
                                      </div>
                                      {getEventOptionDesc(option) && (
                                        <div
                                          class="mt-0.5 text-[11px] text-[#cfd3e2]"
                                          set:html={formatRelicText(getEventOptionDesc(option), base)}
                                        />
                                      )}
                                    </div>
                                  ))}
                                </div>
                              </div>
                            )}
                            {(dialogue.event.relics?.length ?? 0) > 0 && (
                              <div class="mt-3">
                                <div class="text-[10px] uppercase tracking-[0.16em] text-[#9ea2b3]">
                                  {t.eventOfferings}
                                </div>
                                <div class="mt-1 flex flex-wrap gap-1.5">
                                  {(dialogue.event.relics ?? []).map((relicId, relicIdx) => {
                                    const relic = findRelic(relicId);
                                    const relicName = getRelicName(relicId);
                                    const relicImage = getRelicImage(relic);
                                    const relicDescHtml = relic
                                      ? formatRelicText(getRelicDesc(relic), base)
                                      : "";
                                    const popoverId = `offering-${idx}-${relicIdx}`;
                                    return (
                                      <div class="relative">
                                        <button
                                          type="button"
                                          class="rounded-full border border-white/15 bg-white/10 px-2 py-0.5 text-[10px] text-[#f2e5cd] transition hover:border-white/30 hover:bg-white/20"
                                          data-offering-trigger
                                          data-popover-id={popoverId}
                                          aria-expanded="false"
                                          title={stripHtml(relicDescHtml) || relicName}
                                        >
                                          {relicName}
                                        </button>
                                        <template id={popoverId}>
                                          <div class="w-[260px] rounded-[12px] border border-white/15 bg-[#10141f] p-3 shadow-[0_16px_36px_rgba(0,0,0,0.45)]">
                                            <div class="flex items-start gap-2.5">
                                              <div class="h-[44px] w-[44px] shrink-0 rounded-[10px] border border-white/10 bg-black/30 p-1.5">
                                                {relicImage ? (
                                                  <img
                                                    class="h-full w-full object-contain"
                                                    src={`${base}${relicImage}`}
                                                    alt={relicName}
                                                    loading="lazy"
                                                  />
                                                ) : (
                                                  <div class="flex h-full w-full items-center justify-center text-[10px] text-white/40">
                                                    —
                                                  </div>
                                                )}
                                              </div>
                                              <div class="min-w-0 flex-1">
                                                <div class="text-[12px] font-semibold text-[#fdf0d8]">
                                                  {relicName}
                                                </div>
                                                {relic ? (
                                                  <div
                                                    class="mt-1 text-[11px] leading-[1.35] text-[#f2e5cd]"
                                                    set:html={relicDescHtml}
                                                  />
                                                ) : (
                                                  <div class="mt-1 text-[11px] text-[#9ea2b3]">
                                                    {t.noRelicDesc}
                                                  </div>
                                                )}
                                              </div>
                                            </div>
                                          </div>
                                        </template>
                                      </div>
                                    );
                                  })}
                                </div>
                              </div>
                            )}
                          </div>
                        ) : (
                          <div class="mt-3 text-[11px] text-[#9ea2b3]">
                            {t.noAncientEvent}
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            {quoteEntries.length === 0 && ancientDialogues.length === 0 && (
              <div class="mt-2 text-[11px] text-[#9ea2b3]">{t.noAncients}</div>
            )}
          </div>
        </div>
      </section>
    </div>
  </main>
  <div
    id="offering-popover"
    class="fixed left-0 top-0 z-[80] hidden"
    style="pointer-events: none;"
  >
    <div data-offering-popover-content></div>
  </div>
</Layout>

<script>
  import { autoUpdate, computePosition, flip, offset, shift } from "@floating-ui/dom";

  const toggle = document.getElementById("deck-toggle-upgrade") as
    | HTMLButtonElement
    | null;
  const deck = document.querySelector("[data-deck-cards]");

  if (toggle && deck) {
    const setState = (showUpgrade: boolean) => {
      deck.setAttribute("data-show-upgrade", showUpgrade ? "1" : "0");
      const labelBase = toggle.getAttribute("data-label-base") ?? "显示基础";
      const labelUpgrade =
        toggle.getAttribute("data-label-upgrade") ?? "显示升级";
      toggle.textContent = showUpgrade ? labelBase : labelUpgrade;

      deck.querySelectorAll("[data-card-entry]").forEach((entry) => {
        const hasUpgrade = entry.getAttribute("data-has-upgrade") === "1";
        if (!hasUpgrade) return;

        const baseEl = entry.querySelector("[data-card-variant='base']");
        const upgradeEl = entry.querySelector("[data-card-variant='upgrade']");
        if (showUpgrade) {
          baseEl?.classList.add("hidden");
          upgradeEl?.classList.remove("hidden");
        } else {
          baseEl?.classList.remove("hidden");
          upgradeEl?.classList.add("hidden");
        }
      });
    };

    let showingUpgrade = false;
    toggle.addEventListener("click", () => {
      showingUpgrade = !showingUpgrade;
      setState(showingUpgrade);
    });
  }

  document.querySelectorAll<HTMLButtonElement>("[data-ancient-toggle]").forEach((btn) => {
    const targetId = btn.getAttribute("data-target");
    if (!targetId) return;
    const panel = document.getElementById(targetId);
    const stateEl = btn.querySelector<HTMLElement>("[data-ancient-toggle-label]");
    const expandLabel = btn.getAttribute("data-label-expand") ?? "展开";
    const collapseLabel = btn.getAttribute("data-label-collapse") ?? "收起";
    if (!panel || !stateEl) return;

    btn.addEventListener("click", () => {
      const isOpen = !panel.classList.contains("hidden");
      if (isOpen) {
        panel.classList.add("hidden");
        btn.setAttribute("aria-expanded", "false");
        stateEl.textContent = expandLabel;
      } else {
        panel.classList.remove("hidden");
        btn.setAttribute("aria-expanded", "true");
        stateEl.textContent = collapseLabel;
      }
    });
  });

  const offeringPopover = document.getElementById("offering-popover") as
    | HTMLDivElement
    | null;
  const offeringContent = offeringPopover?.querySelector(
    "[data-offering-popover-content]",
  ) as HTMLDivElement | null;
  const offeringTriggers = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-offering-trigger]"),
  );

  if (offeringPopover && offeringContent && offeringTriggers.length > 0) {
    let cleanupAutoUpdate: (() => void) | null = null;
    let activeTrigger: HTMLButtonElement | null = null;
    let pinned = false;
    let closeTimer: number | null = null;
    let pointerInsidePopover = false;

    const clearCloseTimer = () => {
      if (closeTimer !== null) {
        window.clearTimeout(closeTimer);
        closeTimer = null;
      }
    };

    const setTriggerExpanded = (trigger: HTMLButtonElement | null, open: boolean) => {
      if (!trigger) return;
      trigger.setAttribute("aria-expanded", open ? "true" : "false");
    };

    const closePopover = () => {
      clearCloseTimer();
      cleanupAutoUpdate?.();
      cleanupAutoUpdate = null;
      setTriggerExpanded(activeTrigger, false);
      activeTrigger = null;
      pinned = false;
      pointerInsidePopover = false;
      offeringPopover.classList.add("hidden");
      offeringPopover.style.pointerEvents = "none";
    };

    const updatePosition = async (trigger: HTMLButtonElement) => {
      try {
        const { x, y } = await computePosition(trigger, offeringPopover, {
          strategy: "fixed",
          placement: "top",
          middleware: [offset(10), flip({ padding: 8 }), shift({ padding: 8 })],
        });
        if (!Number.isFinite(x) || !Number.isFinite(y)) {
          throw new Error("Invalid floating position");
        }
        offeringPopover.style.left = `${x}px`;
        offeringPopover.style.top = `${y}px`;
      } catch {
        const rect = trigger.getBoundingClientRect();
        offeringPopover.style.left = `${Math.max(8, rect.left)}px`;
        offeringPopover.style.top = `${Math.max(8, rect.bottom + 8)}px`;
      }
    };

    const openPopover = (trigger: HTMLButtonElement, pin: boolean) => {
      const templateId = trigger.getAttribute("data-popover-id");
      if (!templateId) return;
      const template = document.getElementById(templateId) as HTMLTemplateElement | null;
      if (!template) return;

      clearCloseTimer();
      if (activeTrigger && activeTrigger !== trigger) {
        setTriggerExpanded(activeTrigger, false);
      }

      activeTrigger = trigger;
      pinned = pin;
      pointerInsidePopover = false;
      offeringContent.innerHTML = template.innerHTML;
      offeringPopover.classList.remove("hidden");
      offeringPopover.style.pointerEvents = "auto";
      setTriggerExpanded(trigger, true);
      const rect = trigger.getBoundingClientRect();
      offeringPopover.style.left = `${rect.left}px`;
      offeringPopover.style.top = `${rect.bottom + 8}px`;

      cleanupAutoUpdate?.();
      cleanupAutoUpdate = autoUpdate(trigger, offeringPopover, () => {
        void updatePosition(trigger);
      });
      void updatePosition(trigger);
    };

    const scheduleClose = () => {
      clearCloseTimer();
      if (pinned || pointerInsidePopover) return;
      closeTimer = window.setTimeout(() => {
        if (pinned || pointerInsidePopover) return;
        closePopover();
      }, 240);
    };

    for (const trigger of offeringTriggers) {
      trigger.addEventListener("mouseenter", () => {
        openPopover(trigger, false);
      });
      trigger.addEventListener("mouseleave", () => {
        scheduleClose();
      });
      trigger.addEventListener("focus", () => {
        openPopover(trigger, false);
      });
      trigger.addEventListener("blur", () => {
        scheduleClose();
      });
      trigger.addEventListener("click", (event) => {
        event.preventDefault();
        const alreadyPinned =
          activeTrigger === trigger &&
          !offeringPopover.classList.contains("hidden") &&
          pinned;
        if (alreadyPinned) {
          closePopover();
          return;
        }
        openPopover(trigger, true);
      });
    }

    offeringPopover.addEventListener("mouseenter", () => {
      pointerInsidePopover = true;
      clearCloseTimer();
    });
    offeringPopover.addEventListener("mouseleave", () => {
      pointerInsidePopover = false;
      scheduleClose();
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest("[data-offering-trigger]")) return;
      if (offeringPopover.contains(target)) return;
      closePopover();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") {
        closePopover();
      }
    });
  }
</script>
