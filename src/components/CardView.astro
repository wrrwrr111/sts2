---
import keywordsData from "../../data/keywords.json";
import cardsData from "../../data/cards.json";
import type { Card, Keyword } from "../lib/cardModels";
import { TYPE_ZH } from "../lib/cardModels";
import type { Lang } from "../lib/i18n";
import { pickText } from "../lib/i18n";

type Props = {
  card: Card;
  variant?: "auto" | "base" | "upgrade";
  lang?: Lang;
  enableSpawnPreview?: boolean;
};

const getDisplayDesc = (card: Card, lang: Lang) =>
  pickText(lang, card.description_zh, card.description);

const getDisplayDescUpgraded = (card: Card, lang: Lang) =>
  pickText(
    lang,
    card.description_upgraded_zh,
    card.description_upgraded,
    getDisplayDesc(card, lang),
  );

const rawProps = (Astro.props ?? null) as Partial<Props> | null;
const card = rawProps?.card;
if (!card) {
  throw new Error("CardView requires a card prop");
}
const variant = rawProps?.variant ?? "auto";
const lang = rawProps?.lang ?? "zh";
const enableSpawnPreview = rawProps?.enableSpawnPreview ?? false;
const isEn = lang === "en";
const showBaseLayer = variant !== "upgrade";

const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");

const keywords = keywordsData as Keyword[];
const allCards = cardsData as Card[];
const normalizeCardId = (value: string) =>
  value.toLowerCase().replace(/[^a-z0-9]/g, "");
const cardMap = new Map(allCards.map((item) => [item.id.toLowerCase(), item]));
const cardLooseMap = new Map(
  allCards.map((item) => [normalizeCardId(item.id), item]),
);
const findCard = (id: string) =>
  cardMap.get(id.toLowerCase()) ?? cardLooseMap.get(normalizeCardId(id)) ?? null;

const keywordMap = new Map<
  string,
  {
    name: string;
    name_zh: string | null;
    description: string;
    description_zh: string | null;
  }
>();
for (const k of keywords) {
  keywordMap.set(k.name.toLowerCase(), k);
  if (k.name_zh) keywordMap.set(k.name_zh.toLowerCase(), k);
}

const keywordLabel = (kw: string) => {
  const hit = keywordMap.get(kw.toLowerCase());
  if (!hit) return kw;
  return isEn ? hit.name ?? hit.name_zh ?? kw : hit.name_zh ?? hit.name ?? kw;
};

const escapeHtml = (value: string) =>
  value.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");

const escapeAttr = (value: string) =>
  value
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");

const openTag = (tag: string) => {
  const t = tag.toLowerCase();
  if (t === "b") return '<strong class="inline-block">';
  if (t === "i") return '<em class="inline-block">';
  if (t === "u") return '<span class="inline-block underline">';
  if (t === "gold") return '<span class="inline-block text-[#ffd38c]">';
  if (t === "red") return '<span class="inline-block text-[#ff7b7b]">';
  if (t === "blue") return '<span class="inline-block text-[#7fb8ff]">';
  if (t === "green") return '<span class="inline-block text-[#86e3a0]">';
  if (t === "purple") return '<span class="inline-block text-[#b89bff]">';
  if (t === "orange") return '<span class="inline-block text-[#ffb46a]">';
  if (t === "aqua") return '<span class="inline-block text-[#7fe3ff]">';
  if (t === "pink") return '<span class="inline-block text-[#ff9bd0]">';
  if (t === "rainbow") {
    return '<span class="inline-block text-transparent [background:linear-gradient(90deg,#ff6b6b,#ffd93d,#6bffb6,#6bc7ff,#b56bff)] [-webkit-background-clip:text]">';
  }
  if (t === "amount")
    return '<span class="inline-block text-[#ffe6b0] font-semibold">';
  if (t === "passive" || t === "evoke")
    return '<span class="inline-block text-[#bfe5ff] uppercase tracking-[0.08em] text-[0.85em]">';
  if (t === "sine") return '<span class="inline-block animate-bounce">';
  if (t === "jitter") return '<span class="inline-block animate-pulse">';
  return '<span class="inline-block">';
};

const closeTag = (tag: string) => {
  const t = tag.toLowerCase();
  if (t === "b") return "</strong>";
  if (t === "i") return "</em>";
  if (t === "u") return "</span>";
  return "</span>";
};

const openTagWithTitle = (tag: string, innerText: string) => {
  const t = tag.toLowerCase();
  const key = innerText.trim().toLowerCase();
  const tipHtml = keywordTipHtmlMap.get(key) ?? "";
  if (!tipHtml) {
    return openTag(tag);
  }
  const tipAttr = ` data-tip-html="${escapeAttr(tipHtml)}" class="inline-block relative cursor-help"`;
  if (t === "b") return `<strong${tipAttr}>`;
  if (t === "i") return `<em${tipAttr}>`;
  if (t === "u")
    return `<span class="inline-block underline relative cursor-help" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "gold")
    return `<span class="inline-block relative cursor-help text-[#ffd38c]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "red")
    return `<span class="inline-block relative cursor-help text-[#ff7b7b]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "blue")
    return `<span class="inline-block relative cursor-help text-[#7fb8ff]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "green")
    return `<span class="inline-block relative cursor-help text-[#86e3a0]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "purple")
    return `<span class="inline-block relative cursor-help text-[#b89bff]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "orange")
    return `<span class="inline-block relative cursor-help text-[#ffb46a]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "aqua")
    return `<span class="inline-block relative cursor-help text-[#7fe3ff]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "pink")
    return `<span class="inline-block relative cursor-help text-[#ff9bd0]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "rainbow") {
    return `<span class="inline-block relative cursor-help text-transparent [background:linear-gradient(90deg,#ff6b6b,#ffd93d,#6bffb6,#6bc7ff,#b56bff)] [-webkit-background-clip:text]" data-tip-html="${escapeAttr(tipHtml)}">`;
  }
  if (t === "amount")
    return `<span class="inline-block relative cursor-help text-[#ffe6b0] font-semibold" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "passive" || t === "evoke")
    return `<span class="inline-block relative cursor-help text-[#bfe5ff] uppercase tracking-[0.08em] text-[0.85em]" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "sine")
    return `<span class="inline-block relative cursor-help animate-bounce" data-tip-html="${escapeAttr(tipHtml)}">`;
  if (t === "jitter")
    return `<span class="inline-block relative cursor-help animate-pulse" data-tip-html="${escapeAttr(tipHtml)}">`;
  return `<span class="inline-block relative cursor-help" data-tip-html="${escapeAttr(tipHtml)}">`;
};

const energyIconForColor = (color: string | null) => {
  const c = color ?? "colorless";
  if (c === "silent") return "energy_silent";
  if (c === "ironclad") return "energy_ironclad";
  if (c === "defect") return "energy_defect";
  if (c === "necrobinder") return "energy_necrobinder";
  if (c === "regent") return "energy_regent";
  if (c === "quest") return "energy_quest";
  return "energy_colorless";
};

const highlightNumbersInHtml = (html: string, highlightValues: Set<string>) =>
  html
    .split(/(<[^>]+>)/g)
    .map((part) => {
      if (part.startsWith("<")) return part;
      return part.replace(/\d+(?:\.\d+)?/g, (match) =>
        highlightValues.has(match)
          ? `<span style="color:#7efe00">${match}</span>`
          : match,
      );
    })
    .join("");

const extractVarNames = (raw: string | null) => {
  const names = new Set<string>();
  if (!raw) return names;
  for (const match of raw.matchAll(/\{([^}:]+)(?::[^}]*)?\}/g)) {
    if (match[1]) names.add(match[1].toLowerCase());
  }
  return names;
};

const parseUpgradeDelta = (value: string) => {
  const trimmed = value.trim();
  if (!trimmed) return null;
  const op = trimmed[0];
  const num = Number(trimmed.slice(1));
  if (!Number.isFinite(num)) return null;
  if (op === "+" || op === "-")
    return { type: "delta", value: op === "-" ? -num : num };
  if (op === "*") return { type: "mul", value: num };
  return null;
};

const formatNumber = (value: number) => {
  if (Number.isInteger(value)) return String(value);
  return String(Number(value.toFixed(3))).replace(/\.0+$/, "");
};

const getVarValue = (varName: string, upgraded: boolean) => {
  const baseValue = card.vars?.[varName];
  if (typeof baseValue !== "number") return null;
  if (!upgraded) return baseValue;

  const upgradeRaw = card.upgrade?.[varName];
  if (typeof upgradeRaw !== "string") return baseValue;
  const delta = parseUpgradeDelta(upgradeRaw);
  if (!delta) return baseValue;
  return delta.type === "delta"
    ? baseValue + delta.value
    : baseValue * delta.value;
};

const resolveRawCardDescription = (raw: string | null, upgraded: boolean) => {
  if (!raw) return "";
  let text = raw;
  for (let i = 0; i < 4; i++) {
    const next = text.replace(
      /\{IfUpgraded:show:([^{}|]*)\|([^{}]*)\}/g,
      (_, upText, baseText) => (upgraded ? upText : baseText),
    );
    if (next === text) break;
    text = next;
  }

  text = text.replace(/\{([A-Za-z0-9_]+):diff\(\)\}/g, (_, varName) => {
    const value = getVarValue(varName, upgraded);
    return value === null ? `{${varName}:diff()}` : formatNumber(value);
  });

  text = text.replace(
    /\{([A-Za-z0-9_]+):plural:([^{}|]*)\|([^{}]*)\}/g,
    (_, varName, single, plural) => {
      const value = getVarValue(varName, upgraded);
      if (value === null) return single;
      return Math.abs(value) > 1 ? plural : single;
    },
  );

  text = text.replace(/\{([A-Za-z0-9_]+)\}/g, (_, varName) => {
    const value = getVarValue(varName, upgraded);
    return value === null ? `{${varName}}` : formatNumber(value);
  });
  return text;
};

const formatDescription = (
  desc: string | null,
  color: string | null,
  options: { tooltips?: boolean; highlightValues?: Set<string> } = {},
) => {
  if (!desc) return "";
  const escaped = escapeHtml(desc);
  const withTooltips = options.tooltips !== false;
  const html = escaped
    .replace(/\[energy:(\d+)\]/gi, (_, raw) => {
      const count = Math.max(0, Math.min(9, Number(raw)));
      const icon = energyIconForColor(color);
      if (!count) return "";
      return `<span class="inline-flex gap-0.5 align-middle">${Array.from({
        length: count,
      })
        .map(
          () =>
            `<img class="inline-block align-text-bottom" style="height:1em;width:1em;margin-bottom:0.1em;filter:drop-shadow(0 1px 1px rgba(0,0,0,0.45));" src="${basePath}/images/ui/${icon}.png" alt="" />`,
        )
        .join("")}</span>`;
    })
    .replace(/\[star:(\d+)\]/gi, (_, raw) => {
      const count = Math.max(0, Math.min(9, Number(raw)));
      if (!count) return "";
  return `<span class="inline-flex gap-0.5 align-middle">${Array.from({
        length: count,
      })
        .map(
          () =>
            `<img class="inline-block align-text-bottom" style="height:1em;width:1em;margin-bottom:0.1em;filter:drop-shadow(0 1px 1px rgba(0,0,0,0.45));" src="${basePath}/images/icons/star_icon.png" alt="" />`,
        )
        .join("")}</span>`;
    })
    .replace(/\[([a-zA-Z0-9_]+)\]([\s\S]*?)\[\/\1\]/g, (_, tag, inner) => {
      const plain = inner.replace(/\[\/?[a-zA-Z0-9_]+\]/g, "");
      return withTooltips
        ? `${openTagWithTitle(tag, plain)}${inner}${closeTag(tag)}`
        : `${openTag(tag)}${inner}${closeTag(tag)}`;
    })
    .replace(/\[([a-zA-Z0-9_]+)\]/g, (_, tag) => openTag(tag))
    .replace(/\[\/([a-zA-Z0-9_]+)\]/g, (_, tag) => closeTag(tag))
    .replace(/\n/g, "<br />");
  if (!options.highlightValues || options.highlightValues.size === 0)
    return html;
  return highlightNumbersInHtml(html, options.highlightValues);
};

const keywordTipHtmlMap = new Map<string, string>();
for (const k of keywords) {
  const desc = pickText(lang, k.description_zh, k.description);
  const html = formatDescription(desc, null, { tooltips: false });
  keywordTipHtmlMap.set(k.name.toLowerCase(), html);
  if (k.name_zh) keywordTipHtmlMap.set(k.name_zh.toLowerCase(), html);
}

const isAncient = card.rarity?.toLowerCase() === "ancient";
const isInfection = card.id?.toLowerCase() === "infection";
const typeLower = card.type?.toLowerCase() ?? "";
const rarityLower = card.rarity?.toLowerCase() ?? "";
const colorLower = card.color?.toLowerCase() ?? "";
const rawDescTemplate = pickText(lang, card.description_raw_zh, card.description_raw);
const rawBaseDesc = resolveRawCardDescription(rawDescTemplate, false);
const rawUpgradeDesc = resolveRawCardDescription(rawDescTemplate, true);
const explicitUpgradeDesc = pickText(
  lang,
  card.description_upgraded_zh,
  card.description_upgraded,
);
const baseDesc = getDisplayDesc(card, lang) || rawBaseDesc;
const upgradedDesc = explicitUpgradeDesc || rawUpgradeDesc || baseDesc;
const hasImplicitUpgrade = rawUpgradeDesc.trim() !== rawBaseDesc.trim();
const hasUpgradeVersion =
  Boolean(card.upgrade) ||
  Boolean(explicitUpgradeDesc && explicitUpgradeDesc !== baseDesc) ||
  hasImplicitUpgrade;
const isUpgradeView = variant === "upgrade" && hasUpgradeVersion;
const showUpgradeLayer = (variant === "auto" || variant === "upgrade") &&
  hasUpgradeVersion;
const rawDescForVars = rawDescTemplate ?? baseDesc;

const normalizeImageUrl = (url: string | null) => {
  if (!url) return null;
  return url.replace("/static/images/", "/images/");
};

const getCardImage = (card: Card) => {
  const normalized =
    normalizeImageUrl(card.image_url) ?? normalizeImageUrl(card.beta_image_url);
  if (normalized) return normalized;
  return `/images/cards/${card.id.toLowerCase()}.png`;
};

const getDisplayName = (card: Card) =>
  pickText(lang, card.name_zh, card.name, card.id);

const getSpawnCardName = (spawnId: string) => {
  const hit = findCard(spawnId);
  return hit ? getDisplayName(hit) : spawnId;
};

const getSpawnCardImage = (spawnId: string) => {
  const hit = findCard(spawnId);
  if (!hit) return `/images/cards/${spawnId.toLowerCase()}.png`;
  return getCardImage(hit);
};

const getCostLabel = (card: Card) => {
  if (card.is_x_cost) return "X";
  if (card.cost !== null) return String(card.cost);
  return "";
};

const getUpgradeCostLabel = (card: Card) => {
  if (!card.upgrade) return "";
  if (typeof card.upgrade.cost !== "number") return "";
  const base = getCostLabel(card);
  const upgraded = String(card.upgrade.cost);
  if (!upgraded || upgraded === base) return "";
  return upgraded;
};

const getCostBucket = (card: Card) => {
  if (card.is_x_cost) return "X";
  if (card.cost === null) return "N";
  if (card.cost >= 4) return "4+";
  return String(card.cost);
};

const getStarLabel = (card: Card) =>
  card.star_cost !== null ? String(card.star_cost) : "";

const getTypeLabel = (card: Card) => {
  if (!card.type) return isEn ? "Unknown" : "未知";
  return isEn ? card.type : TYPE_ZH[card.type] ?? card.type;
};

const frameImageFor = (card: Card) => {
  if (card.rarity?.toLowerCase() === "ancient") return "card_frame_ancient_s";
  const t = card.type?.toLowerCase();
  if (t === "curse" || t === "status") return "card_frame_power_s";
  if (t === "attack") return "card_frame_attack_s";
  if (t === "skill") return "card_frame_skill_s";
  if (t === "power") return "card_frame_power_s";
  if (t === "quest") return "card_frame_quest_s";
  return "card_frame_skill_s";
};

const borderImageFor = (card: Card) => {
  const t = card.type?.toLowerCase();
  if (t === "attack") return "card_portrait_border_attack_s";
  if (t === "skill") return "card_portrait_border_skill_s";
  if (t === "power") return "card_portrait_border_power_s";
  return "card_portrait_border_power_s";
};

const bannerImageFor = (card: Card) =>
  card.rarity?.toLowerCase() === "ancient" ? "ancient_banner" : "card_banner";

const energyImageFor = (card: Card) =>
  energyIconForColor(card.color ?? "colorless");

const frameFilterByColor = {
  ironclad: "hue-rotate(15deg) grayscale(.05) brightness(1.05)",
  silent: "hue-rotate(97deg) brightness(1.5) saturate(.6)",
  defect: "hue-rotate(217deg) brightness(1.3) saturate(.625)",
  necrobinder: "hue-rotate(-23deg) brightness(1.3) saturate(.55)",
  regent: "hue-rotate(45deg) brightness(1.55) saturate(1)",
  colorless: "grayscale() brightness(1.35)",
  curse: "hue-rotate(-60deg) grayscale(.9) brightness(.6)",
  status: "grayscale() brightness(1.35)",
  event: "grayscale() brightness(1.35)",
  token: "grayscale() brightness(1.35)",
};

const frameFilterKey = colorLower as keyof typeof frameFilterByColor;
const frameFilter =
  colorLower === "quest"
    ? ""
    : frameFilterByColor[frameFilterKey] || "grayscale() brightness(1.35)";
const frameStyle = frameFilter ? `filter: ${frameFilter};` : "";

const borderFilterByRarity = {
  rare: "hue-rotate(-145deg) brightness(1.075) saturate(1.9)",
  basic: "hue-rotate(-145deg) grayscale(.9) brightness(.775)",
  common: "hue-rotate(-145deg) grayscale(.9) brightness(.775)",
  curse: "hue-rotate(78deg) brightness(.8) saturate(2.55)",
  event: "hue-rotate(-78deg) brightness(.9) saturate(1.25)",
  quest: "hue-rotate(-172deg) brightness(.8) saturate(2.5)",
  status: "hue-rotate(-122deg) brightness(.8) saturate(.75)",
  token: "hue-rotate(-145deg) grayscale(.9) brightness(.775)",
};

const borderFilterKey = rarityLower as keyof typeof borderFilterByRarity;
const borderFilter = borderFilterByRarity[borderFilterKey] || "";
const frameImage = frameImageFor(card);
const cardImage = `${basePath}${getCardImage(card)}`;
const upgradeCost = getUpgradeCostLabel(card);
const showBaseCost = showBaseLayer || (isUpgradeView && !upgradeCost);
const upgradeHighlights = (() => {
  if (!card.upgrade || !card.vars) return new Set<string>();
  const usedVars = extractVarNames(rawDescForVars);
  const varsMap = new Map(
    Object.keys(card.vars).map((key) => [key.toLowerCase(), key]),
  );
  const highlights = new Set<string>();
  for (const [key, rawVal] of Object.entries(card.upgrade)) {
    if (typeof rawVal !== "string") continue;
    const mappedKey = varsMap.get(key.toLowerCase());
    if (!mappedKey) continue;
    if (!usedVars.has(mappedKey.toLowerCase())) continue;
    const baseVal = card.vars[mappedKey];
    if (typeof baseVal !== "number") continue;
    const delta = parseUpgradeDelta(rawVal);
    if (!delta) continue;
    const next =
      delta.type === "delta" ? baseVal + delta.value : baseVal * delta.value;
    highlights.add(formatNumber(next));
  }
  return highlights;
})();
const baseDescHtml = baseDesc ? formatDescription(baseDesc, card.color) : "";
const upgradeDescHtml =
  hasUpgradeVersion && upgradedDesc
    ? formatDescription(upgradedDesc, card.color, {
        highlightValues: upgradeHighlights,
      })
    : "";
const hasBaseDesc = Boolean(baseDescHtml);
const hasUpgradeDesc = Boolean(upgradeDescHtml) && hasUpgradeVersion;
const showUpgradeDesc = showUpgradeLayer && hasUpgradeDesc;
const showBaseDesc = showBaseLayer;
const hasKeywords = Boolean(card.keywords && card.keywords.length > 0);
const keywordLines = hasKeywords
  ? (card.keywords ?? []).map((kw) => ({
      label: keywordLabel(kw),
      key: kw.toLowerCase(),
      tip:
        keywordTipHtmlMap.get(kw.toLowerCase()) ??
        keywordTipHtmlMap.get(keywordLabel(kw).toLowerCase()) ??
        "",
    }))
  : [];
const leadingKeywordOrder = ["innate", "ethereal", "unplayable"];
const leadingKeywordRank = new Map(
  leadingKeywordOrder.map((key, idx) => [key, idx]),
);
const leadingKeywordLines = keywordLines
  .filter((kw) => leadingKeywordRank.has(kw.key))
  .sort(
    (a, b) =>
      (leadingKeywordRank.get(a.key) ?? Number.MAX_SAFE_INTEGER) -
      (leadingKeywordRank.get(b.key) ?? Number.MAX_SAFE_INTEGER),
  );
const trailingKeywordLines = keywordLines.filter(
  (kw) => !leadingKeywordRank.has(kw.key),
);
const hasLeadingKeywords = leadingKeywordLines.length > 0;
const hasTrailingKeywords = trailingKeywordLines.length > 0;
const spawnTitle = isEn ? "Spawns" : "生成卡牌";
const spawnCards = (card.spawns_cards ?? []).map((spawnId) => ({
  id: spawnId,
  label: getSpawnCardName(spawnId),
  image: `${basePath}${getSpawnCardImage(spawnId)}`,
}));
const hasSpawnCards = enableSpawnPreview && spawnCards.length > 0;
const searchText = [
  getDisplayName(card),
  card.name ?? "",
  card.name_zh ?? "",
  baseDesc,
  card.description ?? "",
  card.description_zh ?? "",
  upgradedDesc,
  card.description_upgraded ?? "",
  card.description_upgraded_zh ?? "",
  card.keywords?.join(" ") ?? "",
  getTypeLabel(card),
  card.type ?? "",
  card.rarity ?? "",
]
  .join(" ")
  .toLowerCase();
---

<div class='relative h-full w-full'>
  <article
    class={`group relative left-0 top-0 h-[211px] w-[150px] origin-top-left transition-transform duration-150 ${
      hasSpawnCards ? "hover:scale-[1.08] hover:z-[35]" : ""
    }`}
    data-card='1'
    data-color={card.color ?? "neutral"}
    data-type={card.type?.toLowerCase() ?? "unknown"}
    data-rarity={card.rarity?.toLowerCase() ?? "unknown"}
    data-type-raw={card.type ?? ""}
    data-rarity-raw={card.rarity ?? ""}
    data-color-raw={card.color ?? ""}
    data-cost-raw={getCostBucket(card)}
    data-has-upgrade={hasUpgradeVersion ? "1" : "0"}
    data-search={searchText}
  >
    <div
      class={isAncient
        ? "absolute left-0 top-0 z-[0] h-[211px] w-[150px] overflow-hidden rounded-[16px]"
        : "absolute left-[12.5px] top-[21.5px] z-[0] h-[95px] w-[125px] overflow-hidden rounded-[5px]"}
    >
      <img
        class='h-full w-full object-cover [filter:drop-shadow(0_5px_9px_rgba(0,0,0,0.4))]'
        src={cardImage}
        alt=''
        loading='lazy'
      />
    </div>
    <img
      class='absolute left-0 top-0 z-[1] h-[211px] w-[150px]'
      style={frameStyle}
      src={`${basePath}/images/ui/${frameImage}.png`}
      alt=''
      loading='lazy'
    />
    {
      isInfection && (
        <img
          class='absolute left-[-5px] top-[-5px] z-[5] h-[221px] w-[160px] pointer-events-none object-cover max-w-none'
          data-infection-overlay
          src={`${basePath}/images/card_overlays/infection/infection_00.png`}
          alt=''
          loading='lazy'
        />
      )
    }
    <img
      class='absolute left-0 top-0 z-[5] h-[211px] w-[150px] opacity-60 mix-blend-soft-light'
      src={`${basePath}/images/ui/${frameImageFor(card)}.png`}
      alt=''
      loading='lazy'
    />
    {
      !isAncient && (
        <img
          class='absolute left-[6.25px] top-[23.5px] z-[4] h-[105px] w-[137.5px]'
          style={borderFilter ? `filter: ${borderFilter};` : ""}
          src={`${basePath}/images/ui/${borderImageFor(card)}.png`}
          alt=''
          loading='lazy'
        />
      )
    }
    <img
      class='absolute left-[59.75px] top-[106px] z-[6] h-[18.5px] w-[30.5px]'
      style={borderFilter ? `filter: ${borderFilter};` : ""}
      src={`${basePath}/images/ui/card_portrait_border_plaque2.png`}
      alt=''
      loading='lazy'
    />
    <img
      class={`absolute left-[-10px] ${isAncient ? "top-[1px]" : "top-[6px]"} z-[6] h-[41.5px] w-[170px] max-w-none`}
      style={borderFilter ? `filter: ${borderFilter};` : ""}
      src={`${basePath}/images/ui/${bannerImageFor(card)}.png`}
      alt=''
      loading='lazy'
    />
    {card.cost !== -1 && (
      <div class='absolute left-[-8px] top-[-8px] z-[7] h-[32px] w-[32px]'>
        <img
          class='h-full w-full'
          src={`${basePath}/images/ui/${energyImageFor(card)}.png`}
          alt=''
          loading='lazy'
        />
        <span
          data-cost='base'
          class={`absolute left-[4.5px] top-[3px] z-[8] grid h-[28px] w-[23px] place-items-center text-[16px] font-extrabold text-white [text-shadow:0_1px_0_rgba(0,0,0,0.55),0_0_3px_rgba(0,0,0,0.45)]${showBaseCost ? "" : " hidden"}`}
        >
          {getCostLabel(card)}
        </span>
        {
          showUpgradeLayer && upgradeCost && (
            <span
              data-cost='upgrade'
              class={`absolute left-[4.5px] top-[3px] z-[8] grid h-[28px] w-[23px] place-items-center text-[16px] font-extrabold text-[#7efe00] [text-shadow:0_1px_0_rgba(0,0,0,0.55),0_0_3px_rgba(0,0,0,0.45)]${variant === "auto" ? " hidden" : ""}`}
            >
              {upgradeCost}
            </span>
          )
        }
      </div>
    )}
    <span
      class='absolute left-[59.75px] top-[106px] z-[7] grid h-[18.5px] w-[30.5px] place-items-center text-center text-[8px] font-bold uppercase tracking-[0.08em] text-[#241f17] [text-shadow:0_1px_0_rgba(255,255,255,0.5)]'
    >
      {getTypeLabel(card)}
    </span>
    <span
      data-name='base'
      class={`absolute left-[22.5px] top-[5.5px] font-semibold z-[7] w-[105px] text-center text-[13px] text-[#fdf0d8] [text-shadow:0_1px_2px_rgba(0,0,0,0.35),0_0_2px_rgba(77,75,64,0.95),1px_0_0_rgba(77,75,64,0.9),-1px_0_0_rgba(77,75,64,0.9),0_1px_0_rgba(77,75,64,0.9),0_-1px_0_rgba(77,75,64,0.9)]${showBaseLayer ? "" : " hidden"}`}
    >
      {getDisplayName(card)}
    </span>
    {
      hasUpgradeVersion && showUpgradeLayer && (
        <span
          data-name='upgrade'
          class={`absolute left-[22.5px] top-[5.5px] font-semibold z-[7] w-[105px] text-center text-[13px] text-[#7efe00] [text-shadow:0_1px_2px_rgba(0,0,0,0.35),0_0_2px_rgba(77,75,64,0.95),1px_0_0_rgba(77,75,64,0.9),-1px_0_0_rgba(77,75,64,0.9),0_1px_0_rgba(77,75,64,0.9),0_-1px_0_rgba(77,75,64,0.9)]${variant === "auto" ? " hidden" : ""}`}
        >
          {getDisplayName(card)}+
        </span>
      )
    }
    {
      getStarLabel(card) && (
        <div class='absolute left-[-14px] top-[16px] z-[7] h-[32px] w-[32px]'>
          <img
            class='h-full w-full'
            src={`${basePath}/images/ui/energy_star.png`}
            alt=''
            loading='lazy'
          />
          <span class='absolute left-[4.5px] top-[3px] z-[8] grid h-[28px] w-[23px] place-items-center text-[16px] font-extrabold text-[#ffe3a6] [text-shadow:0_1px_0_rgba(0,0,0,0.55),0_0_3px_rgba(0,0,0,0.45)]'>
            {getStarLabel(card)}
          </span>
        </div>
      )
    }
    {
      (hasBaseDesc || hasUpgradeDesc || hasKeywords) && (
        <div class='absolute left-[14px] top-[124px] z-[6] h-[72px] w-[121.5px] text-center text-[10.5px] leading-[1.02] tracking-[0.02em] text-[#f2e5cd] [text-shadow:0_1px_2px_rgba(0,0,0,0.55),0_0_3px_rgba(0,0,0,0.45),1px_0_0_rgba(0,0,0,0.35),-1px_0_0_rgba(0,0,0,0.35)] flex flex-col items-center justify-center'>
          {hasLeadingKeywords && (
            <div
              class={`${hasBaseDesc || hasUpgradeDesc ? "mb-1" : ""} text-[9px] tracking-[0.08em] text-[#efc751]`}
            >
              {leadingKeywordLines.map((kw) => (
                <div
                  class={kw.tip ? "cursor-help" : ""}
                  data-tip-html={kw.tip ? escapeAttr(kw.tip) : undefined}
                >
                  {kw.label}
                </div>
              ))}
            </div>
          )}
          {showBaseDesc && hasBaseDesc && (
            <div data-desc='base' set:html={baseDescHtml} />
          )}
          {showUpgradeDesc && (
            <div
              data-desc='upgrade'
              class={variant === "auto" && hasBaseDesc ? "hidden" : ""}
              set:html={upgradeDescHtml}
            />
          )}
          {hasTrailingKeywords && (
            <div
              class={`${hasBaseDesc || hasUpgradeDesc ? "mt-1" : ""} text-[9px] tracking-[0.08em] text-[#efc751]`}
            >
              {trailingKeywordLines.map((kw) => (
                <div
                  class={kw.tip ? "cursor-help" : ""}
                  data-tip-html={kw.tip ? escapeAttr(kw.tip) : undefined}
                >
                  {kw.label}
                </div>
              ))}
            </div>
          )}
        </div>
      )
    }
    {
      hasSpawnCards && (
        <div
          class='pointer-events-none absolute left-[156px] top-[8px] z-[30] hidden w-[270px] rounded-[12px] border border-[#8fd0ff]/35 bg-[#0f1624]/95 p-2 shadow-[0_14px_28px_rgba(0,0,0,0.5)] group-hover:block'
        >
          <div class='text-center text-[10px] uppercase tracking-[0.14em] text-[#9bd9ff]'>
            {spawnTitle}
          </div>
          <div class='mt-2 grid grid-cols-2 gap-2'>
            {spawnCards.map((spawn) => (
              <div class='rounded-[8px] border border-white/10 bg-black/25 p-1.5'>
                <img
                  class='h-[72px] w-full rounded-[6px] object-cover'
                  src={spawn.image}
                  alt={spawn.label}
                  loading='lazy'
                />
                <div class='mt-1 line-clamp-2 text-center text-[9px] leading-tight text-[#dff2ff]'>
                  {spawn.label}
                </div>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </article>
</div>

{isInfection && (
  <script is:inline>
    const basePath =
      document.querySelector("[data-base-path]")?.getAttribute("data-base-path") ||
      "";
    const infectionFrames = Array.from({ length: 30 }, (_, idx) => {
      const suffix = String(idx).padStart(2, "0");
      return `${basePath}/images/card_overlays/infection/infection_${suffix}.png`;
    });
    infectionFrames.forEach((src) => {
      const img = new Image();
      img.src = src;
    });
    const infectionOverlays = document.querySelectorAll("[data-infection-overlay]");
    if (infectionOverlays.length) {
      let frame = 0;
      const frameInterval = 1000 / 30;
      setInterval(() => {
        frame = (frame + 1) % infectionFrames.length;
        const src = infectionFrames[frame];
        infectionOverlays.forEach((el) => {
          if (el instanceof HTMLImageElement) {
            el.src = src;
          }
        });
      }, frameInterval);
    }
  </script>
)}
