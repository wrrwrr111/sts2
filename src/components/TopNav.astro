---
import type { Lang } from "../lib/i18n";
import { withLang } from "../lib/i18n";

type Props = {
  current?: "cards" | "relics" | "events" | "monsters" | "characters" | "potions";
  basePath?: string;
  lang?: Lang;
};

const { current = "cards", basePath = "", lang = "zh" } = Astro.props;
const base = basePath.replace(/\/$/, "");
const isEn = lang === "en";
const items = [
  { key: "cards", label: isEn ? "Cards" : "卡牌", href: withLang(`${base}/`, lang) },
  {
    key: "characters",
    label: isEn ? "Characters" : "角色",
    href: withLang(`${base}/characters`, lang),
  },
  { key: "potions", label: isEn ? "Potions" : "药剂", href: withLang(`${base}/potions`, lang) },
  { key: "relics", label: isEn ? "Relics" : "遗物", href: withLang(`${base}/relics`, lang) },
  { key: "events", label: isEn ? "Events" : "事件", href: withLang(`${base}/events`, lang) },
  {
    key: "monsters",
    label: isEn ? "Monsters" : "怪物",
    href: withLang(`${base}/monsters`, lang),
  },
] as const;
---

<nav class='order-first flex w-full flex-nowrap items-center justify-start gap-1.5 overflow-x-auto pb-0.5 text-[10px] uppercase tracking-[0.16em] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden sm:order-none sm:w-auto sm:flex-wrap sm:justify-center sm:gap-2 sm:overflow-visible sm:pb-0 sm:text-[12px] sm:tracking-[0.25em]'>
  {items.map((item) => (
    <a
      class={
        item.key === current
          ? "shrink-0 rounded-[9px] border border-white/15 bg-white/15 px-2 py-1 text-[#f7f1df] sm:rounded-[10px] sm:px-3 sm:py-2"
          : "shrink-0 rounded-[9px] border border-white/10 bg-white/5 px-2 py-1 text-[#9ea2b3] hover:text-[#f7f1df] hover:border-white/20 hover:bg-white/10 transition sm:rounded-[10px] sm:px-3 sm:py-2"
      }
      href={item.href}
      aria-current={item.key === current ? "page" : undefined}
    >
      {item.label}
    </a>
  ))}
</nav>
