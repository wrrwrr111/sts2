---
type Props = {
  current?: "cards" | "relics" | "events" | "monsters";
  basePath?: string;
};

const { current = "cards", basePath = "" } = Astro.props;
const base = basePath.replace(/\/$/, "");
const items = [
  { key: "cards", label: "卡牌", href: `${base}/` },
  { key: "relics", label: "遗物", href: `${base}/relics` },
  { key: "events", label: "事件", href: `${base}/events` },
  { key: "monsters", label: "怪物", href: `${base}/monsters` },
] as const;
---

<nav class='flex flex-wrap items-center justify-center gap-2 text-[11px] uppercase tracking-[0.2em] sm:text-[12px] sm:tracking-[0.25em]'>
  {items.map((item) => (
    <a
      class={
        item.key === current
          ? "rounded-[10px] border border-white/15 bg-white/15 px-2.5 py-1.5 text-[#f7f1df] sm:px-3 sm:py-2"
          : "rounded-[10px] border border-white/10 bg-white/5 px-2.5 py-1.5 text-[#9ea2b3] hover:text-[#f7f1df] hover:border-white/20 hover:bg-white/10 transition sm:px-3 sm:py-2"
      }
      href={item.href}
      aria-current={item.key === current ? "page" : undefined}
    >
      {item.label}
    </a>
  ))}
</nav>
